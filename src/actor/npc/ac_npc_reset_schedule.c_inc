static void aRST_ready_sailing(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    if (aRI_get_door_alpha_percent() == 0.0f) {
        if (actor->timer > 0) {
            actor->timer--;
        } else {
            aRST_setup_think_proc(actor, play, ++actor->think_idx);
        }
    }
}

static void aRST_sailing(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    if (aRST_CHAIR(actor)->act_idx == aRC_ACT_HIDE) {
        if (actor->timer > 0) {
            actor->timer--;
        } else {
            aRST_setup_think_proc(actor, play, ++actor->think_idx);
        }
    }
}

static void aRST_settlement(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    if (aRI_get_door_alpha_percent() == 1.0f) {
        aRST_setup_think_proc(actor, play, ++actor->think_idx);
        mPlib_request_main_wait_type3((GAME*)play);
    }
}

static void aRST_hide(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    if (actor->timer > 0) {
        actor->timer--;
    } else if (!mDemo_CheckDemo()) {
        if (!mPlib_check_label_player_demo_wait((GAME*)play, actor)) {
            mPlib_request_main_demo_wait_type1((GAME*)play, FALSE, actor);
        } else {
            aRST_setup_think_proc(actor, play, ++actor->think_idx);
        }
    }
}

static void aRST_return(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    if (aRST_CHAIR(actor)->act_idx == aRC_ACT_WAIT) {
        if (actor->timer > 0) {
            actor->timer--;
        } else {
            aRST_setup_think_proc(actor, play, ++actor->think_idx);
        }
    }
}

static void aRST_reset_ainote(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    if (Common_Get(event_common).resetcenter_flags & 0x80) {
        actor->talk_flag = 0;
        Common_Get(event_common).resetcenter_flags &= ~0x80;
    }

    if (Common_Get(event_common).resetcenter_flags & 0x20) {
        actor->talk_flag = 5;
        Common_Get(event_common).resetcenter_flags &= ~0x20;
    }

    if (Common_Get(event_common).resetcenter_flags & 0x40) {
        actor->talk_flag = 4;
        Common_Get(event_common).resetcenter_flags &= ~0x40;
    }

    if (Common_Get(event_common).resetcenter_flags & 0x10) {
        aRST_setup_think_proc(actor, play, ++actor->think_idx);
        Common_Get(event_common).resetcenter_flags &= ~0x10;
    }
}

static void aRST_racket_ainote(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    if (Common_Get(event_common).resetcenter_flags & 0x8) {
        actor->talk_flag = 0;
        Common_Get(event_common).resetcenter_flags &= ~0x8;
    }

    if (Common_Get(event_common).resetcenter_flags & 0x2) {
        actor->talk_flag = 6;
        Common_Get(event_common).resetcenter_flags &= ~0x2;
    }

    if (Common_Get(event_common).resetcenter_flags & 0x4) {
        actor->talk_flag = 4;
        Common_Get(event_common).resetcenter_flags &= ~0x4;
    }

    if (Common_Get(event_common).resetcenter_flags & 0x1) {
        aRST_setup_think_proc(actor, play, ++actor->think_idx);
        Common_Get(event_common).resetcenter_flags &= ~0x1;
    }
}

static void aRST_hunt(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    if (actor->look_range != 0) {
        aRST_setup_think_proc(actor, play, ++actor->think_idx);
    }
}

static void aRST_remain(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    if (aRST_sailing_process(actor)) {
        aRST_setup_think_proc(actor, play, ++actor->think_idx);
    }
}

static void aRST_timer(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    if (actor->timer > 0) {
        actor->timer--;
    } else {
        aRST_setup_think_proc(actor, play, ++actor->think_idx);
    }
}

static void aRST_think_main_proc(NPC_ACTOR* nactorx, GAME_PLAY* play) {
    NPC_RESET_ACTOR* actor = (NPC_RESET_ACTOR*)nactorx;

    actor->think_proc(actor, play);
}

static void aRST_think_init_proc(NPC_ACTOR* nactorx, GAME_PLAY* play) {
    static u8 reset_table[] = {
        0x09, 0x0C, 0x13, 0x15, 0x1F, 0x20, 0x21, 0x26,
        0x0B, 0x12, 0x14, 0x1E, 0x1F, 0x20, 0x25, 0x29,
    };

    static u8 racket_table[] = {
        0x2A, 0x2B, 0x32, 0x33, 0x39, 0x3A, 0x3C, 0x3D,
        0x2A, 0x31, 0x32, 0x38, 0x39, 0x3B, 0x3C, 0x3F,
    };

    NPC_RESET_ACTOR* actor = (NPC_RESET_ACTOR*)nactorx;
    ACTOR* actorx = (ACTOR*)actor;
    u8 think_idx = 0;

    actorx->status_data.weight = MASSTYPE_IMMOVABLE;
    nactorx->collision.check_kind = aNPC_BG_CHECK_TYPE_NONE;
    nactorx->condition_info.demo_flg = aNPC_COND_DEMO_SKIP_BGCHECK | aNPC_COND_DEMO_SKIP_FORWARD_CHECK | aNPC_COND_DEMO_SKIP_MOVE_Y | aNPC_COND_DEMO_SKIP_MOVE_CIRCLE_REV | aNPC_COND_DEMO_SKIP_MOVE_RANGE_CHECK;
    nactorx->collision.BGcheck_radius = 1.0f;
    nactorx->actor_class.position_speed.y = 0.0f;
    nactorx->actor_class.gravity = 0.0f;
    nactorx->actor_class.max_velocity_y = 0.0f;
    nactorx->actor_class.world.position.y = 60.0f;
    NPC_CLIP->animation_init_proc(actorx, aNPC_ANIM_WAIT_R1, FALSE);
    nactorx->draw.main_animation.keyframe.frame_control.mode = cKF_FRAMECONTROL_REPEAT;
    nactorx->talk_info.turn = aNPC_TALK_TURN_HEAD;

    switch (nactorx->actor_class.npc_id) {
        case SP_NPC_RESET_MAJIN:
            think_idx = reset_table[actor->reset_mode_E];
            switch (actor->reset_mode_E) {
                case 7:
                    actorx->talk_distance = 80.0f;
                    break;
            }
            break;
        case SP_NPC_RESET_BROTHER:
            think_idx = racket_table[actor->reset_mode_E];
            break;
    }

    nactorx->condition_info.hide_request = FALSE;
    aRST_setup_think_proc(actor, play, think_idx);
}

static void aRST_normal_wait_init(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    ACTOR* actorx = (ACTOR*)actor;
    cKF_SkeletonInfo_R_c* kf_p = &actor->npc_class.draw.main_animation.keyframe;

    actor->npc_class.action.idx = aNPC_ACT_WAIT;
    aRST_set_request_act(actor, 4, aNPC_ACT_WAIT, aNPC_ACT_TYPE_DEFAULT, aNPC_ACT_OBJ_DEFAULT, 0, 0);
    NPC_CLIP->animation_init_proc(actorx, aNPC_ANIM_WAIT_R1, FALSE);
    kf_p->frame_control.mode = cKF_FRAMECONTROL_REPEAT;
    if (actor->npc_class.actor_class.npc_id == SP_NPC_RESET_BROTHER) {
        kf_p->frame_control.current_frame = RANDOM(kf_p->frame_control.max_frames);
    }
}

static void aRST_ready_sailing_init(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    aRI_request_light_on();
    aRI_request_disappear_door();
    aRST_normal_wait_init(actor, play);

    switch (actor->think_after_talk_idx) {
        case 2:
            actor->timer = 120;
            break;
        case 6:
            actor->timer = 30;
            break;
        default:
            actor->timer = 0;
            break;
    }
}

static void aRST_sailing_init(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    aRST_CHAIR(actor)->next_act_idx = aRC_ACT_SAILING;
    sAdo_OngenTrgStart(0x105, &actor->npc_class.actor_class.world.position);
    actor->timer = 30;
}

static void aRST_settlement_init(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    aRI_request_light_off();
    aRI_request_appear_door();
}

static void aRST_hide_init(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    actor->timer = 600;
}

static void aRST_return_init(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    aRST_CHAIR(actor)->next_act_idx = aRC_ACT_RETURN;
    sAdo_OngenTrgStart(0x105, &actor->npc_class.actor_class.world.position);
    actor->timer = 30;
}

static void aRST_end_init(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    aRST_normal_wait_init(actor, play);
    actor->npc_class.actor_class.talk_distance = 45.0f;
}

static void aRST_start_init(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    aRST_normal_wait_init(actor, play);

    if (actor->npc_class.actor_class.npc_id == SP_NPC_RESET_MAJIN) {
        Common_Get(event_common).resetcenter_flags |= 0x4;
    } else {
        Common_Get(event_common).resetcenter_flags |= 0x40;
    }
}

static void aRST_start2_init(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    aRST_normal_wait_init(actor, play);

    if (actor->npc_class.actor_class.npc_id == SP_NPC_RESET_MAJIN) {
        Common_Get(event_common).resetcenter_flags |= 0x2;
    } else {
        Common_Get(event_common).resetcenter_flags |= 0x20;
    }
}

static void aRST_start3_init(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    if (actor->npc_class.actor_class.npc_id == SP_NPC_RESET_MAJIN) {
        Common_Get(event_common).resetcenter_flags |= 0x1;
    } else {
        Common_Get(event_common).resetcenter_flags |= 0x10;
    }
}

static void aRST_timer_sailing_init(NPC_RESET_ACTOR* actor, GAME_PLAY* play) {
    actor->timer = 10;
}

