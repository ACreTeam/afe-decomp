static int mMsgTag_Com_OpenChoice(mMsg_Window_c* msg_p, int* idx_p) {
    u32 status = msg_p->status_flags;

    if ((status & mMsg_STATUS_FLAG_19) != 0) {
        msg_p->status_flags = status & ~mMsg_STATUS_FLAG_19;
        return mMsg_Main_Cursol_SetSelectWindow_ControlCursol(msg_p, idx_p);
    }

    if ((status & mMsg_STATUS_FLAG_LAST_DELAY) != 0) {
        msg_p->status_flags = status & ~mMsg_STATUS_FLAG_LAST_DELAY;
        msg_p->end_text_cursor_idx = *idx_p;
        msg_p->status_flags |= mMsg_STATUS_FLAG_19;
        return mMsg_RESULT_FALSE;
    }

    msg_p->status_flags = status | mMsg_STATUS_FLAG_LAST_DELAY;
    msg_p->end_text_cursor_idx = *idx_p;
    return mMsg_RESULT_TRUE;
}

