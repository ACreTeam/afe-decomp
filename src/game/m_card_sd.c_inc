}

extern int mSdcard_thread_init(int proc) {
    int started = TRUE;
    OSThread* thread = &MemCardThread;
    
    if (S_SDthread_use_fg == 0) {
        static void (*thread_proc[])(void*) = {
            mSdcardthread_main,
            mSdtr_tiff_write_main,
            mSdtr_mura_write_main,
            mSdtr_sd_format_main,
            mSdtr_mura_read_main,
            mSdtr_sd_tiff_read,
            mSdtr_sd_CheckStation,
            mSdtr_sd_allcount_get,
            mSdtr_sd_nextname_get,
        };

        S_SDthread_use_fg = 1;
        S_SDprobe_fg = 0;
        osCreateThread2(thread, 15, thread_proc[proc], NULL, MemCardStack + sizeof(MemCardStack),
                        sizeof(MemCardStack), 5);
        osStartThread(thread);
    } else {
        started = FALSE;
    }

    return started;
}

extern int mSdcard_thread_endchk(void) {
    int terminated = FALSE;

    if (OSIsThreadTerminated(&MemCardThread)) {
        terminated = TRUE;
        S_SDthread_use_fg = 0;
    }

    return terminated;
}

#define mCD_RESULT_SD_SLOT (-2)
#define mCD_SD_FILE_MAGIC 0x8936
#define mCD_SD_SAVE_DATA_SIZE 0x2E000
