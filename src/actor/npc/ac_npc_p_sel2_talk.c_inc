static void aNPS2_chk_breaking_1(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    int chose_num;

    if (mDemo_Get_OrderValue(mDemo_ORDER_NPC0, 9) != 0) {
        mDemo_Set_OrderValue(mDemo_ORDER_NPC0, 9, 0);
        chose_num = mChoice_GET_CHOSENUM();
        switch (chose_num) {
            case mChoice_CHOICE0:
                aNPS2_change_talk_proc(p_sel2, play, aNPS2_TALK_MSG_WAIT_BREAKING_1);
                aNPS2_search_sd_drive();
                break;
            case mChoice_CHOICE1:
                aNPS2_change_talk_proc(p_sel2, play, aNPS2_TALK_CHK_BREAKING_2);
                break;
            case mChoice_CHOICE2:
                aNPS2_change_talk_proc(p_sel2, play, aNPS2_TALK_WHATS_HAPPEN);
                mMsg_SET_CONTINUE_MSG_NUM(aNPS2_make_msg(p_sel2, aNPS2_MSG_GRP2 + 14));
                break;
        }
    }
}

static void aNPS2_breaking_1_0(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    int ret;
    int chan;
    int msg_no;

    ret = aNPS2_chk_repayment_bg_local(&chan);
    switch (ret) {
        case 0:
            return;
        case 2:
        case 4:
        case 7:
            aNPS2_next_talk_proc(p_sel2, play);
            return;
        case 3:
            msg_no = aNPS2_make_msg(p_sel2, aNPS2_MSG_GRP5 + 2);
            mMsg_SET_CONTINUE_MSG_NUM(msg_no);
            break;
        case 1:
            msg_no = aNPS2_make_msg(p_sel2, aNPS2_MSG_GRP5 + 3);
            mMsg_SET_CONTINUE_MSG_NUM(msg_no);
            break;
        case 5:
            msg_no = aNPS2_make_msg(p_sel2, aNPS2_MSG_GRP2 + 6);
            mMsg_SET_CONTINUE_MSG_NUM(msg_no);
            break;
        case 6:
            msg_no = aNPS2_make_msg(p_sel2, aNPS2_MSG_GRP5 + 7);
            mMsg_SET_CONTINUE_MSG_NUM(msg_no);
            break;
        default:
            msg_no = aNPS2_make_msg(p_sel2, aNPS2_MSG_GRP2 + 6);
            mMsg_SET_CONTINUE_MSG_NUM(msg_no);
            break;
    }

    sAdo_SysLevStop(0x47);
    mMsg_UNSET_LOCKCONTINUE();
    aNPS2_change_talk_proc(p_sel2, play, aNPS2_TALK_WHATS_HAPPEN);
}

static void aNPS2_breaking_1_1(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    static int msg_table[] = { -1, aNPS2_MSG_GRP2 + 16, aNPS2_MSG_GRP0 + 33, aNPS2_MSG_GRP0 + 38,
                               aNPS2_MSG_GRP1 + 6,  aNPS2_MSG_GRP2 + 5,  aNPS2_MSG_GRP2 + 6,
                               aNPS2_MSG_GRP2 + 7,  aNPS2_MSG_GRP2 + 11, aNPS2_MSG_GRP2 + 17,
                               aNPS2_MSG_GRP2 + 18 };
    static int idx_table[] = { -1, aNPS2_TALK_RETURN_TITLE, aNPS2_TALK_RETURN_TITLE, aNPS2_TALK_RETURN_TITLE,
                               aNPS2_TALK_RETURN_TITLE, aNPS2_TALK_WHATS_HAPPEN, aNPS2_TALK_WHATS_HAPPEN,
                               aNPS2_TALK_WHATS_HAPPEN, aNPS2_TALK_WHATS_HAPPEN, aNPS2_TALK_WHATS_HAPPEN,
                               aNPS2_TALK_CHK_OPTION_SDCARD };
    int sd_act;

    sd_act = aNPS2_repayment_village_local(p_sel2, FALSE);
    aNPS2_common_sdcard(p_sel2, play, sd_act, ARRAY_COUNT(msg_table), msg_table, idx_table, TRUE);
}

static void aNPS2_chk_breaking_2(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    aNPS2_common_chk_return(p_sel2, play, aNPS2_TALK_WHATS_HAPPEN);
}

static void aNPS2_breaking_2(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    static int msg_table[] = { -1, -1, aNPS2_MSG_GRP0 + 33, aNPS2_MSG_GRP0 + 38, aNPS2_MSG_GRP1 + 6 };
    static int idx_table[] = { -1, aNPS2_TALK_RETURN_TITLE, aNPS2_TALK_RETURN_TITLE, aNPS2_TALK_RETURN_TITLE,
                               aNPS2_TALK_RETURN_TITLE };
    int sd_act;

    sd_act = aNPS2_breaking_2_local(p_sel2);
    aNPS2_common_sdcard(p_sel2, play, sd_act, ARRAY_COUNT(msg_table), msg_table, idx_table, TRUE);
}

static void aNPS2_chk_kanji(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    int chose_num;
    u8 kanji_lv;

    if (mDemo_Get_OrderValue(mDemo_ORDER_NPC0, 9) != 0) {
        mDemo_Set_OrderValue(mDemo_ORDER_NPC0, 9, 0);
        p_sel2->flags |= 1;
        chose_num = mChoice_GET_CHOSENUM();
        kanji_lv = 5 - chose_num;
        Common_Set(cur_kanji_lv, kanji_lv);
        aNPS2_change_talk_proc(p_sel2, play, aNPS2_TALK_WHATS_HAPPEN);
    }
}

static void aNPS2_chk_option_sdcard(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    int order = mDemo_Get_OrderValue(mDemo_ORDER_NPC0, 9);
    int talk_idx = -1;

    if (order != 0) {
        mDemo_Set_OrderValue(mDemo_ORDER_NPC0, 9, 0);
        switch (mChoice_GET_CHOSENUM()) {
            case mChoice_CHOICE0:
                talk_idx = aNPS2_TALK_MSG_WAIT_RESERVE_SDCARD;
                mMsg_SET_CONTINUE_MSG_NUM(aNPS2_make_msg(p_sel2, aNPS2_MSG_GRP4));
                aNPS2_search_sd_drive();
                break;
            case mChoice_CHOICE1:
                p_sel2->sd_file_count = 0;
                talk_idx = aNPS2_TALK_DELETE_SEL_P_FIRST;
                p_sel2->sd_action = 2;
                break;
            case mChoice_CHOICE2:
                talk_idx = aNPS2_TALK_CHK_SDCARD_DELETE;
                break;
            case mChoice_CHOICE3:
                talk_idx = aNPS2_TALK_CHK_SDCARD_FORMAT;
                break;
            case mChoice_CHOICE4:
                talk_idx = aNPS2_TALK_WHATS_HAPPEN;
                break;
        }

        if (talk_idx != -1) {
            aNPS2_change_talk_proc(p_sel2, play, talk_idx);
        }
    }
}

static void aNPS2_chk_sdcard_delete(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    int order = mDemo_Get_OrderValue(mDemo_ORDER_NPC0, 9);
    int talk_idx = -1;

    if (order != 0) {
        mDemo_Set_OrderValue(mDemo_ORDER_NPC0, 9, 0);
        switch (mChoice_GET_CHOSENUM()) {
            case mChoice_CHOICE0:
                talk_idx = aNPS2_TALK_CHK_DELETE_ALL_V;
                aNPS2_search_sd_drive();
                break;
            case mChoice_CHOICE1:
                talk_idx = aNPS2_TALK_CHK_DELETE_ALL_P;
                aNPS2_search_sd_drive();
                break;
            case mChoice_CHOICE2:
                talk_idx = aNPS2_TALK_COMMON_MESSAGE_WAIT_NO_SOUND;
                p_sel2->sd_slot_no = 0;
                aNPS2_search_sd_drive();
                break;
            case mChoice_CHOICE3:
                p_sel2->sd_file_count = 0;
                talk_idx = aNPS2_TALK_DELETE_SEL_P_FIRST;
                p_sel2->sd_action = 1;
                mMsg_SET_CONTINUE_MSG_NUM(aNPS2_make_msg(p_sel2, aNPS2_MSG_GRP3 + 10));
                break;
            case mChoice_CHOICE4:
                talk_idx = aNPS2_TALK_CHK_OPTION_SDCARD;
                break;
        }

        if (talk_idx != -1) {
            aNPS2_change_talk_proc(p_sel2, play, talk_idx);
        }
    }
}

static void aNPS2_chk_sdcard_format(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    aNPS2_common_chk_return(p_sel2, play, aNPS2_TALK_CHK_OPTION_SDCARD);
}

static void aNPS2_sdcard_format(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    static int msg_table[] = { -1, aNPS2_MSG_GRP3 + 4, aNPS2_MSG_GRP3 + 5, aNPS2_MSG_GRP2 + 17,
                               aNPS2_MSG_GRP2 + 6, aNPS2_MSG_GRP2 + 5 };
    static int idx_table[] = { -1, aNPS2_TALK_WHATS_HAPPEN, aNPS2_TALK_CHK_OPTION_SDCARD,
                               aNPS2_TALK_WHATS_HAPPEN, aNPS2_TALK_WHATS_HAPPEN, aNPS2_TALK_WHATS_HAPPEN };
    int sd_act;

    sd_act = aNPS2_sdcard_format_local(p_sel2);
    if (sd_act == 2 || sd_act == 5) {
        aNPS2_set_slot_name(mCsd_nowdrive_get(), mMsg_FREE_STR3);
    }
    aNPS2_common_sdcard(p_sel2, play, sd_act, ARRAY_COUNT(msg_table), msg_table, idx_table, TRUE);
}

static void aNPS2_chk_delete_all_v(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    aNPS2_common_chk_return(p_sel2, play, aNPS2_TALK_CHK_OPTION_SDCARD);
}

static void aNPS2_delete_all_v(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    static int msg_table[] = { -1, aNPS2_MSG_GRP3 + 9,  aNPS2_MSG_GRP2 + 5,  aNPS2_MSG_GRP2 + 6,
                               aNPS2_MSG_GRP2 + 17, aNPS2_MSG_GRP2 + 18, aNPS2_MSG_GRP3 + 12 };
    static int idx_table[] = { -1, aNPS2_TALK_CHK_OPTION_SDCARD, aNPS2_TALK_WHATS_HAPPEN,
                               aNPS2_TALK_WHATS_HAPPEN, aNPS2_TALK_WHATS_HAPPEN,
                               aNPS2_TALK_CHK_OPTION_SDCARD, aNPS2_TALK_CHK_OPTION_SDCARD };
    int sd_act;

    // @BUG: devs forgot to initialize this in the event talk_idx is invalid
#ifdef BUGFIXES
    sd_act = 0;
#endif

    switch (p_sel2->talk_idx) {
        case aNPS2_TALK_DELETE_ALL_V:
            sd_act = aNPS2_delete_all_v_local(p_sel2);
            break;
        case aNPS2_TALK_DELETE_ALL_P:
            sd_act = aNPS2_delete_all_p_local(p_sel2);
            break;
    }

    if (sd_act != 0) {
        aNPS2_now_sd_drive();
    }
    aNPS2_common_sdcard(p_sel2, play, sd_act, ARRAY_COUNT(msg_table), msg_table, idx_table, TRUE);
}

static void aNPS2_chk_delete_all_p(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    aNPS2_common_chk_return(p_sel2, play, aNPS2_TALK_CHK_OPTION_SDCARD);
}

static void aNPS2_delete_sel_v_first(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    static int msg_table[] = { -1, aNPS2_MSG_GRP3 + 11, aNPS2_MSG_GRP3 + 12, aNPS2_MSG_GRP3 + 19,
                               aNPS2_MSG_GRP2 + 5,  aNPS2_MSG_GRP2 + 6,  aNPS2_MSG_GRP2 + 17,
                               aNPS2_MSG_GRP2 + 18 };
    static int idx_table[] = { -1, aNPS2_TALK_CHK_DELETE_SEL_V, aNPS2_TALK_CHK_OPTION_SDCARD,
                               aNPS2_TALK_CHK_OPTION_SDCARD, aNPS2_TALK_WHATS_HAPPEN,
                               aNPS2_TALK_WHATS_HAPPEN, aNPS2_TALK_WHATS_HAPPEN,
                               aNPS2_TALK_CHK_OPTION_SDCARD };
    int sd_act;

    sd_act = aNPS2_chk_sdcard_village(p_sel2);
    if (sd_act != 0) {
        aNPS2_now_sd_drive();
    }
    aNPS2_common_sdcard(p_sel2, play, sd_act, ARRAY_COUNT(msg_table), msg_table, idx_table, FALSE);
}

static void aNPS2_chk_delete_sel_v(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    int chose_num;

    if (mDemo_Get_OrderValue(mDemo_ORDER_NPC0, 9) != 0) {
        mDemo_Set_OrderValue(mDemo_ORDER_NPC0, 9, 0);
        chose_num = mChoice_GET_CHOSENUM();
        switch (chose_num) {
            case mChoice_CHOICE0:
                aNPS2_next_talk_proc(p_sel2, play);
                break;
            case mChoice_CHOICE1:
                aNPS2_change_talk_proc(p_sel2, play, aNPS2_TALK_DELETE_SEL_V_FIRST);
                mMsg_SET_LOCKCONTINUE();
                break;
            case mChoice_CHOICE2:
                aNPS2_change_talk_proc(p_sel2, play, aNPS2_TALK_CHK_OPTION_SDCARD);
                break;
        }
    }
}

static void aNPS2_delete_sel_v(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    static int msg_table[] = { -1, aNPS2_MSG_GRP3 + 14, aNPS2_MSG_GRP2 + 5,  aNPS2_MSG_GRP2 + 6,
                               aNPS2_MSG_GRP2 + 17, aNPS2_MSG_GRP2 + 18, aNPS2_MSG_GRP3 + 12 };
    static int idx_table[] = { -1, aNPS2_TALK_COMMON_MESSAGE_WAIT_NO_SOUND, aNPS2_TALK_WHATS_HAPPEN,
                               aNPS2_TALK_WHATS_HAPPEN, aNPS2_TALK_WHATS_HAPPEN,
                               aNPS2_TALK_CHK_OPTION_SDCARD, aNPS2_TALK_CHK_OPTION_SDCARD };
    int sd_act;

    sd_act = aNPS2_delete_sel_v_local(p_sel2);
    if (sd_act == 1 && p_sel2->sd_slot_no > 0) {
        p_sel2->sd_slot_no--;
    }
    aNPS2_common_sdcard(p_sel2, play, sd_act, ARRAY_COUNT(msg_table), msg_table, idx_table, TRUE);
}

static void aNPS2_delete_sel_p_first_local(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play, int wait_msg) {
    int ret;
    int msg_no;

    ret = aNPS2_chk_sdcard_photograph(p_sel2);
    switch (ret) {
        case 1:
            if (wait_msg != 0) {
                aNPS2_change_talk_proc(p_sel2, play, aNPS2_TALK_DELETE_SEL_P_SBMN_W);
            } else {
                aNPS2_change_talk_proc(p_sel2, play, aNPS2_TALK_DELETE_SEL_P_SBMN_E);
            }
            break;
        case 2:
            if (wait_msg != 0) {
                msg_no = aNPS2_make_msg(p_sel2, aNPS2_MSG_GRP3 + 12);
                mMsg_SET_CONTINUE_MSG_NUM(msg_no);
            } else {
                msg_no = aNPS2_make_msg(p_sel2, aNPS2_MSG_GRP3 + 19);
                mMsg_SET_CONTINUE_MSG_NUM(msg_no);
            }
            aNPS2_change_talk_proc(p_sel2, play, aNPS2_TALK_CHK_OPTION_SDCARD);
            break;
        case 3:
            aNPS2_change_talk_proc(p_sel2, play, aNPS2_TALK_WHATS_HAPPEN);
            mMsg_SET_CONTINUE_MSG_NUM(aNPS2_make_msg(p_sel2, aNPS2_MSG_GRP2 + 5));
            break;
        case 4:
            aNPS2_change_talk_proc(p_sel2, play, aNPS2_TALK_WHATS_HAPPEN);
            mMsg_SET_CONTINUE_MSG_NUM(aNPS2_make_msg(p_sel2, aNPS2_MSG_GRP2 + 6));
            break;
        case 5:
            aNPS2_change_talk_proc(p_sel2, play, aNPS2_TALK_CHK_OPTION_SDCARD);
            mMsg_SET_CONTINUE_MSG_NUM(aNPS2_make_msg(p_sel2, aNPS2_MSG_GRP2 + 18));
            break;
        case 6:
            aNPS2_change_talk_proc(p_sel2, play, aNPS2_TALK_WHATS_HAPPEN);
            mMsg_SET_CONTINUE_MSG_NUM(aNPS2_make_msg(p_sel2, aNPS2_MSG_GRP2 + 17));
            break;
    }

    if (ret != 1 && wait_msg == 0) {
        mMsg_REQUEST_MAIN_APPEAR_WAIT_TYPE1();
        mMsg_SET_FORCENEXT();
    }
}

static void aNPS2_delete_sel_p_first(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    if (mDemo_Get_OrderValue(mDemo_ORDER_NPC0, 9) != 0) {
        mDemo_Set_OrderValue(mDemo_ORDER_NPC0, 9, 0);
        aNPS2_delete_sel_p_first_local(p_sel2, play, TRUE);
    }
}

static void aNPS2_delete_sel_p_sbmn_w(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    if (mMsg_CHECK_MAIN_WAIT() == TRUE) {
        aNPS2_next_talk_proc(p_sel2, play);
    }
}

static void aNPS2_delete_sel_p_sbmn_e(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    Submenu* submenu = &play->submenu;
    int result;

    if (submenu->open_flag == FALSE) {
        aNPS2_now_sd_drive();
        result = submenu->param3;
        switch (result) {
            case 0:
                mMsg_REQUEST_MAIN_APPEAR_WAIT_TYPE1();
                mMsg_SET_FORCENEXT();
                if (p_sel2->sd_action == 2) {
                    mMsg_SET_CONTINUE_MSG_NUM(aNPS2_make_msg(p_sel2, aNPS2_MSG_GRP3 + 17));
                } else {
                    mMsg_SET_CONTINUE_MSG_NUM(aNPS2_make_msg(p_sel2, aNPS2_MSG_GRP3 + 8));
                }
                aNPS2_change_talk_proc(p_sel2, play, aNPS2_TALK_CHK_OPTION_SDCARD);
                break;
            case 1:
                aNPS2_delete_sel_p_first_local(p_sel2, play, FALSE);
                break;
            case 2:
                if (p_sel2->sd_file_count > 0 && p_sel2->sd_action == 1) {
                    p_sel2->sd_file_count--;
                }
                aNPS2_delete_sel_p_first_local(p_sel2, play, FALSE);
                break;
        }
    }
}

static void aNPS2_chk_repayment_village(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    aNPS2_common_chk_return(p_sel2, play, aNPS2_TALK_CANNOT_REPAYMENT_VILLAGE);
}

static void aNPS2_repayment_village(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    static int msg_table[] = { -1, aNPS2_MSG_GRP2 + 10, aNPS2_MSG_GRP0 + 33, aNPS2_MSG_GRP0 + 38,
                               aNPS2_MSG_GRP1 + 6,  aNPS2_MSG_GRP2 + 5,  aNPS2_MSG_GRP2 + 6,
                               aNPS2_MSG_GRP2 + 7,  aNPS2_MSG_GRP2 + 11, aNPS2_MSG_GRP2 + 17,
                               aNPS2_MSG_GRP2 + 18 };
    static int idx_table[] = { -1, aNPS2_TALK_RETURN_TITLE, aNPS2_TALK_RETURN_TITLE, aNPS2_TALK_RETURN_TITLE,
                               aNPS2_TALK_RETURN_TITLE, aNPS2_TALK_WHATS_HAPPEN, aNPS2_TALK_WHATS_HAPPEN,
                               aNPS2_TALK_WHATS_HAPPEN, aNPS2_TALK_WHATS_HAPPEN, aNPS2_TALK_WHATS_HAPPEN,
                               aNPS2_TALK_CHK_OPTION_SDCARD };
    int sd_act;

    sd_act = aNPS2_repayment_village_local(p_sel2, TRUE);
    aNPS2_common_sdcard(p_sel2, play, sd_act, ARRAY_COUNT(msg_table), msg_table, idx_table, TRUE);
}

static void aNPS2_cannot_repayment_village(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    if (mDemo_Get_OrderValue(mDemo_ORDER_NPC0, 9) != 0) {
        mDemo_Set_OrderValue(mDemo_ORDER_NPC0, 9, 0);
        aNPS2_whats_happen_play(p_sel2, play);
    }
}

static void aNPS2_reserve_sdcard(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    static int msg_table[] = { -1, aNPS2_MSG_GRP4 + 1, aNPS2_MSG_GRP2 + 5,  aNPS2_MSG_GRP2 + 6,
                               aNPS2_MSG_GRP2 + 18, aNPS2_MSG_GRP2 + 17, aNPS2_MSG_GRP2 + 7,
                               aNPS2_MSG_GRP5 + 10 };
    static int idx_table[] = { -1, aNPS2_TALK_CHK_OPTION_SDCARD, aNPS2_TALK_WHATS_HAPPEN,
                               aNPS2_TALK_WHATS_HAPPEN, aNPS2_TALK_CHK_OPTION_SDCARD,
                               aNPS2_TALK_WHATS_HAPPEN, aNPS2_TALK_WHATS_HAPPEN,
                               aNPS2_TALK_WHATS_HAPPEN };
    int sd_act;

    sd_act = aNPS2_reserve_sdcard_local(p_sel2);
    if (sd_act != 0) {
        aNPS2_now_sd_drive();
    }
    aNPS2_common_sdcard(p_sel2, play, sd_act, ARRAY_COUNT(msg_table), msg_table, idx_table, TRUE);
}

static void aNPS2_chk_repayment_bg(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    int ret;
    int chan;

    ret = aNPS2_chk_repayment_bg_local(&chan);
    switch (ret) {
        case 0:
            return;
        case 1:
        case 3:
        case 5:
        case 7:
            aNPS2_whats_happen_play(p_sel2, play);
            break;
        case 2:
            mMsg_SET_CONTINUE_MSG_NUM(aNPS2_make_msg(p_sel2, aNPS2_MSG_GRP5 + 8));
            aNPS2_change_talk_proc(p_sel2, play, aNPS2_TALK_CHK_REPAYMENT_VILLAGE);
            break;
        case 4:
            mMsg_SET_CONTINUE_MSG_NUM(aNPS2_make_msg(p_sel2, aNPS2_MSG_GRP2 + 9));
            aNPS2_change_talk_proc(p_sel2, play, aNPS2_TALK_CANNOT_REPAYMENT_VILLAGE);
            break;
        case 6:
            mMsg_SET_CONTINUE_MSG_NUM(aNPS2_make_msg(p_sel2, aNPS2_MSG_GRP5 + 6));
            aNPS2_change_talk_proc(p_sel2, play, aNPS2_TALK_CANNOT_REPAYMENT_VILLAGE);
            break;
        default:
            aNPS2_whats_happen_play(p_sel2, play);
            break;
    }

    mMsg_UNSET_LOCKCONTINUE();
}

static void aNPS2_clr_pl_data_init(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play) {
    int pl_no = p_sel2->player_no;

    mPO_clear_delivery_mail(mHS_get_arrange_idx(pl_no));
    mPr_ClearPrivateInfo(Save_GetPointer(private_data[pl_no]));
    mHm_ClearHomeInfo(mHS_get_arrange_idx(pl_no));
    mMmd_DeletePresentedByPlayer(pl_no);
    mEv_ClearPersonalEventFlag(pl_no);
    mGH_animal_return_init();
    mSC_LightHouse_Delete_Player(pl_no);
    mMpswd_AllClearHPMailPlayerIdx(pl_no);
    mNW_InitPrivateOriginalData(pl_no);
    mPr_ClearMotherMailInfo(Save_GetPointer(mother_mail[pl_no]));
}

