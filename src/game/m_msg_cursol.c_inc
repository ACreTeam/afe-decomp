static int mMsgTag_Choice_Option(mMsg_Window_c* msg_p, int* idx_p, int count) {
    int id_tbl[mChoice_CHOICE_NUM];
    u8* str_p[mChoice_CHOICE_NUM];
    u8 choice_str[mChoice_CHOICE_NUM][mChoice_CHOICE_STRING_LEN];
    u8* data = msg_p->msg_data->text_buf.data + *idx_p;
    int i;
    ACTOR* actor = msg_p->client_actor_p;

    for (i = 0; i < count; i++) {
        id_tbl[i] = (data[5 + i * 2] << 8) | data[5 + i * 2 + 1];
        mChoice_Load_ChoseStringFromRom(mChoice_Get_base_window_p(), choice_str[i], id_tbl[i], actor);
    }

    for (i = 0; i < mChoice_CHOICE_NUM; i++) {
        if (i < count) {
            str_p[i] = choice_str[i];
        } else {
            str_p[i] = NULL;
        }
    }

    mChoice_Set_choice_data(mChoice_Get_base_window_p(), str_p[0], mChoice_CHOICE_STRING_LEN, str_p[1], mChoice_CHOICE_STRING_LEN, str_p[2],
                            mChoice_CHOICE_STRING_LEN, str_p[3], mChoice_CHOICE_STRING_LEN, str_p[4],
                            mChoice_CHOICE_STRING_LEN, str_p[5], mChoice_CHOICE_STRING_LEN);

    (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
    return mMsg_RESULT_VOID;
}

static int mMsgTag_Choice_Answer(mMsg_Window_c* msg_p, int* idx_p, int choice_idx) {
    u8* data = msg_p->msg_data->text_buf.data + *idx_p;
    int choice_no = mChoice_Get_ChoseNum(mChoice_Get_base_window_p());
    u16 msg_no = mFont_Get_TagPrmU16(data);

    if (choice_idx == 0xFF || choice_idx == choice_no) {
        if (msg_no != 0xFFFF) {
            mMsg_Set_continue_msg_num(msg_p, msg_no);
        } else {
            mMsg_Set_CancelNormalContinue(msg_p);
        }
    }

    (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
    return mMsg_RESULT_VOID;
}

