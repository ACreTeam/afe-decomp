    mCD_memMgr_c* mgr = &l_memMgr;

    if (mgr->workArea != NULL) {
        S_SDprobe_fg = mSD_sdcard_tiff_read_common(mgr->workArea, mgr->init_game_start_info.fileNo,
                                                   mgr->init_game_start_info.chan);
    }
}

void mSdtr_sd_format_main(void* arg) {
