static int mMsgTag_Sys_Ruby(mMsg_Window_c* msg_p, int* idx_p) {
    u8* data = msg_p->msg_data->text_buf.data;
    u8* data_p = data + *idx_p;
    int kana_done = FALSE;
    int ruby_done = FALSE;
    int advance_ruby = FALSE;
    int reset_ruby = FALSE;
    int result = mMsg_RESULT_VOID;
    int pause_frame;
    mFontRuby_c ruby;

    if ((msg_p->status_flags & mMsg_STATUS_FLAG_FAST_TEXT) != 0 && (msg_p->status_flags & mMsg_STATUS_FLAG_CURSOL_JUST) == 0) {
        mMsg_sound_MessageSpeedClear(1);
        msg_p->status_flags &= ~mMsg_STATUS_FLAG_NOT_PAUSE_FRAME;
    } else {
        mMsg_sound_MessageSpeedClear(2);
    }

    pause_frame = !(msg_p->status_flags & mMsg_STATUS_FLAG_NOT_PAUSE_FRAME);
    mFontTag_Get_Ruby(data_p, &ruby);

    if (msg_p->ruby_saved_base_end == 0 && pause_frame) {
        msg_p->ruby_saved_base_end = ruby.cmd_size - 1;
    }

    if (msg_p->ruby_saved_base_end < ruby.cmd_size + ruby.kana_count - 1) {
        if (pause_frame) {
            msg_p->ruby_saved_base_end++;
        }
    } else if (pause_frame) {
        kana_done = TRUE;
    }

    if (msg_p->ruby_saved_reading_end == 0 && pause_frame ) {
        msg_p->ruby_saved_reading_end = ruby.ruby_start - 1;
    }

    if (msg_p->ruby_saved_reading_end < ruby.ruby_start + ruby.ruby_count - 1) {
        if (pause_frame) {
            advance_ruby = TRUE;
            msg_p->ruby_saved_reading_end++;
        }
    } else if (pause_frame) {
        ruby_done = TRUE;
    }

    if (msg_p->font_bank == 0) {
        if (ruby_done) {
            reset_ruby = TRUE;
        }
    } else if (kana_done && ruby_done) {
        reset_ruby = TRUE;
    }

    if (reset_ruby || msg_p->cancel_flag != 0) {
        msg_p->ruby_saved_reading_end = 0;
        msg_p->ruby_saved_base_end = 0;
        msg_p->font_bank = 0;
        msg_p->status_flags &= ~mMsg_STATUS_FLAG_NOT_PAUSE_FRAME;
        result = mMsgTag_dummy_proc(msg_p, idx_p);
    } else {
        msg_p->end_text_cursor_idx = *idx_p;
        msg_p->status_flags ^= mMsg_STATUS_FLAG_NOT_PAUSE_FRAME;
        msg_p->status_flags |= mMsg_STATUS_FLAG_20;

        if (!ruby_done &&
            mMsg_sound_CodeVoice(msg_p, *idx_p + msg_p->ruby_saved_reading_end, advance_ruby) != 0) {
            msg_p->status_flags |= mMsg_STATUS_FLAG_21;
        }

        result = mMsg_RESULT_TRUE;
    }

    return result;
}

