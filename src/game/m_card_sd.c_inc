int mCsd_probe_chk(void) {
    s32 chan;
    s32 mem_size = 0;
    s32 sector_size = 0;
    int ret = mCD_SD_PROBE_NO_SD;

    for (chan = 0; chan < CARD_NUM_CHANS; chan++) {
        s32 probe_res;

        do {
            probe_res = EXIProbeEx(chan);
        } while (probe_res == 0);

        if (probe_res == 1) {
            s32 card_res = CARDProbeEx(chan, &mem_size, &sector_size);

            if (card_res == CARD_RESULT_READY && sector_size == mCD_MEMCARD_SECTORSIZE) {
                ret = 0;
            } else {
                ret = mSD_sdcard_test(chan);
                mCsd_nowdrive_set(chan);
                break;
            }
        }
    }

    return ret;
}

extern int mSdcardprobe_fg_chk(void) {
    return S_SDprobe_fg;
}

void mSdcardthread_main(void* arg) {
    S_SDprobe_fg = mCsd_probe_chk();
}

void mSdtr_tiff_write_main(void* arg) {
    mCD_memMgr_c* mgr = &l_memMgr;

    if (mgr->workArea != NULL) {
        S_SDprobe_fg = mSD_sdcard_tiff_write(mgr->workArea, mCsd_tiffBufferSize_get());
    }
}

void mSdtr_mura_write_main(void* arg) {
    mCD_memMgr_c* mgr = &l_memMgr;

    if (mgr->workArea != NULL) {
        S_SDprobe_fg = mSD_sdcard_mura_write(mgr->workArea, mCD_SD_MURA_WRITE_SIZE, mgr->save_home_info._20);
    }
}

void mSdtr_mura_read_main(void* arg) {
    mCD_memMgr_c* mgr = &l_memMgr;

    if (mgr->_0014 != NULL) {
