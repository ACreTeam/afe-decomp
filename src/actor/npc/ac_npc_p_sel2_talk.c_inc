static void aNPS2_talk_init_proc(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play, int talk_idx) {
    // clang-format off
    static aNPS2_TALK_INIT_PROC init_proc[] = {
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_SETUP_YURE
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_SETUP_SOUND
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_SETUP_VOICE
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_SETUP_VOICE_OK
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_WHATS_HAPPEN
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_CHK_OPTION
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_CHK_OPTION2
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_CHK_CLR_VILLAGE_DATA_CARTRIDGE
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_CLR_VILLAGE_DATA_CARTRIDGE
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_CHK_CLR_PL_DATA
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_CHK_CLR_PL_DATA2
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_CHK_CLR_PL_DATA3
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_CHK_CLR_PL_DATA4
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_CHK_CLR_PASSPORT_FILE
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_CLR_PASSPORT_FILE
        &aNPS2_clr_pl_data_init, // aNPS2_TALK_CLR_PL_DATA
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_TI_MENU_OPEN_MSG_WAIT
        &aNPS2_ti_menu_open_wait_init, // aNPS2_TALK_TI_MENU_OPEN_WAIT
        &aNPS2_ti_menu_close_wait_init, // aNPS2_TALK_TI_MENU_CLOSE_WAIT
        &aNPS2_select_player_init, // aNPS2_TALK_SELECT_PLAYER
        &aNPS2_select_card_player_init, // aNPS2_TALK_SELECT_CARD_PLAYER
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_CHK_FUZAI_PLAYER
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_CHK_KITAKU_PLAYER
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_START_TYPE0
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_START_TYPE1
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_START_TYPE2
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_START_TYPE3
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_RETURN_TITLE
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_CHK_MAKE_SDCARD
        &aNPS2_make_sdcard_bf_init, // aNPS2_TALK_COMMON_MESSAGE_WAIT
        &aNPS2_make_sdcard_init, // aNPS2_TALK_MAKE_SDCARD
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_CHK_BREAKING_1
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_MSG_WAIT_BREAKING_1
        &aNPS2_breaking_1_0_init, // aNPS2_TALK_BREAKING_1_0
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_BREAKING_1_1
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_CHK_BREAKING_2
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_MSG_WAIT_BREAKING_2
        &aNPS2_breaking_2_init, // aNPS2_TALK_BREAKING_2
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_CHK_KANJI
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_CHK_OPTION_SDCARD
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_CHK_SDCARD_DELETE
        &aNPS2_chk_sdcard_format_init, // aNPS2_TALK_CHK_SDCARD_FORMAT
        &aNPS2_sdcard_format_bf_init, // aNPS2_TALK_MSG_WAIT_SDCARD_FORMAT
        &aNPS2_sdcard_format_init, // aNPS2_TALK_SDCARD_FORMAT
        &aNPS2_chk_delete_all_v_init, // aNPS2_TALK_CHK_DELETE_ALL_V
        &aNPS2_delete_all_v_bf_init, // aNPS2_TALK_MSG_WAIT_DELETE_ALL_V
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_DELETE_ALL_V
        &aNPS2_chk_delete_all_p_init, // aNPS2_TALK_CHK_DELETE_ALL_P
        &aNPS2_delete_all_p_bf_init, // aNPS2_TALK_MSG_WAIT_DELETE_ALL_P
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_DELETE_ALL_P
        &aNPS2_delete_sel_v_first_bf_init, // aNPS2_TALK_COMMON_MESSAGE_WAIT_NO_SOUND
        &aNPS2_delete_sel_v_first_init, // aNPS2_TALK_DELETE_SEL_V_FIRST
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_CHK_DELETE_SEL_V
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_MSG_WAIT_DELETE_SEL_V
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_DELETE_SEL_V
        &aNPS2_delete_sel_p_first_init, // aNPS2_TALK_DELETE_SEL_P_FIRST
        &aNPS2_delete_sel_p_sbmn_w_init, // aNPS2_TALK_DELETE_SEL_P_SBMN_W
        &aNPS2_delete_sel_p_sbmn_e_init, // aNPS2_TALK_DELETE_SEL_P_SBMN_E
        &aNPS2_reserve_sdcard_bf_init, // aNPS2_TALK_MSG_WAIT_RESERVE_SDCARD
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_RESERVE_SDCARD
        &aNPS2_chk_repayment_bg_init, // aNPS2_TALK_CHK_REPAYMENT_BG
        &aNPS2_chk_repayment_village_init, // aNPS2_TALK_CHK_REPAYMENT_VILLAGE
        &aNPS2_repayment_village_bf_init, // aNPS2_TALK_MSG_WAIT_REPAYMENT_VILLAGE
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_REPAYMENT_VILLAGE
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_CANNOT_REPAYMENT_VILLAGE
        (aNPS2_TALK_INIT_PROC)&none_proc1, // aNPS2_TALK_WAIT
    };
    // clang-foramt on

    (*init_proc[talk_idx])(p_sel2, play);
}

static void aNPS2_change_talk_proc(NPC_P_SEL2_ACTOR* p_sel2, GAME_PLAY* play, int talk_idx) {
    // clang-format off
    static aNPS2_TALK_PROC process[] = {
        &aNPS2_setup_yure, // aNPS2_TALK_SETUP_YURE
        &aNPS2_setup_sound, // aNPS2_TALK_SETUP_SOUND
