        &aNPS2_common_message_wait, // aNPS2_TALK_MSG_WAIT_DELETE_ALL_V
        &aNPS2_delete_all_v, // aNPS2_TALK_DELETE_ALL_V
        &aNPS2_chk_delete_all_p, // aNPS2_TALK_CHK_DELETE_ALL_P
        &aNPS2_common_message_wait, // aNPS2_TALK_MSG_WAIT_DELETE_ALL_P
        &aNPS2_delete_all_v, // aNPS2_TALK_DELETE_ALL_P
