static int mMsgTag_Base_KanjiCom(mMsg_Window_c* msg_p, int* idx_p) {
    int level;
    int bank;
    int idx = *idx_p;
    u8* data = msg_p->msg_data->text_buf.data + idx;
    int player_kanji_lv = mFont_GetPlayerKanjiLv();

    mFontTag_get_KanjiCom(data, &level, &bank);
    if (level > player_kanji_lv) {
        msg_p->font_bank = mFont_TEX_TYPE_FONT1;
    } else if (bank == 0) {
        msg_p->font_bank = mFont_TEX_TYPE_FONT2;
    } else {
        msg_p->font_bank = mFont_TEX_TYPE_FONT3;
    }

    return mMsgTag_dummy_proc(msg_p, idx_p);
}

static int mMsgTag_Base_KanjiPlLvSet(mMsg_Window_c* msg_p, int* idx_p) {
    Now_Private->kanji_pl_lv = mFont_Get_TagPrmU16(msg_p->msg_data->text_buf.data + *idx_p);
    return mMsgTag_dummy_proc(msg_p, idx_p);
}

static int mMsgTag_Base_KanjiPlLvInc(mMsg_Window_c* msg_p, int* idx_p) {
    u8 player_kanji_lv = Now_Private->kanji_pl_lv;

    if (player_kanji_lv < 5) {
        player_kanji_lv++;
    }
    Now_Private->kanji_pl_lv = player_kanji_lv;
    return mMsgTag_dummy_proc(msg_p, idx_p);
}

static int mMsgTag_Base_KanjiPlLvDec(mMsg_Window_c* msg_p, int* idx_p) {
    u8 player_kanji_lv = Now_Private->kanji_pl_lv;
    if (player_kanji_lv > 0) {
        player_kanji_lv--;
    }
    Now_Private->kanji_pl_lv = player_kanji_lv;
    return mMsgTag_dummy_proc(msg_p, idx_p);
}

