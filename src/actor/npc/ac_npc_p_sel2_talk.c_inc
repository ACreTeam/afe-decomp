    }

    if (p_sel2->sd_result == 0xFF) {
        if (context != aNPS2_SD_CONTEXT_TIFF) {
            ret = mSD_mura_remove_all();
        } else {
            ret = mSD_tiff_remove_all();
        }

        switch (ret) {
            case mCD_TRANS_ERR_NONE:
                p_sel2->sd_result = 1;
                break;
            case 38:
                break;
            case 34:
                p_sel2->sd_result = 3;
                break;
            case 35:
                p_sel2->sd_result = 5;
                break;
            case 36:
            case 41:
            case 46:
            case 50:
                p_sel2->sd_result = 2;
                break;
            case 37:
                p_sel2->sd_result = 4;
                break;
            case 42:
                p_sel2->sd_result = 6;
                break;
            default:
                p_sel2->sd_result = 2;
                break;
        }
    }

    if (p_sel2->sd_action_timer == 0 && p_sel2->sd_result != 0xFF) {
        ret = p_sel2->sd_result;
    } else {
        ret = 0;
    }

    return ret;
}

static int aNPS2_delete_all_p_local(NPC_P_SEL2_ACTOR* p_sel2) {
    return aNPS2_delete_all_vp_local(p_sel2, aNPS2_SD_CONTEXT_TIFF);
}

static int aNPS2_delete_all_v_local(NPC_P_SEL2_ACTOR* p_sel2) {
