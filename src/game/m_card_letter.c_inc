static char l_comment_lt_0_str0[32] ATTRIBUTE_ALIGN(4) = "どうぶつの森ｅ＋";
static char l_comment_lt_0_str1[32] ATTRIBUTE_ALIGN(4) = "手紙の保存１";
static char l_comment_lt_0_str2[32] ATTRIBUTE_ALIGN(4) = "手紙の保存２";
static char l_comment_lt_0_str3[32] ATTRIBUTE_ALIGN(4) = "手紙の保存３";
static char l_comment_lt_0_str4[32] ATTRIBUTE_ALIGN(4) = "手紙の保存４";
static char l_comment_lt_0_str5[32] ATTRIBUTE_ALIGN(4) = "手紙の保存５";
