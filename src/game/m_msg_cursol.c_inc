static int mMsgTag_Jump_Ifsj(mMsg_Window_c* msg_p, int* idx_p) {
    u8* data = msg_p->msg_data->text_buf.data + *idx_p;
    int friendship = mNpc_GetActor2NowPlayerFriendship(msg_p->client_actor_p);
    u8 friendship_min;
    u16 msg_success;
    u16 msg_fail;
    int id;

    mFont_Get_TagPrmU8U16U16(data, &friendship_min, &msg_success, &msg_fail);
    if (friendship >= friendship_min) {
        id = msg_success;
    } else {
        id = msg_fail; 
    }

    mMsg_Set_continue_msg_num(msg_p, id);
    (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
    return mMsg_RESULT_VOID;
}

static int mMsgTag_Jump_Ifjj(mMsg_Window_c* msg_p, int* idx_p) {
    u8* data = msg_p->msg_data->text_buf.data + *idx_p;
    u16 msg_success;
    u16 msg_fail;
    u16 id;

    mFont_Get_TagPrmU16U16(data, &msg_success, &msg_fail);
    if (mLd_PlayerManKindCheck() == NATIVE) {
        id = msg_success;
    } else {
        id = msg_fail; 
    }

    mMsg_Set_continue_msg_num(msg_p, id);
    (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
    return mMsg_RESULT_VOID;
}

static int mMsgTag_Jump_Ifsx(mMsg_Window_c* msg_p, int* idx_p) {
    u8* data = msg_p->msg_data->text_buf.data + *idx_p;
    u16 msg_male;
    u16 msg_female;
    u16 id;

    mFont_Get_TagPrmU16U16(data, &msg_male, &msg_female);
    if (Now_Private->gender == mPr_SEX_MALE) {
        id = msg_male;
    } else {
        id = msg_female;
    }

    mMsg_Set_continue_msg_num(msg_p, id);
    (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
    return mMsg_RESULT_VOID;
}

static int mMsgTag_Jump_Iftl(mMsg_Window_c* msg_p, int* idx_p) {
    u8* data = msg_p->msg_data->text_buf.data + *idx_p;
    int shop_level = mSP_GetShopLevel();
    u16 msg0;
    u16 msg1;
    u16 msg2;
    u16 msg3;
    u16 msg_no;

    mFont_Get_TagPrmU16U16U16U16(data, &msg0, &msg1, &msg2, &msg3);
    if (shop_level == mSP_SHOP_TYPE_ZAKKA) {
        msg_no = msg0;
    } else if (shop_level == mSP_SHOP_TYPE_COMBINI) {
        msg_no = msg1;
    } else if (shop_level == mSP_SHOP_TYPE_SUPER) {
        msg_no = msg2;
    } else {
        msg_no = msg3;
    }

    mMsg_Set_continue_msg_num(msg_p, msg_no);
    (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
    return mMsg_RESULT_VOID;
}

static int mMsgTag_Jump_Ifhl(mMsg_Window_c* msg_p, int* idx_p) {
    mHm_hs_c* house = Common_Get(now_home);
    u8* data = msg_p->msg_data->text_buf.data + *idx_p;
    u16 msg0;
    u16 msg1;
    u16 msg2;
    u16 msg3;
    u16 msg_no;
    
    mFont_Get_TagPrmU16U16U16U16(data, &msg0, &msg1, &msg2, &msg3);
    
    if (house != NULL) {
        int house_level = house->size_info.size;

        if (house_level == mHm_HOMESIZE_SMALL) {
            msg_no = msg0;
        } else if (house_level == mHm_HOMESIZE_MEDIUM) {
            msg_no = msg1;
        } else if (house_level == mHm_HOMESIZE_LARGE) {
            msg_no = msg2;
        } else {
            msg_no = msg3;
        }

        mMsg_Set_continue_msg_num(msg_p, msg_no);
        (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
        return mMsg_RESULT_VOID;
    }

    return mMsgTag_dummy_proc(msg_p, idx_p);
}

