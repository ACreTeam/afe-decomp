        &aNPS2_common_message_wait, // aNPS2_TALK_COMMON_MESSAGE_WAIT
        &aNPS2_make_sdcard, // aNPS2_TALK_MAKE_SDCARD
        &aNPS2_chk_breaking_1, // aNPS2_TALK_CHK_BREAKING_1
        &aNPS2_common_message_wait, // aNPS2_TALK_MSG_WAIT_BREAKING_1
