static int Player_actor_request_main_struggle_secretbase_all(GAME* game, f32 counter, int changed_scene, int prio) {
    if (Player_actor_check_request_main_able(game, mPlayer_INDEX_STRUGGLE_SECRETBASE, prio)) {
        PLAYER_ACTOR* player = GET_PLAYER_ACTOR_GAME(game);
        mPlayer_request_struggle_secretbase_c* req_struggle_secretbase_p = &player->requested_main_index_data.struggle_secretbase;

        req_struggle_secretbase_p->counter = counter;
        req_struggle_secretbase_p->changed_scene = changed_scene;
        Player_actor_request_main_index(game, mPlayer_INDEX_STRUGGLE_SECRETBASE, prio);
        return TRUE;
    }

    return FALSE;
}

static void Player_actor_setup_main_Struggle_secretbase(ACTOR* actorx, GAME* game) {
    PLAYER_ACTOR* player = (PLAYER_ACTOR*)actorx;
    mPlayer_main_struggle_secretbase_c* struggle_secretbase_p;
    mPlayer_request_struggle_secretbase_c* request_struggle_secretbase_p = &player->requested_main_index_data.struggle_secretbase;
    int anim1_idx;
    int part_table_idx;

    struggle_secretbase_p = &player->main_data.struggle_secretbase;
    struggle_secretbase_p->counter = request_struggle_secretbase_p->counter;
    struggle_secretbase_p->changed_scenes = request_struggle_secretbase_p->changed_scene;

    Player_actor_SetupItem_Base1(actorx, mPlayer_ANIM_MOGAKU1, -5.0f, &anim1_idx, &part_table_idx);
    Player_actor_InitAnimation_Base1(actorx, game, mPlayer_ANIM_MOGAKU1, mPlayer_ANIM_MOGAKU1, 1.0f, 1.0f, 0.5f, -5.0f, mPlayer_PART_TABLE_NORMAL);
    player->draw_effect_idx = 1 + eEC_EFFECT_ASE2;
    player->draw_effect_arg1 = 1;
    Player_actor_setup_main_Base(actorx, game);
}

static void Player_actor_settle_main_Struggle_secretbase(ACTOR* actorx, GAME* game) {
    eEC_CLIP->effect_kill_proc(eEC_EFFECT_ASE2, RSV_NO);
}

static void Player_actor_Movement_Struggle_secretbase(ACTOR* actorx) {
    Player_actor_Movement_Base_Stop(actorx, FALSE);
}

static void Player_actor_CulcAnimation_Struggle_secretbase(ACTOR* actorx) {
    f32 last_frame;

    Player_actor_CulcAnimation_Base2(actorx, &last_frame);
}

static void Player_actor_set_eye_pattern_Struggle_secretbase(ACTOR* actorx) {
    Player_actor_set_tex_anime_pattern(actorx);
    Player_actor_set_eye_pattern(actorx, 6);
}

static void Player_actor_ObjCheck_Struggle_secretbase(ACTOR* actorx, GAME* game) {
    Player_actor_Excute_Corect_forStand(actorx, game);
}

static void Player_actor_CheckAndRequest_NextGoToSecretbase_Struggle_secretbase(ACTOR* actorx) {
    PLAYER_ACTOR* player = (PLAYER_ACTOR*)actorx;
    mPlayer_main_struggle_secretbase_c* struggle_secretbase_p = &player->main_data.struggle_secretbase;

    Player_actor_CheckAndRequest_NextGoToSecretbase_common(actorx, &struggle_secretbase_p->counter, &struggle_secretbase_p->changed_scenes);
}

static void Player_actor_main_Struggle_secretbase(ACTOR* actorx, GAME* game) {
    Player_actor_Movement_Struggle_secretbase(actorx);
    Player_actor_Reinput_force_position_angle(actorx, game);
    Player_actor_CulcAnimation_Struggle_secretbase(actorx);
    Player_actor_recover_lean_angle(actorx);
    Player_actor_set_eye_pattern_Struggle_secretbase(actorx);
    Player_actor_ObjCheck_Struggle_secretbase(actorx, game);
    Player_actor_Item_main(actorx, game);
    Player_actor_CheckAndRequest_NextGoToSecretbase_Struggle_secretbase(actorx);
}
