static int mCD_SavePostOffice_get_status(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int ret;

    ret = mCD_get_status_common(mgr, fileInfo, mgr->filename, 0, CARD_COMMENT_SIZE, CARD_STAT_ICON_C8, CARD_STAT_SPEED_SLOW, 1,
                              CARD_STAT_BANNER_C8);
    if (ret == mCD_RESULT_ERROR) {
        mCD_SavePostOffice_set_rewrite_main(mgr, fileInfo);
        ret = mCD_RESULT_SUCCESS;
    }

    return ret;
}

static int mCD_SavePostOffice_set_status(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    Save_t* save;
    mCD_memMgr_card_info_c* card;
    s32 chan;
    int ret;

    chan = mgr->chan;
    if (chan != -1) {
        card = &mgr->cards[chan];
        ret = mCD_set_file_status_bg(&card->stat, mgr->filename, chan, &card->result);
        if (ret == mCD_RESULT_SUCCESS) {
            mgr->chan = S_mura_slot_no;
            mgr->loaded_file_type = mCD_FILE_SAVE_MAIN;
            mgr->workArea_size = mCD_get_size(mgr->loaded_file_type);
            bzero(mgr->workArea, mgr->workArea_size);
            chan = mgr->chan;
            card = &mgr->cards[chan];
            if (mCD_load_file(mgr->workArea, mgr->loaded_file_type, chan, &card->result) == mCD_RESULT_SUCCESS) {
                u16 checksum = mFRm_ReturnCheckSum((u16*)mgr->workArea, mgr->workArea_size);
                save = (Save_t*)mgr->workArea;

                if (checksum == 0 &&
                    mLd_CheckId(save->land_info.id) == TRUE && mLd_CheckThisLand(save->land_info.name, save->land_info.id) == TRUE) {
                    fileInfo->proc = 13; /* TODO: proc enum */
                    mgr->loaded_file_type = mCD_FILE_SAVE_MAIN_BAK;
                    mgr->workArea_size = mCD_get_size(mgr->loaded_file_type);
                    ret = mCD_RESULT_SUCCESS;
                } else {
                    fileInfo->_04 = mCD_TRANS_ERR_DAMAGED;
                    ret = mCD_RESULT_ERROR;
                }
            } else {
                fileInfo->_04 = mCD_TransErrorCode_nes(card->result);
                ret = mCD_RESULT_ERROR;
            }
        } else if (ret != mCD_RESULT_BUSY) {
            ret = mCD_SavePostOffice_set_rewrite_main(mgr, fileInfo);
        }
    } else {
        fileInfo->_04 = mCD_TRANS_ERR_NOCARD;
        ret = mCD_RESULT_ERROR;
    }

    return ret;
}

static int mCD_SavePostOffice_write_bk(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int ret = mCD_SaveMydesign_write_bk(mgr, fileInfo);
    // TODO: enums
    if (fileInfo->proc == 14) {
        fileInfo->proc = 14;
    }

    return ret;
}

// TODO: it's probably not 'void* buf'
// TODO: it looks like save_home_info has a generic 'param' member instead of 'fileNo' or 'chan'.
extern int mCD_SavePostOffice_bg(void* buf, s32 chan, s32 idx) {
    // clang-format off
    static mCD_SAVEHOME_PROC save_proc[] = {
        mCD_SavePostOffice_bg_get_area,
        mCD_SavePostOffice_mura_check_slot,
        mCD_SavePostOffice_check_repair_land,
        mCD_SavePostOffice_repair_land,
        mCD_SavePostOffice_check_slot,
        mCD_SavePostOffice_set_data,
        mCD_SavePostOffice_write_main,
        mCD_SavePostOffice_make_file_name,
        mCD_SavePostOffice_create_file,
        mCD_SaveLetter_set,
        mCD_SavePostOffice_write,
        mCD_SavePostOffice_get_status,
        mCD_SavePostOffice_set_status,
        mCD_SavePostOffice_write_bk,
    };
    // clang-format on

    mCD_memMgr_c* mgr = &l_memMgr;
    mCD_memMgr_fileInfo_c* fileInfo = &mgr->save_home_info;
    int ret = mCD_TRANS_ERR_BUSY;
    u8 proc;
    int res;

    proc = (u8)fileInfo->proc;
    mgr->_115C = buf;
    if (proc == 0) {
        mgr->chan = chan;
        fileInfo->fileNo = chan;
        fileInfo->chan = idx;
    }

    mgr->_0188++;
    if (mgr->_018C == 0) {
        if (proc < 14) {
            res = (*save_proc[proc])(mgr, fileInfo);
            if (res == mCD_RESULT_SUCCESS) {
                if (fileInfo->proc == 14) {
                    ret = mCD_TRANS_ERR_NONE;
                }
            } else if (res != mCD_RESULT_BUSY) {
                ret = fileInfo->_04;
            }

            if (res == mCD_RESULT_ERROR || (res == mCD_RESULT_SUCCESS && fileInfo->proc == 14)) {
                if (mgr->_0188 >= 112) {
                    sAdo_SysLevStop(NA_SE_47);
                    mCD_ClearMemMgr_com2(mgr);
                } else {
                    mgr->_018C = 1;
                    mgr->_0190 = ret;
                    ret = mCD_TRANS_ERR_BUSY;
                    if (mgr->_0190 == mCD_TRANS_ERR_BUSY) {
                        mgr->_0190 = mCD_TRANS_ERR_NOCARD;
                    }
                }
            }
        } else {
            ret = mCD_TRANS_ERR_NONE;
            mCD_ClearMemMgr_com2(mgr);
        }
    } else if (mgr->_0188 >= 112) {
        ret = mgr->_0190;
        mCD_ClearMemMgr_com2(mgr);
        sAdo_SysLevStop(NA_SE_47);
    }

    if (ret != mCD_TRANS_ERR_BUSY) {
        SoftResetEnable = TRUE;
    }

    return ret;
}

extern void mCD_LoadLetter(s32 chan, s32 idx, mCD_keep_mail_c* keep_mail) {
    mCD_memMgr_c* mgr = &l_memMgr;
    LetterSave_c* save;
    mCD_memMgr_fileInfo_c* fileInfo;
    s32 result = 0;
    int failed = FALSE;
    int res;

    fileInfo = &mgr->save_home_info;
    if (idx < 5) {
        res = mCD_bg_get_area_common(mgr, fileInfo, mCD_FILE_MAIL, 2);
        save = (LetterSave_c*)mgr->workArea;
        if (res == mCD_RESULT_SUCCESS) {
            mgr->loaded_file_type = mCD_FILE_MAIL;
            mgr->workArea_size = mCD_get_size(mCD_FILE_MAIL);
            bzero(save, mgr->workArea_size);
            bcopy(l_mCD_letter0_file_name, mgr->filename, 0x20);
            mgr->filename[0x11] = '0' | (idx & 0xF);
            mgr->filename[0x12] = '\0';
            if (mCD_read_fg(save, mgr->filename, mCD_MAIL_SAVE_SIZE, 0, chan, &result) == mCD_RESULT_SUCCESS) {
                if (mFRm_ReturnCheckSum((u16*)&save->mail.checksum, l_aram_real_size_32_table[mCD_ARAM_DATA_MAIL]) == 0) {
                    S_comp_code = save->mail.landid;
                    bcopy(&save->mail, keep_mail, l_aram_real_size_32_table[mCD_ARAM_DATA_MAIL]);
                } else {
                    failed = TRUE;
                }
            } else {
                failed = TRUE;
            }
        }
    } else {
        failed = TRUE;
    }

    if (failed == TRUE) {
        mCD_set_init_mail_data(keep_mail);
    }

    mCD_ClearMemMgr_com2(mgr);
    mCD_TransErrorCode_nes(result);
}

typedef struct {
    int unk;
    CARDFileInfo fileInfo;
} mCD_card_file_info2_c;

extern int mCD_CheckLoadOldData(mCD_keep_mail_c* mail) {
    volatile mCD_card_file_info2_c fileInfo2;
    CARDFileInfo fileInfo;
    s32 checkResult;
    CARDStat cardStat;
    s32 fileNo;
    void* workArea;
    int foundOldData;
    s32 chan;

    foundOldData = FALSE;
    for (chan = 0; chan < CARD_NUM_CHANS; chan++) {
        workArea = NULL;
        if (mCD_check_card(&checkResult, mCD_MEMCARD_SECTORSIZE, (int)chan) == mCD_RESULT_SUCCESS) {
            workArea = mCD_malloc_32(CARD_WORKAREA_SIZE);
            checkResult = CARDMount((s32)chan, workArea, NULL);
            if (checkResult == CARD_RESULT_READY || checkResult == CARD_RESULT_BROKEN) {
                checkResult = CARDCheck((s32)chan);
                if (checkResult == CARD_RESULT_READY) {
                    for (fileNo = 0; fileNo < CARD_MAX_FILE; fileNo++) {
                        checkResult = CARDFastOpen((s32)chan, fileNo, &fileInfo);
                        if (checkResult == CARD_RESULT_READY) {
                            fileInfo2.unk = fileInfo.fileNo;
                            checkResult = CARDGetStatus((s32)chan, fileInfo.fileNo, &cardStat);
                            if (cardStat.company[0] == '0' && cardStat.company[1] == '1' &&
                                cardStat.gameName[0] == 'G' && cardStat.gameName[1] == 'A' &&
                                cardStat.gameName[2] == 'F' && cardStat.gameName[3] == 'J') {
                                u16* buf = (u16*)mCD_malloc_32(mCD_LAND_SAVE_SIZE);

                                if (buf != NULL) {
                                    int readPass;

                                    for (readPass = 0; readPass < 2; readPass++) {
                                        s32 read_offset = readPass == 0 ? 0x2000 : 0x20000;
                                        checkResult =
                                            CARDRead(&fileInfo, buf, 0x1E000, read_offset);
                                        if (checkResult == CARD_RESULT_READY &&
                                            mFRm_ReturnCheckSum(buf, 0x1E000) == 0) {
                                            foundOldData = TRUE;
                                            if (mail != NULL) {
                                                memcpy(mail, buf, 0x7820);
                                                break;
                                            }
                                        }
                                    }
                                }

                                zelda_free(buf);
                            }
                            
                            CARDClose(&fileInfo);
                        }
                        if (foundOldData == TRUE) {
                            break;
                        }
                    }
                }
            }

            CARDUnmount((s32)chan);
            if (workArea != NULL) {
                zelda_free(workArea);
            }
        }

        if (foundOldData == TRUE) {
            break;
        }
    }

    return foundOldData;
}

static int mCD_LET_GetSpaceSlot_check_get_area(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int i;

    SoftResetEnable = FALSE;
    S_slot_ok[0] = 0;
    S_slot_ok[1] = 0;

    for (i = 0; i < 6; i++) {
        S_slot_a_file_extence[i] = '\0';
        S_slot_b_file_extence[i] = '\0';
    }

    S_slot_file_count = 0;
    S_slot_slot_count = 0;
    mgr->cards[0].game_result = mCD_TRANS_ERR_NONE;
    mgr->cards[1].game_result = mCD_TRANS_ERR_NONE;

    return mCD_bg_get_area_common(mgr, fileInfo, mCD_FILE_MAIL, 0);
}

static int mCD_LET_GetSpaceSlot_check_mura_check(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int ret = mCD_GetSpaceSlot_check_mura_check(mgr, fileInfo);

    return ret;
}

static int mCD_myletter_GetSpaceSlot_bg(mCD_memMgr_c* mgr, int size, int slot) {
    mCD_memMgr_card_info_c* card;
    int ret = mCD_RESULT_BUSY;
    int space_res;

    card = &mgr->cards[slot];

    if (slot == mCD_SLOT_A) {
        S_slot_a_file_extence[5] = 1;
    } else {
        S_slot_b_file_extence[5] = 1;
    }

    if (card->workArea != NULL) {
        space_res = mCD_get_space_bg(&card->freeBytes, slot, &card->result, card->workArea);
        if (space_res == mCD_RESULT_SUCCESS) {
            ret = mCD_RESULT_SUCCESS;
            S_slot_ok[slot] = mCD_SLOT_B;
            if (card->freeBytes > size) {
                if (mCD_get_file_num(card->workArea, slot) >= CARD_MAX_FILE) {
                    if (slot == mCD_SLOT_A) {
                        S_slot_a_file_extence[5] = '\0';
                    } else {
                        S_slot_b_file_extence[5] = '\0';
                    }
                    mgr->cards[slot].game_result = mCD_TRANS_ERR_NO_FILES;
                } else {
                    ret = mCD_RESULT_SUCCESS;
                    S_slot_ok[slot] = TRUE;
                }
            } else {
                if (slot == mCD_SLOT_A) {
                    S_slot_a_file_extence[5] = '\0';
                } else {
                    S_slot_b_file_extence[5] = '\0';
                }
                mgr->cards[slot].game_result = mCD_TRANS_ERR_NO_SPACE;
            }
        } else if (space_res != mCD_RESULT_BUSY) {
            mgr->cards[slot].game_result = mCD_TransErrorCode_nes(card->result);
            ret = mCD_RESULT_ERROR;
        }
    } else {
        ret = mCD_RESULT_ERROR;
    }

    return ret;
}

static int mCD_LET_GetSpaceSlot_check_spacechk(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int ret = mCD_RESULT_BUSY;
    int space_res;

    space_res = mCD_mydesign_GetSpaceSlot_bg(mgr, mCD_MAIL_SAVE_SIZE, S_slot_slot_count);
    if (space_res != mCD_RESULT_BUSY) {
        if (space_res == mCD_RESULT_SUCCESS) {
            S_slot_ok[S_slot_slot_count] = 1;
        }
        S_slot_slot_count++;
        if (S_slot_slot_count >= 2) {
            ret = mCD_RESULT_SUCCESS;
            S_slot_slot_count = 0;
            fileInfo->proc++;
        }
    }

    return ret;
}

static int mCD_Myletter_existence_check_common(mCD_memMgr_c* mgr, int file_idx, int slot) {
    LetterSave_c* save;
    s32 result;
    int ret;

    save = (LetterSave_c*)mgr->workArea;
    mgr->loaded_file_type = mCD_FILE_MAIL;
    mgr->workArea_size = mCD_get_size(mgr->loaded_file_type);
    bzero(save, mgr->workArea_size);
    bcopy(l_mCD_letter0_file_name, mgr->filename, 0x20);
    mgr->filename[0x11] = '0' | (file_idx & 0xF);
    mgr->filename[0x12] = '\0';
    if (mCD_read_fg(save, mgr->filename, mCD_MAIL_SAVE_SIZE, 0, slot, &result) == mCD_RESULT_SUCCESS) {
        mFRm_ReturnCheckSum((u16*)&save->mail.checksum, l_aram_real_size_32_table[mCD_ARAM_DATA_MAIL]);
        ret = mCD_RESULT_SUCCESS;
    } else {
        if (mgr->cards[slot].game_result == mCD_TRANS_ERR_NONE) {
            mgr->cards[slot].game_result = mCD_TransErrorCode_nes(result);
        }
        ret = mCD_RESULT_ERROR;
    }

    return ret;
}

static int mCD_LET_GetSpaceSlot_check_file_existence(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int ret = mCD_RESULT_BUSY;
    int exists;

    exists = mCD_Mydesign_existence_check_common(mgr, S_slot_file_count, S_slot_slot_count);
    if (exists == mCD_RESULT_SUCCESS) {
        if (S_slot_slot_count == 0) {
            S_slot_a_file_extence[S_slot_file_count] = 1;
        } else {
            S_slot_b_file_extence[S_slot_file_count] = 1;
        }
    }

    S_slot_file_count++;
    if (S_slot_file_count >= 5) {
        S_slot_file_count = 0;
        S_slot_slot_count++;
        if (S_slot_slot_count >= 2) {
            if (S_slot_a_file_extence[0] == '\0' && S_slot_a_file_extence[1] == '\0' &&
                S_slot_a_file_extence[2] == '\0' && S_slot_a_file_extence[3] == '\0' &&
                S_slot_a_file_extence[4] == '\0' && S_slot_a_file_extence[5] == '\0') {
                S_slot_ok[0] = 0;
            }

            if (S_slot_b_file_extence[0] == '\0' && S_slot_b_file_extence[1] == '\0' &&
                S_slot_b_file_extence[2] == '\0' && S_slot_b_file_extence[3] == '\0' &&
                S_slot_b_file_extence[4] == '\0' && S_slot_b_file_extence[5] == '\0') {
                S_slot_ok[1] = 0;
            }

            if (S_slot_a_file_extence[0] == 1 && S_slot_a_file_extence[1] == 1 &&
                S_slot_a_file_extence[2] == 1 && S_slot_a_file_extence[3] == 1 &&
                S_slot_a_file_extence[4] == 1) {
                S_slot_a_file_extence[5] = '\0';
            }

            if (S_slot_b_file_extence[0] == 1 && S_slot_b_file_extence[1] == 1 &&
                S_slot_b_file_extence[2] == 1 && S_slot_b_file_extence[3] == 1 &&
                S_slot_b_file_extence[4] == 1) {
                S_slot_b_file_extence[5] = '\0';
            }

            S_slot_slot_count = 0;

            if (S_slot_ok[0] == 0 && S_slot_ok[1] == 0) {
                mgr->chan = (~fileInfo->_20) & 1;
                if (mgr->cards[mgr->chan].game_result == mCD_TRANS_ERR_NOCARD) {
                    mgr->chan = fileInfo->_20 & 1;
                }
                ret = mCD_RESULT_ERROR;
                fileInfo->_04 = mgr->cards[mgr->chan].game_result;
                S_slot_ok[mgr->chan] = 0xFF;
            } else {
                ret = mCD_RESULT_SUCCESS;
                fileInfo->proc++;
            }
        }
    }

    return ret;
}

// TODO: verify these types
extern int mCD_LET_GetSpaceSlot_check_light_main_bg(u8* slot_ok, u8* slot_a_file_extence, u8* slot_b_file_extence) {
    // clang-format off
    static mCD_SAVEHOME_PROC save_proc[] = {
        mCD_GetSpaceSlot_check_get_area,
        mCD_GetSpaceSlot_check_mura_check,
        mCD_GetSpaceSlot_check_spacechk,
        mCD_GetSpaceSlot_check_file_existence,
    };
    // clang-format on

    mCD_memMgr_c* mgr = &l_memMgr;
    mCD_memMgr_fileInfo_c* fileInfo = &mgr->save_home_info;
    int ret = mCD_TRANS_ERR_BUSY;
    u8 proc;
    int res;

    proc = (u8)fileInfo->proc;
    mgr->_0188++;
    if (mgr->_018C == 0) {
        if (proc < 4) {
            res = (*save_proc[proc])(mgr, fileInfo);
            if (res == mCD_RESULT_SUCCESS) {
                if (fileInfo->proc == 4) {
                    ret = mCD_TRANS_ERR_NONE;
                }
            }

            if (res == mCD_RESULT_ERROR || (res == mCD_RESULT_SUCCESS && fileInfo->proc == 4)) {
                if (res == mCD_RESULT_ERROR) {
                    ret = fileInfo->_04;
                }

                if (mgr->_0188 >= 112) {
                    sAdo_SysLevStop(NA_SE_47);
                    mCD_ClearMemMgr_com2(mgr);
                    if (ret == mCD_TRANS_ERR_BUSY) {
                        ret = mCD_TRANS_ERR_NOCARD;
                    }
                } else {
                    mgr->_0190 = ret;
                    ret = mCD_TRANS_ERR_BUSY;
                    mgr->_018C = 1;
                    if (mgr->_0190 == mCD_TRANS_ERR_BUSY) {
                        mgr->_0190 = mCD_TRANS_ERR_NOCARD;
                    }
                }
            }
        } else {
            ret = mCD_TRANS_ERR_NONE;
            mCD_ClearMemMgr_com2(mgr);
        }
    } else if (mgr->_0188 >= 112) {
        ret = mgr->_0190;
        mCD_ClearMemMgr_com2(mgr);
        sAdo_SysLevStop(NA_SE_47);
    }

    if (ret != mCD_TRANS_ERR_BUSY) {
        SoftResetEnable = TRUE;
    }

    memcpy(slot_ok, S_slot_ok, 2);
    memcpy(slot_a_file_extence, S_slot_a_file_extence, 6);
    memcpy(slot_b_file_extence, S_slot_b_file_extence, 6);

    return ret;
}
