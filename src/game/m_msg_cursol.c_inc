static int mMsgTag_Com_StartKeyChk(mMsg_Window_c* msg_p, int* idx_p) {
    msg_p->status_flags |= mMsg_STATUS_FLAG_KEYCNT;
    msg_p->keyCnt_a = 0;
    msg_p->keyCnt_b = 0;
    msg_p->keyCnt_x = 0;
    msg_p->keyCnt_y = 0;
    msg_p->keyCnt_other = 0;
    return mMsgTag_dummy_proc(msg_p, idx_p);
}

static int mMsgTag_Com_StopKeyChk(mMsg_Window_c* msg_p, int* idx_p) {
    u8 str[mMsg_FREE_STRING_LEN];
    
    msg_p->status_flags &= ~mMsg_STATUS_FLAG_KEYCNT;
    mFont_UnintToString(str, sizeof(str), msg_p->keyCnt_a, 4, TRUE, FALSE, FALSE);
    mMsg_Set_free_str(msg_p, mMsg_FREE_STR0, str, sizeof(str));
    mFont_UnintToString(str, sizeof(str), msg_p->keyCnt_b, 4, TRUE, FALSE, FALSE);
    mMsg_Set_free_str(msg_p, mMsg_FREE_STR1, str, sizeof(str));
    mFont_UnintToString(str, sizeof(str), msg_p->keyCnt_x, 4, TRUE, FALSE, FALSE);
    mMsg_Set_free_str(msg_p, mMsg_FREE_STR2, str, sizeof(str));
    mFont_UnintToString(str, sizeof(str), msg_p->keyCnt_y, 4, TRUE, FALSE, FALSE);
    mMsg_Set_free_str(msg_p, mMsg_FREE_STR3, str, sizeof(str));
    mFont_UnintToString(str, sizeof(str), msg_p->keyCnt_a + msg_p->keyCnt_b + msg_p->keyCnt_x + msg_p->keyCnt_y, 4, TRUE, FALSE, FALSE);
    mMsg_Set_free_str(msg_p, mMsg_FREE_STR4, str, sizeof(str));
    return mMsgTag_dummy_proc(msg_p, idx_p);
}

