extern int mMsg_CopyCountryName(u8* data, int start_idx, int len, u32 capitalize, int not_kanji) {
    int new_len;
    int new_start_idx;
    int command_len = mFont_CodeSize_idx_get(data, start_idx);
    u8* land_name = mLd_GetLandName();
    int land_name_len = mMsg_Get_Length_String(land_name, LAND_NAME_SIZE);

    new_start_idx = start_idx + land_name_len;
    new_len = mMsg_MoveDataCut(data, start_idx + land_name_len, start_idx + command_len, len, FALSE);

    mMsg_CopyString(&data[start_idx], land_name, land_name_len);

    /* Leftover from JP to add 'むら' (mura) to the town name */
    {
        u8 mura_str[mMsg_FREE_STRING_LEN];
        u8* mura_str_p = mura_str;
        int mura_size;

        mString_Load_StringFromRom(mura_str_p, sizeof(mura_str), not_kanji ? 0x1E4 : 0x75D);
        mura_size = mMsg_Get_Length_String(mura_str_p, sizeof(mura_str));
        new_len = mMsg_MoveDataCut(data, new_start_idx + mura_size, new_start_idx, new_len, FALSE);
        mMsg_CopyString(&data[new_start_idx], mura_str_p, mura_size);
    }

    if (capitalize) {
        data[start_idx] = mFont_small_to_capital(data[start_idx]);
    }

    return new_len;
}

static int mMsg_CopyIslandName_sub(u8* data, int start_idx, int len, u32 capitalize, u8* island_name_p, int island_name_len) {
    // clang-format off
    static const u8 string[] = {
        // convert じま (jima) to 島 if Kanji level is set high enough
        CHAR_MESSAGE_TAG, 6, mFont_TAG_GROUP_BASE, (mFont_TAG_BASE_KANJI_COM) >> 8, (mFont_TAG_BASE_KANJI_COM) & 0xFF, 10 + 3,
        CHAR_MESSAGE_TAG, 8, mFont_TAG_GROUP_SYS, (mFont_TAG_SYS_RUBY) >> 8, (mFont_TAG_SYS_RUBY) & 0xFF, 1, CHAR_PP_237, CHAR_PP_030, CHAR_PP_KANJI0_089,
    };
    // clang-format on
    int new_len;
    int command_len = mFont_CodeSize_idx_get(data, start_idx);
    int d_idx = start_idx + island_name_len;

    new_len = mMsg_MoveDataCut(data, start_idx + island_name_len, start_idx + command_len, len, FALSE);
    mMsg_CopyString(data + start_idx, island_name_p, island_name_len);
    // insert the 'island' word string (じま/島) after the island name
    new_len = mMsg_MoveDataCut(data, d_idx + sizeof(string), d_idx, new_len, FALSE);
    mMsg_CopyString(data + d_idx, string, sizeof(string));

    if (capitalize) {
        data[start_idx] = mFont_small_to_capital(data[start_idx]);
    }

    return new_len;
}

extern int mMsg_CopyIslandName(u8* data, int start_idx, int len, u32 capitalize) {
    if (Common_Get(cur_island_house_p) != NULL) {
        Island_c* island = &Common_Get(cur_island_house_p)->island;
        int island_name_len = mMsg_Get_Length_String(island->name, mISL_ISLAND_NAME_LEN);
        return mMsg_CopyIslandName_sub(data, start_idx, len, capitalize, island->name, island_name_len);
    }

    // @BUG - if no island is set, this should return the original length
#ifdef BUGFIXES
    return len;
#endif
}

extern int mMsg_CopyOwnIslandName(u8* data, int start_idx, int len, u32 capitalize) {
    Island_c* island = &Common_Get(now_home)->island;
    int island_name_len = mMsg_Get_Length_String(island->name, mISL_ISLAND_NAME_LEN);
    return mMsg_CopyIslandName_sub(data, start_idx, len, capitalize, island->name, island_name_len);
}

