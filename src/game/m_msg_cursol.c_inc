    }

    mMsg_Set_continue_msg_num(msg_p, id);
    (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
    return mMsg_RESULT_VOID;
}

static int mMsgTag_Str_Opln(mMsg_Window_c* msg_p, int* idx_p) {
    int player_no = Common_Get(player_no);
    int num_owned_houses = 0;
    int house_owner_idx_tbl[PLAYER_NUM];
    int houseIdx;
    int str_no;
    u8 player_name[PLAYER_NAME_LEN];

    for (houseIdx = 0; houseIdx < PLAYER_NUM; houseIdx++) {
        house_owner_idx_tbl[houseIdx] = -1;
    }

    for (houseIdx = 0; houseIdx < PLAYER_NUM; houseIdx++) {
        int owner = mHS_get_pl_no_detail(houseIdx);

        if (owner >= 0 && owner != player_no) {
            house_owner_idx_tbl[num_owned_houses] = owner;
            num_owned_houses++;
        }
    }

    str_no = 1;
    while (num_owned_houses > 0 && str_no <= 3) {
        int i;
        int pick_idx;
        int rnd;

        rnd = get_random_timer(0, num_owned_houses);
        for (i = 0, pick_idx = -1; i < PLAYER_NUM; i++) {
            if (house_owner_idx_tbl[i] != -1) {
                pick_idx++;
            }

            if (rnd == pick_idx) {
                mPr_GetPlayerName(player_name, house_owner_idx_tbl[i]);
                mMsg_Set_free_str(msg_p, str_no, player_name, PLAYER_NAME_LEN);
                house_owner_idx_tbl[i] = -1;
                str_no++;
                break;
            }
        }
        num_owned_houses--;
    }

    return mMsgTag_dummy_proc(msg_p, idx_p);
}

