static int aNPC_check_talk_now(NPC_ACTOR* nactorx) {
    int ret = FALSE;

    if (aNPC_chk_group_talk(nactorx) == TRUE) {
        if (aNPC_get_talk_now_actor() == nactorx) {
            ret = TRUE;
        }
    } else {
        if (mDemo_Check(mDemo_TYPE_SPEAK, (ACTOR*)nactorx) == TRUE || mDemo_Check(mDemo_TYPE_SPEECH, (ACTOR*)nactorx) == TRUE || mDemo_Check(mDemo_TYPE_TALK, (ACTOR*)nactorx) == TRUE) {
            ret = TRUE;
        }
    }

    return ret;
}

static int aNPC_force_call_req_proc(NPC_ACTOR* nactorx, int msg_no) {
    int ret = FALSE;

    if (nactorx->think.force_call_flag == aNPC_FORCE_CALL_NONE &&
        nactorx->condition_info.talk_condition == aNPC_TALK_TYPE_NONE && mDemo_CAN_ACTOR_TALK((ACTOR*)nactorx)) {
        nactorx->think.force_call_flag = aNPC_FORCE_CALL_REQUEST;
        nactorx->think.force_call_msg_no = msg_no;
        nactorx->think.force_call_camera_type = CAMERA2_PROCESS_NORMAL;
        nactorx->think.force_call_talk_turn = aNPC_TALK_TURN_NORMAL;
        ret = TRUE;
    }

    return ret;
}

