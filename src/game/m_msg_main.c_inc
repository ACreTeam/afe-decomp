    const u8* code_p = &data[idx];

    if (mFont_Check_Cont(*code_p) && code_p[1] == mFont_CONT_CODE_SOUND_TRG_SYS && code_p[2] < mFont_SE_NUM) {
        *se_no = code_p[2];
    } else {
