void Museum_Fish_BigFishObjCheck(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* game) {
    int i;
    MUSEUM_FISH_PRIVATE_DATA* fish[2];
    f32 max[2] = { 430.0f, 530.0f };
    fish[0] = &MF_Control_Actor->prvFish[aGYO_TYPE_ARAPAIMA];
    fish[1] = &MF_Control_Actor->prvFish[aGYO_TYPE_GIANT_SNAKEHEAD];

    for (i = 0; i < 2; i++) {
        f32 v;
        xyz_t ip = fish[i]->objchk_pos;
        xyz_t op;
        f32 f27 = actor->init_data.collision_size * (sin_s(actor->angle.y) * 0.3f + 0.7f) + fish[i]->init_data.collision_size;
        f32 f26 = 10.f + (actor->init_data.collision_size * (0.7f + 0.3f * cos_s(actor->angle.y)));
        f32 f25 = actor->init_data.ofs_y + fish[i]->init_data.ofs_y;
        xyz_t_sub(&actor->objchk_pos, &ip, &op);
        if (ABS(op.z) < f26 && ABS(op.y) < f25 && ABS(op.x) < f27) {
            f27 -= ABS(op.x);
            f26 -= ABS(op.z);
            f25 -= ABS(op.y);
            if (f25 < MIN(f27, f26)) {
                if (op.y < 0) {
                    actor->position.y -= MIN(f25, 0.25f);
                    fish[i]->position.y += MIN(f25, 0.05f);
                } else {
                    actor->position.y += MIN(f25, 0.25f);
                    fish[i]->position.y -= MIN(f25, 0.05f);
                }
            } else if (f26 < f27) {
                v = ABS(cos_s(actor->angle.y) * actor->speedF);
                if (op.z < 0) {
                    actor->position.z -= MIN(f26, MAX(0.5f, v));
                    if (fish[i]->objchk_pos.z < max[i] + 10.0f) {
                        fish[i]->position.z += MIN(f26, 0.05f);
                    }
                } else {
                    actor->position.z += MIN(f26, MAX(0.5f, v));
                    if (fish[i]->objchk_pos.z > max[i] - 10.0f) {
                        fish[i]->position.z -= MIN(f26, 0.05f);
                    }
                }
            } else {
                v = ABS(sin_s(actor->angle.y) * actor->speedF);
                if (op.x < 0) {
                    actor->position.x -= MIN(f27, MAX(0.5f, v));
                    fish[i]->position.x += MIN(f27, 0.05f);
                } else {
                    actor->position.x += MIN(f27, MAX(0.5f, v));
                    fish[i]->position.x -= MIN(f27, 0.05f);
                }
            }
        }
    }
}

void Museum_Fish_ObjBGCheck(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* gamex, f32 f1, f32 f2) {
    xyz_t p = suisou_pos[actor->tank];
    f32 a, b, c, d, e;

    switch (actor->tank) {
        case mfish_TANK_0:
            e = 85.0f;
            a = -20.0f + p.x;
            b = 1000.0f + p.x;
            c = -25.0f + p.z;
            d = -1000.0f + p.z;
            break;
        case mfish_TANK_1:
            a = -5.0f + p.x;
            c = -10.0f + p.z;
            b = 1000.0f + p.x;
            d = -1000.0f + p.z;
            // needs cast, temp doesn't work
            e = 75.0f - cos_s((int)DEG2SHORT_ANGLE(180.0f * (actor->objchk_pos.x - a) / 70.0f)) * 5.0f;
            break;
        case mfish_TANK_2:
            e = 80.0f;
            a = -1000.0f + p.x;
            b = -5.0f + p.x;
            c = -20.0f + p.z;
            d = -1000.0f + p.z;
            break;
        case mfish_TANK_3:
            e = 75.0f;
            a = -20.0f + p.x;
            b = 1000.0f + p.x;
            c = -5.0f + p.z;
            d = -1000.0f + p.z;
            break;
        case mfish_TANK_4:
        default:
            return;
    }

    e -= actor->position.y;
    if (e > 0.0f) {
        f32 v1, v2;
        b -= (actor->position.x + (actor->init_data.tank_bounds * f1));
        a -= (actor->position.x - (actor->init_data.tank_bounds * f1));
        c -= (actor->position.z + (actor->init_data.tank_bounds * f2));
        d -= (actor->position.z - (actor->init_data.tank_bounds * f2));
        if (b > 0.0f && c > 0.0f && a < 0.0f && d < 0.0f) {
            if (b > -a) {
                if ((actor->flags & 2) == 0) {
                    actor->flags |= 4;
                }
                v1 = a;
            } else {
                if ((actor->flags & 4) == 0) {
                    actor->flags |= 2;
                }
                v1 = b;
            }

            if (c > -d) {
                if ((actor->flags & 8) == 0) {
                    actor->flags |= 0x10;
                }
                v2 = d;
            } else {
                if ((actor->flags & 0x10) == 0) {
                    actor->flags |= 8;
                }
                v2 = c;
            }

            if (e < MIN(ABS(v2), ABS(v1)) && actor->fishType != 10) {
                actor->position.y += e;
                if (actor->fishType == 3) {
                    actor->goalAngle.x = DEG2SHORT_ANGLE(45);
                } else if (actor->fish_idx == aGYO_TYPE_LOACH) {
                    if (actor->goalAngle.x > DEG2SHORT_ANGLE(30)) {
                        actor->goalAngle.x -= DEG2SHORT_ANGLE(2);
                    } else if (actor->goalAngle.x < DEG2SHORT_ANGLE(-30)) {
                        actor->goalAngle.x += DEG2SHORT_ANGLE(2);
                    }
                }
            } else {
                if (ABS(v2) < ABS(v1)) {
                    actor->position.z += v2;
                } else {
                    actor->position.x += v1;
                }
            }
        }
    }
}

void Museum_Fish_DonkoBGCheck(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* gamex) {
    f32 a, b, d, c;
    f32 f27;
    f32 f24;
    f32 f25;
    f32 f26;
    xyz_t p = suisou_pos[actor->tank];
    f32 v = (sin_s(actor->angle.y) * 0.7f) * (ABS(cos_s(actor->bodyAngle.z)) * 0.5f + 0.5f) + 0.3f;
    f32 v2 = (cos_s(actor->angle.y) * 0.7f) * (ABS(cos_s(actor->bodyAngle.z)) * 0.5f + 0.5f) + 0.3f;
    actor->flags &= ~0x1e;
    actor->avoid_angle = 0;
    Museum_Fish_objchk_pos_set(actor, gamex);

    a = (+00.0f + p.x);
    b = (+45.0f + p.x);
    d = (-17.5f + p.z);
    c = (-45.0f + p.z);

    f27 = 76.0f - 6.0f * cos_s(DEG2SHORT_ANGLE2(180.0f * (actor->objchk_pos.x - p.x) / 55.0f));
    f26 = 76.0f - 6.0f * cos_s(DEG2SHORT_ANGLE2((actor->objchk_pos.x + sin_s(actor->angle.y) - p.x) * 180.0f / 55.0f));

    a -= (actor->position.x + actor->init_data.tank_bounds * v);
    b -= (actor->position.x - actor->init_data.tank_bounds * v);
    c -= (actor->position.z + actor->init_data.tank_bounds * v2);
    d -= (actor->position.z - actor->init_data.tank_bounds * v2);

    actor->distLeftWall = -a;
    actor->distRightWall = b;
    actor->distBackWall = -c;
    actor->distFrontWall = d;

    f27 -= actor->position.y;
    f26 -= actor->position.y;
    if (a > 0.0f) {
        actor->distLeftWall = 0.0f;
        actor->position.x += a;
        actor->flags |= 2;
    } else if (b < 0.0f) {
        actor->distRightWall = 0.0f;
        actor->position.x += b;
        actor->flags |= 4;
    }

    if (c > 0.0f) {
        actor->distBackWall = 0.0f;
        actor->position.z += c;
        actor->flags |= 0x8;
    } else if (d < 0.0f) {
        actor->distFrontWall = 0.0f;
        actor->position.z += d;
        actor->flags |= 0x10;
    }

    if (actor->flags & 2) {
        actor->avoid_angle = DEG2SHORT_ANGLE(-90);
    } else if (actor->flags & 4) {
        actor->avoid_angle = DEG2SHORT_ANGLE(90);
    }

    if (actor->flags & 8) {
        if (actor->flags & 6) {
            actor->avoid_angle = DEG2SHORT_ANGLE(180) - (actor->avoid_angle >> 1);
        } else {
            actor->avoid_angle = DEG2SHORT_ANGLE(-180);
        }
    } else if (actor->flags & 0x10) {
        if (actor->flags & 6) {
            actor->avoid_angle = (actor->avoid_angle >> 1);
        } else {
            actor->avoid_angle = 0;
        }
    }

    f25 = MIN(MIN(actor->distFrontWall, actor->distBackWall), MIN(actor->distRightWall, actor->distLeftWall));
    if (f25 < 5.0f) {
        f27 -= 0.5f * (5.0f - f25);
    }

    f25 = MIN(MIN(actor->distFrontWall - cos_s(actor->angle.y), actor->distBackWall + cos_s(actor->angle.y)),
              MIN(actor->distRightWall - sin_s(actor->angle.y), actor->distLeftWall + sin_s(actor->angle.y)));
    if (f25 < 5.0f) {
        f26 -= 0.5f * (5.0f - f25);
    }
    f26 -= f27;
    actor->goalAngle.x = atans_table(1.0f, -f26);
    if (f27 > 0.0f) {
        actor->position.y += f27;
        actor->speed.y *= 0.95f;
    }
}

void Museum_Fish_objchk_pos_set(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* game) {
    actor->objchk_pos = actor->position;
    actor->objchk_pos.x += (actor->init_data.ofs_z * sin_s(actor->angle.y));
    actor->objchk_pos.z += (actor->init_data.ofs_z * cos_s(actor->angle.y));
}

static void Museum_Fish_old_chk_pos_set(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* game) {
    // UNUSED/STRIPPED
}

void Museum_Fish_BGCheck(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* game) {
    xyz_t p = suisou_pos[actor->tank];
    f32 f29, f30, f28, f27, f26, f25;

    if ((actor->fishType == 0 || actor->fishType == 0xb || actor->fishType == 0x1 || actor->fishType == 0x2) &&
        actor->init_data.tank_bounds < 0) {
        f26 = GETREG(TAKREG, 0x52) * 0.01f + 0.3f +
              (0.7f - GETREG(TAKREG, 0x52) * 0.01f) * ABS(sin_s(actor->angle.y)) *
                  (ABS(cos_s(actor->bodyAngle.z)) * 0.5f + 0.5f);
        f25 = GETREG(TAKREG, 0x52) * 0.01f + 0.3f +
              (0.7f - GETREG(TAKREG, 0x52) * 0.01f) * ABS(cos_s(actor->angle.y)) *
                  (ABS(cos_s(actor->bodyAngle.z)) * 0.5f + 0.5f);
    } else if (actor->fishType == 10 || actor->fishType == 7 || actor->fishType == 9) {
        f26 = GETREG(TAKREG, 0x52) * 0.01f + 0.6f +
              (0.4f - GETREG(TAKREG, 0x52) * 0.01f) * ABS(sin_s(actor->angle.y)) *
                  (ABS(cos_s(actor->bodyAngle.z)) * 0.4f + 0.6f);
        f25 = GETREG(TAKREG, 0x52) * 0.01f + 0.6f +
              (0.4f - GETREG(TAKREG, 0x52) * 0.01f) * ABS(cos_s(actor->angle.y)) *
                  (ABS(cos_s(actor->bodyAngle.z)) * 0.4f + 0.6f);
    } else {
        f26 = 1.0f;
        f25 = 1.0f;
    }

    if (actor->tank < mfish_TANK_4) {
        f30 = 54.0f + actor->init_data.tank_bounds * f26;
        f29 = 54.0f + actor->init_data.tank_bounds * f26;
        f28 = 54.0f + actor->init_data.tank_bounds * f25;
        f27 = 54.0f + actor->init_data.tank_bounds * f25;
    } else {
        f30 = actor->init_data.tank_bounds * f26 + 229.0f;
        f29 = actor->init_data.tank_bounds * f26 + 229.0f;
        f28 = actor->init_data.tank_bounds * f25 + 14.0f;
        f27 = actor->init_data.tank_bounds * f25 + 30.0f;

        if (actor->fish_idx == aGYO_TYPE_SWORDFISH) {
            f28 += -5.0f;
        }
    }

    actor->flags &= ~0x1e;
    actor->avoid_angle = 0;
    Museum_Fish_objchk_pos_set(actor, game);

    if (actor->objchk_pos.x > (p.x + f30)) {
        actor->position.x += (p.x + f30) - actor->objchk_pos.x;
        actor->flags |= 0x4;
    } else if (actor->objchk_pos.x < p.x - f29) {
        actor->position.x += (p.x - f29) - actor->objchk_pos.x;
        actor->flags |= 0x2;
    }

    if (actor->objchk_pos.z > (p.z + f28)) {
        actor->position.z += (p.z + f28) - actor->objchk_pos.z;
        actor->flags |= 0x10;
    } else if (actor->objchk_pos.z < (p.z - f27)) {
        actor->position.z += (p.z - f27) - actor->objchk_pos.z;
        actor->flags |= 0x8;
    }

    Museum_Fish_objchk_pos_set(actor, game);
    actor->distLeftWall = actor->objchk_pos.x - (p.x - f29);
    actor->distRightWall = (p.x + f30) - actor->objchk_pos.x;
    actor->distBackWall = actor->objchk_pos.z - (p.z - f27);
    actor->distFrontWall = (p.z + f28) - actor->objchk_pos.z;

    if (actor->tank < mfish_TANK_4 && actor->fish_idx != aGYO_TYPE_EEL) {
        Museum_Fish_ObjBGCheck(actor, game, f26, f25);
    }

    if (actor->flags & 2) {
        actor->avoid_angle = DEG2SHORT_ANGLE(-90);
    } else if (actor->flags & 4) {
        actor->avoid_angle = DEG2SHORT_ANGLE(90);
    }

    if (actor->flags & 8) {
        if (actor->flags & 6) {
            actor->avoid_angle = (DEG2SHORT_ANGLE(180) - (actor->avoid_angle >> 1));
        } else {
            actor->avoid_angle = DEG2SHORT_ANGLE(-180);
        }
    } else if (actor->flags & 0x10) {
        if (actor->flags & 6) {
            actor->avoid_angle >>= 1;
        } else {
            actor->avoid_angle = DEG2SHORT_ANGLE(0);
        }
    }
}

void Museum_Fish_Kusa_Check(MUSEUM_FISH_ACTOR* actor, GAME* game) {
    static int kusa_group_tbl[14] = {
        mfish_TANK_0,
        mfish_TANK_2,
        mfish_TANK_1,
        mfish_TANK_3,
        mfish_TANK_3,
        mfish_TANK_4,
        mfish_TANK_4,
        mfish_TANK_4,
        mfish_TANK_4,
        mfish_TANK_4,
        mfish_TANK_0,
        mfish_TANK_2,
        mfish_TANK_1,
        mfish_TANK_3,
    };

    MUSEUM_FISH_ACTOR* realActor = (MUSEUM_FISH_ACTOR*)actor; // dangit!
    MUSEUM_FISH_PRIVATE_DATA* f = realActor->prvFish;
    int i;
    int j;
    s16 v;
    f32 f30 = 0.0f;
    f32 f29 = 0.0f;
    f32 f28 = 0.0f;
    f32 temp;
    f32 f1;
    f32 z;
    f32 x;
    f32 dSQ;
    f32 dx;
    f32 dy;
    f32 t;
    f32 sq;
    f32 d;
    
    for (i = 0; i < aGYO_TYPE_NUM; i++, f++) {
        f->flags &= ~0x100;

        // this if statement salso works as a continue statement
        if (f->fish_idx != aGYO_TYPE_EEL && f->fish_idx != aGYO_TYPE_COELACANTH &&
            f->fish_idx != aGYO_TYPE_FROG) {

            for (j = 0; j < 14; j++) {
                f1 = (j < 5) ? 90.0f : (j < 10) ? 115.0f : 80.0f;

                if (kusa_group_tbl[j] == f->tank && f->objchk_pos.y < f1) {
                    if (kusa_group_tbl[j] == mfish_TANK_4) {
                        if (f->fish_idx == aGYO_TYPE_COELACANTH) {
                            d = 5.0f + f->init_data.collision_size;
                        } else {
                            d = 10.0f + f->init_data.collision_size;
                        }
                        dSQ = SQ(d);
                    } else {
                        d = 5.0f + f->init_data.collision_size;
                        dSQ = SQ(d);
                    }

                    x = f->objchk_pos.x - (kusa_pos[j].x + realActor->prvKusa[j].displacementVec.x);
                    z = f->objchk_pos.z - (kusa_pos[j].z + realActor->prvKusa[j].displacementVec.z);

                    sq = SQ(x) + SQ(z);
                    if (sq < dSQ) {
                        v = atans_table(z, x);

                        temp = d - sqrtf(sq);
                        temp *= 0.1f;
                        // d -= sqrtf(sq);
                        // d *= 0.1f;
                        f30 += sin_s(v) * (temp);
                        if (kusa_group_tbl[j] == mfish_TANK_4) {
                            f29 += MAX(cos_s(v), 0.2f) * temp;
                        } else {
                            f29 += cos_s(v) * temp;
                        }

                        f28 += 1;

                        realActor->prvKusa[j].displacementVec.x -= (f->init_data.fish_strength * 1.5f) * temp * sin_s(v);

                        if (kusa_group_tbl[j] == mfish_TANK_4) {
                            realActor->prvKusa[j].displacementVec.z -= (f->init_data.fish_strength * 1.5f) * temp * MAX(cos_s(v), 0.1f);
                        } else {
                            realActor->prvKusa[j].displacementVec.z -= (f->init_data.fish_strength * 1.5f) * temp * cos_s(v);
                        }
                        t = SQ(realActor->prvKusa[j].displacementVec.x) + SQ(realActor->prvKusa[j].displacementVec.z);
                        t = sqrtf(t);
                        if (t > 4.0f) {
                            xyz_t_mult_v(&realActor->prvKusa[j].displacementVec, 4.0f / t);
                        }
                        realActor->prvKusa[j].displacementRot.y = DEG2SHORT_ANGLE(3.5f);
                    }
                }
            }
            if (f28 > 0.0f) {
                f->flags |= 0x100;
                f->position.x += (f30 / f28);
                f->position.z += (f29 / f28);
            }
            f28 = 0.0f;
            f29 = 0.0f;
            f30 = 0.0f;
        }
    }
}

void Museum_Fish_Object_Check(MUSEUM_FISH_ACTOR* actor, GAME* game) {
    int i;
    MUSEUM_FISH_PRIVATE_DATA* fj;
    MUSEUM_FISH_PRIVATE_DATA* f;
    int j;
    f32 f31;
    f32 f30;
    f32 f29;
    xyz_t test;
    f32 f28 = 0.0f;
    f32 f27 = 0.0f;
    f32 f26 = 0.0f;
    f32 f25 = 0.0f;
    f32 f24 = 0.0f;
    f32 f23 = FLT_MAX;
    f32 f22;
    f32 sq_xz;
    f32 sq_xzy;

    fj = f = actor->prvFish;

    for (i = 0; i < aGYO_TYPE_NUM; i++, f++) {
        f->flags &= ~0x20;
    }

    f = actor->prvFish;
    for (i = 0; i < aGYO_TYPE_NUM; i++, f++) {
        if (
            // clang-format off
            i != aGYO_TYPE_FROG &&
            i != aGYO_TYPE_CRAWFISH &&
            i != aGYO_TYPE_EEL &&
            i != aGYO_TYPE_ARAPAIMA &&
            i != aGYO_TYPE_GIANT_SNAKEHEAD &&
            f->flags & 1
            // clang-format on
        ) {
            for (j = 0; j < aGYO_TYPE_NUM; j++, fj++) {
                if (
                    // clang-format off
                    f->tank == fj->tank &&
                    i != j &&
                    j != aGYO_TYPE_FROG &&
                    j != aGYO_TYPE_EEL &&
                    j != aGYO_TYPE_ARAPAIMA &&
                    j != aGYO_TYPE_GIANT_SNAKEHEAD &&
                    (fj->flags & 1) != 0
                    // clang-format on
                ) {

                    test.x = f->objchk_pos.x - fj->objchk_pos.x;
                    test.y = f->objchk_pos.y - fj->objchk_pos.y;
                    test.z = f->objchk_pos.z - fj->objchk_pos.z;
                    sq_xz = SQ(test.x) + SQ(test.z);
                    sq_xzy = sq_xz + SQ(test.y);
                    if (sqrtf(sq_xzy) < f23) {
                        f23 = sqrtf(sq_xzy);
                        f->pClosestFish = fj;
                    }

                    if (ABS(test.y) < (f->init_data.ofs_y + fj->init_data.ofs_y)) {
                        f32 additive = f->init_data.collision_size + fj->init_data.collision_size;

                        if (sq_xz < SQ(additive)) {
                            f22 = additive - sqrtf(SQ(test.x) + SQ(test.z));

                            //! BUG: multiplying by zero?
                            if (test.y > atans_table(sqrtf(SQ(test.x) + SQ(test.z)), test.y) * 0.0f) {
                                test.y = -test.y + (f->init_data.ofs_y + fj->init_data.ofs_y);
                            } else {
                                test.y = -test.y - (f->init_data.ofs_y + fj->init_data.ofs_y);
                            }

                            test.y *= 0.2f + (GETREG(TAKREG, 0x11)) * 0.0001f;
                            f22 *= 0.2f + (GETREG(TAKREG, 0x12)) * 0.0001f;
                            f->escape_angle = atans_table(test.z, test.x);
                            f->flags |= 0x20;
                            fj->escape_angle = f->escape_angle + DEG2SHORT_ANGLE(180);
                            f->flags |= 0x20;
                            f->pCollisionTarget = fj;
                            if ((fj->flags & 0x1e) == 0 || ABS((s16)(fj->avoid_angle - f->escape_angle)) >= DEG2SHORT_ANGLE(90)) {
                                f32 v = (fj->init_data.fish_strength / (f->init_data.fish_strength + fj->init_data.fish_strength));
                                v *= (1.0f - f->init_data.fish_strength);
                                f22 *= v;
                                test.y *= v;
                            } else {
                                f32 v = (2.0f * fj->init_data.fish_strength / (f->init_data.fish_strength + 2.0f * fj->init_data.fish_strength));
                                v *= (1.0f - f->init_data.fish_strength);
                                f22 *= v;
                                test.y *= v;
                            }

                            if (f22 < ABS(test.y) || f->fishType == 0xa || f->fish_idx == aGYO_TYPE_COELACANTH) {
                                f28 += sin_s(f->escape_angle) * f22;
                                f27 += cos_s(f->escape_angle) * f22;
                                f25 += 1.0f;
                            } else {
                                f26 += test.y;
                                f24 += 1;
                            }

                            if (fj->init_data.fish_strength > f->init_data.fish_strength && f->collisionPatience <= f->init_data.collision_size * 10.0f) {
                                f->collisionPatience += f22;
                            }
                        }
                    }
                }
            }

            if (f25 > 0.0f) {
                f->position.x += f28 / f25;
                f->position.z += f27 / f25;
            }

            if (f24 > 0) {
                f->position.y += MAX(MIN(f26 / f24, 0.5f), -0.5f);

                if (f->fishType == 0 || f->fishType == 0xb) {
                    f->yOfsSpeed += f26 / f24;
                }
            }

            if (f24 > 0 && f25 > 0) {
                xyz_t r;
                xyz_t_sub(&f->pCollisionTarget->position, &f->position, &r);
                f->escape_angle = atans_table(r.z, r.x);
            }

            f25 = 0.0f;
            f24 = 0.0f;
            f27 = 0.0f;
            f28 = 0.0f;
            f26 = 0.0f;
            f23 = FLT_MAX;
            fj = actor->prvFish;
        }
        if (f->tank == 3 && f->fishType != 7) {
            Museum_Fish_BigFishObjCheck(f, game);
        }
    }
}

void mfish_body_wind_anime_play(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* game) {
    int a;
    // needs int temp to generate extsh
    a = DEG2SHORT_ANGLE(GETREG(TAKREG, 0x32) * 0.1f + 1.5f + RANDOM_F(1.0f));
    actor->bodyWindPhase0 += a;
    a = DEG2SHORT_ANGLE(GETREG(TAKREG, 0x31) * 0.1f + 0.5f + RANDOM_F(0.5f));
    actor->bodyWindPhase1 += a;
}

void mfish_get_player_angle(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* game, s16* atanx, s16* atany, f32* distance) {
    xyz_t p = GET_PLAYER_ACTOR_GAME_ACTOR(game)->world.position;
    xyz_t p1;
    f32 v;

    p.y += 40.0f;
    xyz_t_sub(&p, &actor->position, &p1);
    v = SQ(p1.x) + SQ(p1.z);
    v = sqrtf(v);
    if (atanx) {
        *atanx = atans_table(p1.z, p1.x);
    }
    if (atany) {
        *atany = atans_table(v, -p1.y);
    }
    if (distance) {
        *distance = v;
    }
}

BOOL mfish_peck_check(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* gamex) {
    Private_c* commonData_prv = Now_Private;

    if (MF_Control_Actor->player_area == actor->tank) {
        if (actor->fish_idx == aGYO_TYPE_PIRANHA) {
            return TRUE;
        } else if (mPr_GetPossessionItemIdx(commonData_prv, ITM_FOOD_CANDY) != -1) {
            if (actor->fish_idx == aGYO_TYPE_CARP || actor->fish_idx == aGYO_TYPE_KOI) {
                return TRUE;
            }
        } else if (mPr_GetPossessionItemIdxItem1Category(commonData_prv, ITEM1_CAT_FRUIT) != -1) {
            if (actor->fish_idx == aGYO_TYPE_GOLDFISH || actor->fish_idx == aGYO_TYPE_POPEYED_GOLDFISH) {
                return TRUE;
            }
        }
    }

    return FALSE;
}

BOOL mfish_peck_wall_check(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* gamex) {
    s16 temp = (actor->angle.y - actor->avoid_angle);
    if (actor->flags & 0x1E && ABS(temp) < DEG2SHORT_ANGLE(45)) {
        xyz_t target = GET_PLAYER_ACTOR_GAME_ACTOR(gamex)->world.position;
        return search_position_distance(&actor->position, &target) < 60.0f;
    }
    return FALSE;
}

BOOL mfish_ground_peck_before_check(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* gamex) {
    xyz_t p, p2;
    f32 v;

    p2 = p = suisou_pos[actor->tank];

    xyz_t_sub(&p2, &actor->position, &p2);

    v = MAX(ABS(p2.x), ABS(p2.z));

    if (actor->currentProcess == mfish_ground_peck_process) {
        return actor->processTimer > 0;
    } else if ((actor->tank == mfish_TANK_2) && (actor->position.x < p.x + 20.0f) && (actor->position.z > p.z - 10.0f) &&
               (actor->position.y < (actor->init_data.collision_size * 0.5f + 75.0f) - (v * 0.15f)) && (RANDOM_F(1.0f) > 0.2f)) {
        return TRUE;
    }

    return FALSE;
}

void mfish_get_player_area(MUSEUM_FISH_ACTOR* actor, GAME* gamex) {
    ACTOR* playerx = GET_PLAYER_ACTOR_GAME_ACTOR(gamex);
    xyz_t p = playerx->world.position;

    if (actor->player_area_update_timer-- < 0) {
        actor->player_area_update_timer = 0x1e;
    } else {
        return;
    }

    if (p.z < 80.0f) {
        actor->player_area = mfish_TANK_4;
        return;
    }

    if (p.z > 120.0f && p.z < 320.0f) {
        if (p.x < 320.0f) {
            actor->player_area = mfish_TANK_0;
        } else {
            actor->player_area = mfish_TANK_1;
        }
        return;
    }

    if (p.z > 360.0f && p.z < 560.0f) {
        if (p.x < 320.0f && p.x > 120.0f) {
            actor->player_area = mfish_TANK_2;
        } else {
            actor->player_area = mfish_TANK_3;
        }
        return;
    }

    actor->player_area = -1;
}

xyz_t mfish_get_flow_vec(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* game) {
    xyz_t p2;
    xyz_t p = suisou_pos[actor->tank];
    xyz_t t;
    xyz_t p3;
    
    f32 s;
    f32 v;
    f32 xy;
    s16 s2;

    f32 d;
    f32 dSQ;

    if (actor->tank == mfish_TANK_0) {
        v = 0.05f;
    } else if (actor->tank == mfish_TANK_1) {
        v = 0.06f;
    } else if (actor->tank == mfish_TANK_2) {
        v = 0.2f;
    } else if (actor->tank == mfish_TANK_3) {
        v = 0.05f;
    } else if (actor->tank == mfish_TANK_4) {
        v = 0.08f;
    }
    xyz_t_sub(&actor->position, &p, &t);
    xy = SQ(t.x) + SQ(t.z);
    s = (sin_s(DEG2SHORT_ANGLE2(360.0f * sqrtf(xy) / 720.0f)) * 0.1f + 0.2f);
    p2.x = s * cos_s(DEG2SHORT_ANGLE2(360.0f * t.x / 60.0f));
    p2.z = s * cos_s(DEG2SHORT_ANGLE2(360.0f * t.z / 60.0f));
    p2.y = (s * 0.5f) * cos_s(DEG2SHORT_ANGLE2(180.0f * t.y / 70.0f));

    s2 = atans_table(t.z, t.x);
    s2 += MF_Control_Actor->tankFlowPhase[actor->tank];

    if (actor->tank == mfish_TANK_2) {
        p2.x += (GETREG(TAKREG, 0xc) * 0.01f + 2.0f) * cos_s(s2);
        p2.z += (GETREG(TAKREG, 0xc) * 0.01f + 2.0f) * sin_s(s2);
    } else {
        p2.x += (GETREG(TAKREG, 0xc) * 0.01f + 1.5f) * cos_s(s2);
        p2.z += (GETREG(TAKREG, 0xc) * 0.01f + 1.5f) * sin_s(s2);
    }

    p2.x *= ABS(cos_s(actor->angle.y) * cos_s(actor->angle.x));
    p2.z *= ABS(sin_s(actor->angle.y) * cos_s(actor->angle.x));

    if (actor->fishType != 3) {
        p2.x *= cos_s(actor->bodyAngle.z);
        p2.z *= cos_s(actor->bodyAngle.z);
    }

    if (actor->tank == mfish_TANK_4) {
        p2.z += (GETREG(TAKREG, 0xb) * 0.01f + 0.5f) * cos_s(actor->angle.y + DEG2SHORT_ANGLE(90));
    } else if (actor->tank == mfish_TANK_2) {
        p2.x -= ABS(cos_s(actor->angle.y)) * 0.02f;
        if (ABS((s16)(actor->angle.y - DEG2SHORT_ANGLE(270))) < DEG2SHORT_ANGLE(100)) {
            p2.x = MIN(-1.0f + GETREG(TAKREG, 0x48) * 0.001f, p2.x);
        }
    }

    if (actor->pClosestFish != NULL) {
        if (actor->tank == mfish_TANK_4) {
            s = actor->pClosestFish->init_data.collision_size * 10.0f + actor->init_data.collision_size * 2.0f;
        } else {
            s = actor->pClosestFish->init_data.collision_size * 5.0f + actor->init_data.collision_size * 2.0f;
        }
        xyz_t_sub(&actor->position, &actor->pClosestFish->position, &p3);
        dSQ = SQ(p3.x) + SQ(p3.y) + SQ(p3.z);
        d = sqrtf(dSQ);

        if (d < s) {
            f32 x = (1.0f / SQ(s)) * (d - s) * (d - s);
            x *= actor->pClosestFish->init_data.fish_strength;
            p2.x += (x * p3.x) / d;
            p2.y += (x * p3.y) / d;
            p2.z += (x * p3.z) / d;
        }
    }

    if (actor->tank == mfish_TANK_2 && p2.x < 0.0f) {
        p2.x *= 1.1f;
    }

    xyz_t_mult_v(&p2, v);
    add_calc2(&actor->flow_vec.x, p2.x, 0.5f, 0.1f);
    add_calc2(&actor->flow_vec.y, p2.y, 0.5f, 0.1f);
    add_calc2(&actor->flow_vec.z, p2.z, 0.5f, 0.1f);
    return actor->flow_vec;
}

s16 mfish_get_escape_angle(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* game) {
    s16 v1 = atans_table(actor->pCollisionTarget->position.z - actor->position.z, actor->pCollisionTarget->position.x - actor->position.x);
    s16 v = actor->angle.y - v1;
    if (ABS(v) < DEG2SHORT_ANGLE(90)) {
        if (actor->fishType == 1 || actor->fishType == 2) {
            if (ABS((s16)(actor->pCollisionTarget->angle.y - actor->angle.y)) > DEG2SHORT_ANGLE(90)) {
                add_calc2(&actor->moveSpeed1, actor->init_data.speed_range + actor->init_data.speed_base, 0.1f, 0.3f);
            } else {
                add_calc2(&actor->moveSpeed1, actor->init_data.speed_base, 0.05f, 0.3f);
            }
        } else if (actor->fishType == 6) {
            if (actor->speedF > 0.0f) {
                add_calc2(&actor->speedF, actor->init_data.speed_range + actor->init_data.speed_base, 0.25f, 0.1f);
            } else {
                actor->speedF *= 0.95f;
            }
        }

        if (v > 0) {
            v1 += DEG2SHORT_ANGLE(90);
        } else {
            v1 -= DEG2SHORT_ANGLE(90);
        }

        return v1;
    } else {
        return actor->escape_angle;
    }
}

void mfish_move_smooth(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* game) {
    s16 vv;
    s16 v = 0;
    s16* o;
    if (actor->distFrontWall < 20.0f || actor->distRightWall < 20.0f || actor->distBackWall < 20.0f || actor->distLeftWall < 20.0f) {
        if (actor->distRightWall < 20.0f) {
            v = DEG2SHORT_ANGLE(90);
        } else if (actor->distLeftWall < 20.0f) {
            v = DEG2SHORT_ANGLE(-90);
        }

        if (actor->distFrontWall < 20.0f) {
            if (v == 0) {
                v = 0;
            } else {
                v >>= 1;
            }
        } else if (actor->distBackWall < 20.0f) {
            if (v == 0) {
                v = DEG2SHORT_ANGLE(-180);
            } else {
                v = DEG2SHORT_ANGLE(180) - (v >> 1);
            }
        }

        if ((actor->speedF > 0.0f || actor->distFrontWall < 5.0f || actor->distBackWall < 5.0f || actor->distRightWall < 5.0f ||
             actor->distLeftWall < 5.0f) &&
            (actor->currentProcess != mfish_peck_process && actor->currentProcess != mfish_koi_peck_process)) {
            vv = actor->angle.y - (s16)v;
            if (ABS(vv) < DEG2SHORT_ANGLE(45)) {
                add_calc0(&actor->speedF, 0.1f * cos_s(vv << 1), 0.02f);
            }

            if ((actor->tank == mfish_TANK_0 || actor->fishType == 10 || actor->fishType == 11 ||
                 actor->fish_idx == aGYO_TYPE_AROWANA) &&
                ABS(vv) < DEG2SHORT_ANGLE(90) && ABS(actor->targetBodyAngle.z) < DEG2SHORT_ANGLE(10)) {
                if (actor->currentProcess == mfish_afish_dummy_process) {
                    o = &actor->hide_camera_angle;
                } else {
                    o = &actor->goalAngle.y;
                }

                if (vv > 0) {
                    add_calc_short_angle2(
                        o, (s16)v + DEG2SHORT_ANGLE(90), CALC_EASE(GETREG(TAKREG, 0x2d) * 0.01f + 0.25f),
                        DEG2SHORT_ANGLE(actor->speedF * ((GETREG(TAKREG, 0x2e) + 12.0f) * cos_s(vv)) + 1.5f) >> 1,
                        DEG2SHORT_ANGLE(0.5f));
                } else {
                    add_calc_short_angle2(
                        o, (s16)v - DEG2SHORT_ANGLE(90), CALC_EASE(GETREG(TAKREG, 0x2d) * 0.01f + 0.25f),
                        DEG2SHORT_ANGLE(actor->speedF * ((GETREG(TAKREG, 0x2e) + 5.0f) * cos_s(vv)) + 1.5f) >> 1,
                        DEG2SHORT_ANGLE(0.5f));
                }
            }
        }
    }
}

void mfish_hamon_make(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* game) {
    GAME_PLAY* play = (GAME_PLAY*)game;
    if ((play->game_frame & 7) == 0 &&
        ((actor->flags & 0x1e) == 0 || ABS((s16)(actor->avoid_angle - actor->angle.y)) < DEG2SHORT_ANGLE(80))) {
        xyz_t p = actor->position;
        p.y = 115.0f;
        Common_Get(clip.effect_clip)
            ->effect_make_proc(eEC_EFFECT_TURI_HAMON, p, 2, DEG2SHORT_ANGLE(180) + actor->angle.y, game, RSV_NO, 7, 0);
    }
}

static void mfish_pos_move_flow(MUSEUM_FISH_PRIVATE_DATA* actor) {
    actor->position.x += actor->flow_vec.x;
    actor->position.y += actor->flow_vec.y;
    actor->position.z += actor->flow_vec.z;
}

static void mfish_pos_moveF(MUSEUM_FISH_PRIVATE_DATA* actor) {
    mfish_calc_speed(actor);
    mfish_pos_move(actor);
}

static void mfish_pos_move(MUSEUM_FISH_PRIVATE_DATA* actor) {
    actor->position.x += actor->speed.x;
    actor->position.y += actor->speed.y;
    actor->position.z += actor->speed.z;
}

static void mfish_set_speed(MUSEUM_FISH_PRIVATE_DATA* actor, f32 x, f32 y, f32 z) {
    actor->speed.x = x;
    actor->speed.y = y;
    actor->speed.z = z;
}

static void mfish_calc_speed(MUSEUM_FISH_PRIVATE_DATA* actor) {
    float x = actor->speedF * sin_s(actor->angle.y);
    float y = actor->speed.y;
    float z = actor->speedF * cos_s(actor->angle.y);

    mfish_set_speed(actor, x, y, z);
}

static s16 mfish_calc_timer_s(s16* timer_s) {
    if (*timer_s != 0) {
        (*timer_s)--;
    }

    return *timer_s;
}

f32 Rnd_EX_f(f32 v) {
    f32 rand1 = RANDOM2_F(2);
    f32 rand2 = RANDOM_F(1);
    if (rand2 > (rand1 * rand1)) {
        if (rand1 > 0) {
            rand1 = sqrtf(rand2);
        } else {
            rand1 = -sqrtf(rand2);
        }
    }
    rand1 = (1.0f + rand1) * 0.5f;
    return v * rand1;
}

f32 Rnd_EX_fx(f32 v) {
    f32 rand1 = RANDOM2_F(2);
    f32 rand2 = RANDOM_F(1);
    if (rand2 > (rand1 * rand1)) {
        if (rand1 > 0) {
            rand1 = sqrtf(rand2);
        } else {
            rand1 = -sqrtf(rand2);
        }
    }
    rand1 = rand1 / 2;
    return v * rand1;
}
