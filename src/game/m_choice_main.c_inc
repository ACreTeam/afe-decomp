        NULL,
        NULL,
        NULL,
        NULL,
        &mChoice_Put_String_AMPM,
        NULL,
        NULL,
        NULL,
        NULL,
    };

    int type = data[idx + 1];

    if (type >= 0 && type < mFont_CONT_CODE_NUM && proc[type] != NULL) {
        return (*proc[type])(data, idx, max_size, actor);
    }

    return max_size;
}

