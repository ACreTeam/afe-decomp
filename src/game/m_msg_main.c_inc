static int mMsg_Set_SizeCode(mMsg_Window_c* msg_p, int idx) {
    return mFont_CodeSize_idx_get(msg_p->msg_data->text_buf.data, idx);
}

static int mMsg_Count_SameCode(u8* data, int start, int length) {
    int res = 0;
    int i = start;
    u8* now_p;
    u8 now_code;
    u8 last_code = CHAR_MESSAGE_TAG;

    while (i < length) {
        now_p = &data[i];
        now_code = *now_p;

        if (mFont_Check_Cont(now_code) || mFont_Check_Tag(now_code)) {
            i += mFont_CodeSize_get(now_p);
            continue;
            // ー/っ (chouonpu and sokuon)
        } else if ((now_code == CHAR_PP_144 || now_code == CHAR_PP_204) != FALSE) {
            res++;
            i++;
        } else {
            if (res > 0) {
                // treat tte/ppe as normal grammar instead of a drawn-out consonant (sokuon)
                // って/っぺ
                if (last_code != CHAR_PP_204 || (now_code != CHAR_PP_018 && now_code != CHAR_PP_254)) {
                    break;
                }

                res--;
            }
            break;
        }

        last_code = now_code;
    }

    return res;
}

static int mMsg_Check_LastCode_forData(const u8* data, int idx) {
    int ret = FALSE;

    data += idx;
    if (mFont_Check_ContId(data, mFont_CONT_CODE_LAST) ||
        mFont_Check_TagId(data, 0, mFont_TAG_GROUP_BASE, mFont_TAG_BASE_MSG_LAST)) {
        ret = TRUE;
    }

    return ret;
}

static int mMsg_Check_LastCode(mMsg_Window_c* msg_p, int idx) {
    return mMsg_Check_LastCode_forData(msg_p->msg_data->text_buf.data, idx);
}

static int mMsg_Check_ContinueCode_forData(const u8* data, int idx) {
    int ret = FALSE;

    data += idx;
    if (mFont_Check_ContId(data, mFont_CONT_CODE_CONTINUE) ||
        mFont_Check_TagId(data, 0, mFont_TAG_GROUP_BASE, mFont_TAG_BASE_MSG_CONTINUE)) {
        ret = TRUE;
    }

    return ret;
}

static int mMsg_Check_ContinueCode(mMsg_Window_c* msg_p, int idx) {
    return mMsg_Check_ContinueCode_forData(msg_p->msg_data->text_buf.data, idx);
}

static int mMsg_Check_NextIndex_ContinueCode(mMsg_Window_c* msg_p) {
    if (mMsg_Check_ContinueCode(msg_p, msg_p->end_text_cursor_idx)) {
        return TRUE;
    }

    return FALSE;
}

static int mMsg_Check_NextIndex_LastCode(mMsg_Window_c* msg_p) {
    if (mMsg_Check_LastCode(msg_p, msg_p->end_text_cursor_idx)) {
        return TRUE;
    }

    return FALSE;
}

static int mMsg_Check_NextIndex_SetSelectWindowCode(mMsg_Window_c* msg_p) {
    int ret = FALSE;
    u8* data = msg_p->msg_data->text_buf.data;
    int idx = msg_p->end_text_cursor_idx;
    u8* code_p = &data[idx];

    if (mFont_Check_ContId(code_p, mFont_CONT_CODE_SET_SELECT_WINDOW) ||
        mFont_Check_TagId(code_p, 0, mFont_TAG_GROUP_COM, mFont_TAG_COM_OPEN_CHOICE)) {
        ret = TRUE;
    }

    return ret;
}

static f32 mMsg_Get_CursolSetTimeCode_forData(const u8* data, int idx) {
    const u8* code_p = &data[idx];
    float ret = -1.0f;

    if (mFont_Check_Cont(*code_p)) {
        if (code_p[1] == mFont_CONT_CODE_CURSOR_SET_TIME) {
            ret = (f32)(int)mFont_Get_ContPrmU8(code_p);
        }
    } else if (mFont_Check_Tag(*code_p)) {
        if (mFont_Check_TagId(code_p, sizeof(u16), mFont_TAG_GROUP_BASE, mFont_TAG_BASE_TIME_INTERVAL)) {
            ret = (f32)mFont_Get_TagPrmU16(code_p);
        }
    }

    return ret >= 0.0f ? ret * 2.0f : 0.0f;
}

static f32 mMsg_Get_CursolSetTimeCode(mMsg_Window_c* msg_p, int idx) {
    return mMsg_Get_CursolSetTimeCode_forData(msg_p->msg_data->text_buf.data, idx);
}

static int mMsg_Get_ColorCode_forData(u8* data, int idx, u8* r, u8* g, u8* b) {
    if (mFont_Check_Cont(data[idx]) && data[idx + 1] == mFont_CONT_CODE_COLOR) {
        *r = data[idx + 2];
        *g = data[idx + 3];
        *b = data[idx + 4];
        return TRUE;
    }

    return FALSE;
}

static int mMsg_Get_ColorCode(mMsg_Window_c* msg_p, int idx, u8* r, u8* g, u8* b) {
    return mMsg_Get_ColorCode_forData(msg_p->msg_data->text_buf.data, idx, r, g, b);
}

static int mMsg_Get_OrderCode_forData(const u8* data, int idx, int* order_idx, u16* order_val) {
    const u8* code_p = &data[idx];
    int ret = FALSE;

    if (mFont_Check_Cont(*code_p)) {
        if (code_p[1] == mFont_CONT_CODE_SET_DEMO_ORDER_PLAYER || code_p[1] == mFont_CONT_CODE_SET_DEMO_ORDER_NPC0 ||
            code_p[1] == mFont_CONT_CODE_SET_DEMO_ORDER_NPC1 || code_p[1] == mFont_CONT_CODE_SET_DEMO_ORDER_NPC2 ||
            code_p[1] == mFont_CONT_CODE_SET_DEMO_ORDER_QUEST) {
            u16 val;

            *order_idx = code_p[2];
            val = (u16)(code_p[3]) << 8;
            *order_val = val | ((code_p[4]) & 0xFF);
            ret = TRUE;
        }
    }

    return ret;
}

static int mMsg_Get_OrderCode(mMsg_Window_c* msg_p, int idx, int* order_idx, u16* order_val) {
    return mMsg_Get_OrderCode_forData(msg_p->msg_data->text_buf.data, idx, order_idx, order_val);
}

static int mMsg_Get_SoundCutCode_forData(const u8* data, int idx) {
    const u8* code_p = &data[idx];
    int ret = -1;

    if (mFont_Check_ContId(code_p, mFont_CONT_CODE_SOUND_CUT)) {
        ret = mFont_Get_ContPrmU8(code_p);
    } else if (mFont_Check_TagId(code_p, 0, mFont_TAG_GROUP_SOUND, mFont_TAG_SOUND_MINDON)) {
        ret = 0;
    } else if (mFont_Check_TagId(code_p, 0, mFont_TAG_GROUP_SOUND, mFont_TAG_SOUND_MINDOFF)) {
        ret = 1;
    }

    return ret;
}

static int mMsg_Get_SoundCutCode(mMsg_Window_c* msg_p, int idx) {
    return mMsg_Get_SoundCutCode_forData(msg_p->msg_data->text_buf.data, idx);
}

static void mMsg_Get_bgm_make_forData(const u8* data, int idx, int* bgm_type, int* stop_type) {
    const u8* code_p = &data[idx];

    if (mFont_Check_ContId(code_p, mFont_CONT_CODE_BGM_MAKE)) {
        *bgm_type = code_p[2];
        *stop_type = code_p[3];
    } else if (mFont_Check_TagId(code_p, 2 * sizeof(u8), mFont_TAG_GROUP_SOUND, mFont_TAG_SOUND_BGMMAKE)) {
        *bgm_type = code_p[5];
        *stop_type = code_p[6];
    } else {
        *bgm_type = mFont_BGM_NUM;
        *stop_type = mFont_BGM_STOP_TYPE_NUM;
    }
}

static void mMsg_Get_bgm_make(mMsg_Window_c* msg_p, int idx, int* bgm_type, int* stop_type) {
    mMsg_Get_bgm_make_forData(msg_p->msg_data->text_buf.data, idx, bgm_type, stop_type);
}

static void mMsg_Get_bgm_delete_forData(const u8* data, int idx, int* bgm_type, int* stop_type) {
    const u8* code_p = &data[idx];

    if (mFont_Check_ContId(code_p, mFont_CONT_CODE_BGM_DELETE)) {
        *bgm_type = code_p[2];
        *stop_type = code_p[3];
    } else if (mFont_Check_TagId(code_p, 2 * sizeof(u8), mFont_TAG_GROUP_SOUND, mFont_TAG_SOUND_BGMDELETE)) {
        *bgm_type = code_p[5];
        *stop_type = code_p[6];
    } else {
        *bgm_type = mFont_BGM_NUM;
        *stop_type = mFont_BGM_STOP_TYPE_NUM;
    }
}

static void mMsg_Get_bgm_delete(mMsg_Window_c* msg_p, int idx, int* bgm_type, int* stop_type) {
    mMsg_Get_bgm_delete_forData(msg_p->msg_data->text_buf.data, idx, bgm_type, stop_type);
}

static int mMsg_Get_MsgTimeEnd_time_forData(const u8* data, int idx) {
    const u8* code_p = &data[idx];
    int ret = -1;

    if (mFont_Check_ContId(code_p, mFont_CONT_CODE_MSG_TIME_END)) {
        ret = mFont_Get_ContPrmU8(code_p);
    } else if (mFont_Check_TagId(code_p, sizeof(u16), mFont_TAG_GROUP_BASE, mFont_TAG_BASE_MSG_WAIT_LAST)) {
        ret = mFont_Get_TagPrmU16(code_p);
    }

    return ret >= 0 ? ret : 0;
}

