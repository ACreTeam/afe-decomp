    drive = mCsd_nowdrive_get();
    if (drive == mCD_SLOT_A) {
        aNPS2_set_slot_name(mCD_SLOT_A, mMsg_FREE_STR3);
        aNPS2_set_slot_name(mCD_SLOT_B, mMsg_FREE_STR4);
    } else {
        aNPS2_set_slot_name(mCD_SLOT_B, mMsg_FREE_STR3);
        aNPS2_set_slot_name(mCD_SLOT_A, mMsg_FREE_STR4);
    }

    p_sel2->sd_action_timer = 0x70;
    p_sel2->sd_result = 0xFF;
}

