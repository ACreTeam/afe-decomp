        &aNPS2_chk_option, // aNPS2_TALK_CHK_OPTION
        &aNPS2_chk_option2, // aNPS2_TALK_CHK_OPTION2
        &aNPS2_chk_clr_village_data_cartridge, // aNPS2_TALK_CHK_CLR_VILLAGE_DATA_CARTRIDGE
        &aNPS2_clr_village_data_cartridge, // aNPS2_TALK_CLR_VILLAGE_DATA_CARTRIDGE
        &aNPS2_chk_clr_pl_data, // aNPS2_TALK_CHK_CLR_PL_DATA
        &aNPS2_chk_clr_pl_data2, // aNPS2_TALK_CHK_CLR_PL_DATA2
        &aNPS2_chk_clr_pl_data3, // aNPS2_TALK_CHK_CLR_PL_DATA3
        &aNPS2_chk_clr_pl_data3, // aNPS2_TALK_CHK_CLR_PL_DATA4
        &aNPS2_chk_clr_passport_file, // aNPS2_TALK_CHK_CLR_PASSPORT_FILE
        &aNPS2_clr_passport_file, // aNPS2_TALK_CLR_PASSPORT_FILE
        &aNPS2_clr_pl_data, // aNPS2_TALK_CLR_PL_DATA
        &aNPS2_ti_menu_open_msg_wait, // aNPS2_TALK_TI_MENU_OPEN_MSG_WAIT
        &aNPS2_ti_menu_open_wait, // aNPS2_TALK_TI_MENU_OPEN_WAIT
        &aNPS2_ti_menu_close_wait, // aNPS2_TALK_TI_MENU_CLOSE_WAIT
        &aNPS2_select_player, // aNPS2_TALK_SELECT_PLAYER
        &aNPS2_select_card_player, // aNPS2_TALK_SELECT_CARD_PLAYER
        &aNPS2_chk_fuzai_player, // aNPS2_TALK_CHK_FUZAI_PLAYER
