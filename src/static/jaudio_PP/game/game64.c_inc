        sou_ongen_entry[i]._09 = 0;
        sou_ongen_entry[i]._0A = 0;
        sou_ongen_entry[i].distance = 9999.0f;
    }
}

void Sou_BgmFadeoutEndCheck() {
    if (sou_now_bgm_fadeout && !AG.groups[BGM0_GROUP].flags.enabled && !AG.groups[BGM1_GROUP].flags.enabled) {
        sou_now_bgm_num = 0;
        sou_now_bgm_fadeout = FALSE;
    }
}

static u16 Sou_BgmTrackMute(u16 id) {
    Na_BgmMuteClear();
    if (id == BGM_SIMPLE_ISLAND_LIFE && sou_PrivateIslandStatus == 0) {
        NA_COMMAND_AUDIO_GROUP_SET_APPLY_SUBTRACK_MASK(sou_now_bgm_handle, BGM_MUTE_PRIVATE_ISLAND);
        NA_COMMAND_AUDIO_SUBTRACK_SET_MUTE(sou_now_bgm_handle, AUDIOCMD_ALL_SUBTRACKS, TRUE);
    }

    if (id >= BGM_FIELD_00 && id <= BGM_FIELD_23) {
        switch (sou_tenki) {
            case mEnv_WEATHER_CLEAR:
                NA_COMMAND_AUDIO_GROUP_SET_APPLY_SUBTRACK_MASK(sou_now_bgm_handle, BGM_MUTE_TABLE_FINE[id - 1]);
                NA_COMMAND_AUDIO_SUBTRACK_SET_MUTE(sou_now_bgm_handle, AUDIOCMD_ALL_SUBTRACKS, TRUE);
                break;
            case mEnv_WEATHER_RAIN:
                id = BGM_RAIN;
                break;
            case mEnv_WEATHER_SNOW:
                NA_COMMAND_AUDIO_GROUP_SET_APPLY_SUBTRACK_MASK(sou_now_bgm_handle, BGM_MUTE_TABLE_SNOW[id - 1]);
                NA_COMMAND_AUDIO_SUBTRACK_SET_MUTE(sou_now_bgm_handle, AUDIOCMD_ALL_SUBTRACKS, TRUE);
                break;
            case mEnv_WEATHER_SAKURA:
                NA_COMMAND_AUDIO_GROUP_SET_APPLY_SUBTRACK_MASK(sou_now_bgm_handle, BGM_MUTE_TABLE_SAKURA[id - 1]);
                NA_COMMAND_AUDIO_SUBTRACK_SET_MUTE(sou_now_bgm_handle, AUDIOCMD_ALL_SUBTRACKS, TRUE);
                break;
            case mEnv_WEATHER_LEAVES:
            default:
                break;
        }
    }

    return id;
}

void Sou_GroupControl(u8 a, u8 pan, f32 volume) {
    u8 i = 0;
    if (volume > 1.f) {
        volume = 1.f;
    }
    NA_COMMAND_AUDIO_GRP_FADE_VOLUME_SCALE(a, volume);
    if (a == 1) {
        sou_bgm1_vol_now = volume;
    }
    if (a == 3) {
        sou_bgm2_vol_now = volume;
    }
    for (i = 0; i < AUDIO_SUBTRACK_NUM; i++) {
        NA_COMMAND_AUDIO_SUBTRACK_SET_PAN(a, i, pan);
    }
}

void Sou_GroupControl_MD(u8 group, u8 pan, f32 volume) {
    u8 i = 0;
    if (volume > 2.25f) {
        volume = 2.25f;
    }
    NA_COMMAND_AUDIO_GRP_FADE_VOLUME_SCALE(group, volume);
    if (group == BGM0_GROUP) {
        sou_bgm1_vol_now = volume;
    }
    if (group == BGM1_GROUP) {
        sou_bgm2_vol_now = volume;
    }
    for (i = 0; i < AUDIO_SUBTRACK_NUM; i++) {
        NA_COMMAND_AUDIO_SUBTRACK_SET_PAN(group, i, pan);
    }
}

u8 pan_kochou(u8 a, f32 b) {
    s16 v = 0;
    switch (sou_out_mode) {
        case 0: {
            b = b * 1.6f;
        } break;
        case 2: {
            b = b * 0.75f;
        }; break;
        case 1: {
            return a;
        };
    }
    v = (s16)((a - 0x40) * b);
    if (v > 0x3f) {
        v = 0x3f;
    }
    if (v < -0x40) {
        v = -0x40;
    }
    return 0x40 + v;
}

u8 angle2pan(u16 angle, f32 dist) {
    u8 a = 0;
    f32 v = 1.f;
    angle >>= 8;
    if (angle >= 0x40 && angle <= 0xc0) {
        a = 0x80 - (angle - 0x40);
        if (a == 0x80) {
            a = 0x7f;
        }
    } else if (angle >= 0xc1) {
        a = angle - 0xc0;
    } else {
        a = angle + 0x40;
    }
    a = pan_kochou(a, v);
    return a;
}

f32 distance2vol(f32 distance) {
    f32 ret = 0.f;
    if (distance > SOU_ONGEN_AREA1) {
        return 0.f;
    }

    ret = 1.15f - (1.15f / SQ(SOU_ONGEN_AREA1)) * SQ(distance);
    if (ret > 1.5f) {
        if (ret > 1.5f) {
            ret = 1.5f;
        }
        ret = 1.5f;
    }
    return ret;
}

f32 distance2vol4KITEKI(f32 distance) {
    f32 vol = 0.0f;

    // @BUG - this should come after the volume calculation or it should return immediately.
    // Also I think this check is entirely wrong. It should be 'if (distance < KITEKI_MIN_DISTANCE)'.
    if (distance > KITEKI_MIN_DISTANCE) {
        vol = KITEKI_BASE_VOLUME;
    }

    // @BUG - this should come after the volume calculation or it should return immediately.
    if (distance < 0.0f) {
        vol = 0.0f;
    }

    // linear falloff
    // @BUG - this can result in negative volume if the distance is more than 6400.
    vol = KITEKI_BASE_VOLUME - KITEKI_VOLUME_SCALE * (distance - KITEKI_MIN_DISTANCE);
    return vol;
}

f32 distance2vol4MD(f32 distance) {
    f32 vol = 0.0f;

    if (distance > MD_MAX_DISTANCE) {
        vol = 0.0f;
    } else {
        // quadratic falloff
        vol = MD_BASE_VOLUME - MD_VOLUME_SCALE * SQ(distance - MD_MIN_DISTANCE);
    }

    if (vol > MD_MAX_VOLUME) {
        vol = MD_MAX_VOLUME;
    }

    if (vol < MD_MIN_VOLUME) {
        vol = MD_MIN_VOLUME;
    }
    
    return vol;
}

void Sou_VoiceStart(u8 subtrack, u8 b) {
    NA_COMMAND_AUDIO_SUBTRACK_SET_PORT(VOICE_GROUP, subtrack, 0, b);
}

void Sou_TrgStart(u16 id, f32 volume, f32 optVolume, f32 freqScale, u8 pan, u8 reverb, f32 distance) {
    u8 subtrack = 0;
    u8 found_free = FALSE;
    u8 i = 0;
    u32 rand = 0;
    u8 se_idx_lo = 0;
    u8 se_idx_hi = 0;
    u8 flags = 0;
    u16 mask = 0;
    u8 mono = FALSE;
    u8 singleton = FALSE;
    u8 do_reverb = FALSE;
    u8 do_echo = FALSE;

    switch (id) {
        case NA_SE_63:
        case NA_SE_65:
        case NA_SE_67:
        case NA_SE_SCOOP1:
        case NA_SE_KIRIBASU_SCOOP:
        case 0x475:
        case NA_SE_4028: {
            rand = Nap_GetRandom();
            id = id + (rand & 1);
        } break;
        case NA_SE_3B:
        case NA_SE_DOYON:
        case NA_SE_43F:
        case NA_SE_501:
        case NA_SE_505:
        case NA_SE_509:
        case NA_SE_50D:
        case NA_SE_511:
        case NA_SE_515:
        case NA_SE_519:
        case NA_SE_51D:
        case NA_SE_521:
        case NA_SE_525:
        case NA_SE_529:
        case NA_SE_531:
        case NA_SE_539:
        case NA_SE_53D: {
            rand = Nap_GetRandom();
            id = id + (rand & 3);
        } break;
    }

    se_idx_lo = id;
    mask = id & 0xF000;
    flags = mask >> 12; // get the flags attached to sound effect

    mask = id & 0x0F00;
    se_idx_hi = mask >> 8; // 

    // pull out flags
    mono = flags & (1 << 0);
    do_reverb = flags & (1 << 1);
    do_echo = flags & (1 << 2);
    singleton = flags & (1 << 3);

    // Check if only one of these can play at a time
    if (singleton) {
        for (i = 0; i < ARRAY_COUNT(sou_trg_se); i++) {
            if (id == sou_trg_se[i].id) {
                return;
            }
        }
    }
    
    if (mono) {
        NA_COMMAND_AUDIO_SUBTRACK_SET_FREQ_SCALE(SE_GROUP, NA_SUBTRACK14, freqScale);
        NA_COMMAND_AUDIO_SUBTRACK_SET_PAN(SE_GROUP, NA_SUBTRACK14, pan);
        NA_COMMAND_AUDIO_SUBTRACK_REVERB_VOLUME(SE_GROUP, NA_SUBTRACK14, reverb);
        NA_COMMAND_AUDIO_SUBTRACK_SET_PORT(SE_GROUP, NA_SUBTRACK14, 0, se_idx_lo);
        NA_COMMAND_AUDIO_SUBTRACK_SET_PORT(SE_GROUP, NA_SUBTRACK14, 1, se_idx_hi);
        return;
    }

    for (i = 0; i < ARRAY_COUNT(sou_trg_se); i++) {
        if (sou_trg_se[i].id == 0) {
            subtrack = i;
            i = ARRAY_COUNT(sou_trg_se);
            found_free = TRUE;
        }
    }

    if (found_free == TRUE) {
        sou_trg_se[subtrack].id = id;
        sou_trg_se[subtrack].priority = TRGPRIO[se_idx_lo];
        sou_trg_se[subtrack].frames = 1;
        sou_trg_se[subtrack].volume = volume;
        sou_trg_se[subtrack].optVolume = optVolume;
        sou_trg_se[subtrack].freqScale = freqScale;
        sou_trg_se[subtrack].pan = pan;
        if (reverb) {
            sou_trg_se[subtrack].reverbVolume = reverb;
        } else {
            // @BUG - if 'do_reverb' is TRUE, the reverb strength is calculated
            // based on the distance from the mic position to the sound source.
            // If 'do_echo' is also TRUE and echo is enabled on the sound effect,
            // the reverb amount is overwritten.
            // HOWEVER, if echo isn't enabled, then the reverb volume is STILL
            // overwritten, being set back to 0. So reverb volume can never be
            // applied properly.

            if (do_reverb) {
                mask = (u16)(distance);
                reverb = mask >> 3;
                if (reverb > 50) {
                    reverb = 50;
                }
            }

            if (do_echo && sou_trg_se[subtrack].echo) {
                reverb = 40;
            } else {
                reverb = 0;
            }
            
            sou_trg_se[subtrack].reverbVolume = reverb;
        }
        NA_COMMAND_AUDIO_SUBTRACK_SET_PORT(SE_GROUP, subtrack, 0, se_idx_lo);
        NA_COMMAND_AUDIO_SUBTRACK_SET_PORT(SE_GROUP, subtrack, 1, se_idx_hi);
        return;
    }

    // find sfx that has existed for longest time and use that since none are free
    rand = 0;
    for (i = 0; i < ARRAY_COUNT(sou_trg_se); i++) {
        if (sou_trg_se[i].frames > rand) {
            rand = sou_trg_se[i].frames;
            subtrack = i;
        }
    }

    // @BUG - 'se_idx_lo' is the lower 8 bits of the sound effect ID.
    // That means that sound effects which share the same index into
    // differing banks (se_idx_hi) will have the same priority.
    // ALSO: there are no bounds check, so even though only indexes of
    // 0x00-0x7F are valid, 0x80+ can be read from unrelated memory.
    if (TRGPRIO[se_idx_lo] >= sou_trg_se[subtrack].priority) {
        sou_trg_se[subtrack].id = id;
        sou_trg_se[subtrack].priority = TRGPRIO[se_idx_lo];
        sou_trg_se[subtrack].frames = 1;
        sou_trg_se[subtrack].volume = volume;
        sou_trg_se[subtrack].optVolume = optVolume;
        sou_trg_se[subtrack].freqScale = freqScale;
        sou_trg_se[subtrack].pan = pan;
        NA_COMMAND_AUDIO_SUBTRACK_SET_PORT(SE_GROUP, subtrack, 0, se_idx_lo);
        NA_COMMAND_AUDIO_SUBTRACK_SET_PORT(SE_GROUP, subtrack, 1, se_idx_hi);
    }
}

void Sou_SpecialRoutine00() {
    u16 r = 0;
    if (sou_kiteki_counter) {
        if (sou_kiteki_counter == 1) {
            r = Nap_GetRandom();
            r >>= 8;
            sou_kiteki_random = r + 0x40;
        }
        if (sou_kiteki_counter == sou_kiteki_random) {
            Na_SysTrgStart(NA_SE_4028);
            r = Nap_GetRandom();
            r >>= 7;
            sou_kiteki_random = r + 0x80;
            sou_kiteki_counter = 2;
        }
        sou_kiteki_counter++;
    }
}

void Sou_SpecialRoutine02() {
    if (sou_SE_SENTAKU_KETTEI_timer) {
        sou_SE_SENTAKU_KETTEI_timer++;
    }
    if (sou_SE_SENTAKU_KETTEI_timer == 30) {
        sou_SE_SENTAKU_KETTEI_timer = 0;
    }
}

void Sou_SpecialRoutine03() {
    if (sou_SE_ami_hit_water_timer) {
        sou_SE_ami_hit_water_timer++;
    }
    if (sou_SE_ami_hit_water_timer == 10) {
        sou_SE_ami_hit_water_timer = 0;
    }
}

void Sou_TrgEndCheck() {
    u8 i = 0;
    u8 unused = 0;
    for (i = 0; i < 6; i++) {
        if (sou_trg_se[i].id != 0) {
            sou_trg_se[i].frames++;
            if (!Nap_ReadSubPort(SE_GROUP, i, 5) && sou_trg_se[i]._1D) {
                sou_trg_se[i].id = 0;
                sou_trg_se[i].frames = 0;
            }
        }
        sou_trg_se[i]._1D = Nap_ReadSubPort(SE_GROUP, i, 5);
    }
}

void Sou_LevStart(u8 index, u8 b) {
    if (b == sou_lev_se[index].queue0 || b == sou_lev_se[index].queue1 || b == sou_lev_se[index].queue2 ||
        b == sou_lev_se[index].queue3 || b == sou_lev_se[index].queue4 || b == sou_lev_se[index].queue5 ||
        b == sou_lev_se[index].queue6 || b == sou_lev_se[index].queue7) {
        return;
    }

    if (sou_ls_stack[index]._0) {
        if (sou_ls_stack[index]._1) {
            if (sou_ls_stack[index]._2) {
                if (sou_ls_stack[index]._3) {
                } else {
                    sou_ls_stack[index]._3 = b;
                }
            } else {
                sou_ls_stack[index]._2 = b;
            }
        } else {
            sou_ls_stack[index]._1 = b;
        }
    } else {
        sou_ls_stack[index]._0 = b;
    }
}

void Sou_LevStop(u8 index, u8 b) {
    u8 v = 0;
    if (b == sou_ls_stack[index]._0) {
        sou_ls_stack[index]._0 = 0;
        if (sou_ls_stack[index]._1) {
            sou_ls_stack[index]._0 = sou_ls_stack[index]._1;
            sou_ls_stack[index]._1 = sou_ls_stack[index]._2;
            sou_ls_stack[index]._2 = sou_ls_stack[index]._3;
            sou_ls_stack[index]._3 = 0;
        }
    }

    if (b == sou_ls_stack[index]._1) {
        sou_ls_stack[index]._1 = 0;
        if (sou_ls_stack[index]._2) {
            sou_ls_stack[index]._1 = sou_ls_stack[index]._2;
            sou_ls_stack[index]._2 = sou_ls_stack[index]._3;
            sou_ls_stack[index]._3 = 0;
        }
    }

    if (b == sou_ls_stack[index]._2) {
        sou_ls_stack[index]._2 = 0;
        if (sou_ls_stack[index]._3) {
            sou_ls_stack[index]._2 = sou_ls_stack[index]._3;
            sou_ls_stack[index]._3 = 0;
        }
    }

    if (b == sou_ls_stack[index]._3) {
        sou_ls_stack[index]._3 = 0;
    }

    if (b == sou_lev_se[index].queue0) {
        sou_lev_se[index].queue0 = sou_lev_se[index].queue1;
        sou_lev_se[index].queue1 = sou_lev_se[index].queue2;
        sou_lev_se[index].queue2 = sou_lev_se[index].queue3;
        sou_lev_se[index].queue3 = sou_lev_se[index].queue4;
        sou_lev_se[index].queue4 = sou_lev_se[index].queue5;
        sou_lev_se[index].queue5 = sou_lev_se[index].queue6;
        sou_lev_se[index].queue6 = sou_lev_se[index].queue7;
        sou_lev_se[index].queue7 = 0;
        NA_COMMAND_AUDIO_SUBTRACK_SET_PORT(SE_GROUP, index + NA_SUBTRACK8, 5, -1);
        if (sou_lev_se[index].queue0) {
            v = sou_lev_se[index].queue0;
            sou_lev_se[index].queue0 = 0;
            Sou_LevStart(index, v);
        }
        return;
    }

    if (b == sou_lev_se[index].queue1) {
        sou_lev_se[index].queue1 = sou_lev_se[index].queue2;
        sou_lev_se[index].queue2 = sou_lev_se[index].queue3;
        sou_lev_se[index].queue3 = sou_lev_se[index].queue4;
        sou_lev_se[index].queue4 = sou_lev_se[index].queue5;
        sou_lev_se[index].queue5 = sou_lev_se[index].queue6;
        sou_lev_se[index].queue6 = sou_lev_se[index].queue7;
        sou_lev_se[index].queue7 = 0;
        return;
    }

    if (b == sou_lev_se[index].queue2) {
        sou_lev_se[index].queue2 = sou_lev_se[index].queue3;
        sou_lev_se[index].queue3 = sou_lev_se[index].queue4;
        sou_lev_se[index].queue4 = sou_lev_se[index].queue5;
        sou_lev_se[index].queue5 = sou_lev_se[index].queue6;
        sou_lev_se[index].queue6 = sou_lev_se[index].queue7;
        sou_lev_se[index].queue7 = 0;
        return;
    }

    if (b == sou_lev_se[index].queue3) {
        sou_lev_se[index].queue3 = sou_lev_se[index].queue4;
        sou_lev_se[index].queue4 = sou_lev_se[index].queue5;
        sou_lev_se[index].queue5 = sou_lev_se[index].queue6;
        sou_lev_se[index].queue6 = sou_lev_se[index].queue7;
        sou_lev_se[index].queue7 = 0;
        return;
    }

    if (b == sou_lev_se[index].queue4) {
        sou_lev_se[index].queue4 = sou_lev_se[index].queue5;
        sou_lev_se[index].queue5 = sou_lev_se[index].queue6;
        sou_lev_se[index].queue6 = sou_lev_se[index].queue7;
        sou_lev_se[index].queue7 = 0;
        return;
    }

    if (b == sou_lev_se[index].queue5) {
        sou_lev_se[index].queue5 = sou_lev_se[index].queue6;
        sou_lev_se[index].queue6 = sou_lev_se[index].queue7;
        sou_lev_se[index].queue7 = 0;
        return;
    }

    if (b == sou_lev_se[index].queue6) {
        sou_lev_se[index].queue6 = sou_lev_se[index].queue7;
        sou_lev_se[index].queue7 = 0;
        return;
    }

    if (b == sou_lev_se[index].queue7) {
        sou_lev_se[index].queue7 = 0;
        return;
    }
}

void Sou_TrgMake(u8 index) {
    f32 volume = 0.f;
    sou_trg_se[index].calcedVolume = sou_trg_se[index].volume * sou_trg_se[index].optVolume;
    volume = sou_trg_se[index].calcedVolume;
    if (sou_se_fadeout_flag) {
        volume *= sou_se_fade[index].volumeScale;
    }
    NA_COMMAND_AUDIO_SUBTRACK_SET_VOL_SCALE(SE_GROUP, index, volume);
    NA_COMMAND_AUDIO_SUBTRACK_SET_FREQ_SCALE(SE_GROUP, index, sou_trg_se[index].freqScale);
    NA_COMMAND_AUDIO_SUBTRACK_SET_PAN(SE_GROUP, index, sou_trg_se[index].pan);
    NA_COMMAND_AUDIO_SUBTRACK_REVERB_VOLUME(SE_GROUP, index, sou_trg_se[index].reverbVolume);
}

void Sou_VoiceMake(u8 index) {
    sou_voice_se[index].volumeScale = sou_voice_se[index]._08 * sou_voice_se[index]._0C;
    sou_voice_se[index].frequencyScale = sou_voice_se[index]._14 * sou_voice_se[index]._18;
    NA_COMMAND_AUDIO_SUBTRACK_SET_VOL_SCALE(VOICE_GROUP, index, sou_voice_se[index].volumeScale);
    NA_COMMAND_AUDIO_SUBTRACK_SET_FREQ_SCALE(VOICE_GROUP, index, sou_voice_se[index].frequencyScale);
    NA_COMMAND_AUDIO_SUBTRACK_SET_PAN(VOICE_GROUP, index, sou_voice_se[index].pan);
    NA_COMMAND_AUDIO_SUBTRACK_REVERB_VOLUME(VOICE_GROUP, index, sou_voice_se[index].reverbVolume);
}

void Sou_LevMake(u8 index) {
    u8 unused = 0;
    f32 volume = 0.f;
    if (sou_pause_flag == 1 && sou_lev_se[index].queue0 == NA_ONGEN_POS_SE_47) {
        NA_COMMAND_AUDIO_SUBTRACK_SET_VOL_SCALE(SE_GROUP, index + NA_SUBTRACK8, 0.85f * sou_lev_se[index].volumeScale);
        return;
    } else if (sou_pause_flag == 1) {
        NA_COMMAND_AUDIO_SUBTRACK_SET_VOL_SCALE(SE_GROUP, index + NA_SUBTRACK8, 0.5f * sou_lev_se[index].volumeScale);
        return;
    }
    volume = sou_lev_se[index].volumeScale;
    if (sou_se_fadeout_flag) {
        volume *= sou_se_fade[index + 8].volumeScale;
    }
    if (sou_lev_se[index].queue0 == NA_ONGEN_POS_SE_KAZAGURUMA) {
        volume *= sou_kazaguruma_speed;
    }
    if (sou_lev_se[index].queue0 == NA_ONGEN_POS_SE_FUUSHA) {
        volume *= sou_fuusha_speed;
    }
    NA_COMMAND_AUDIO_SUBTRACK_SET_VOL_SCALE(SE_GROUP, index + NA_SUBTRACK8, volume);
    NA_COMMAND_AUDIO_SUBTRACK_SET_PAN(SE_GROUP, index + NA_SUBTRACK8, sou_lev_se[index].pan);
    if (sou_lev_se[index].echo && sou_lev_se[index].echoEnableFlag) {
        if (sou_scene_mode == 0xf) {
            sou_lev_se[index].reverbVolume = 0;
        } else {
            sou_lev_se[index].reverbVolume = 0x28;
        }
    } else {
        sou_lev_se[index].reverbVolume = 0;
    }
    NA_COMMAND_AUDIO_SUBTRACK_REVERB_VOLUME(SE_GROUP, index + NA_SUBTRACK8, sou_lev_se[index].reverbVolume);
}

void Sou_ChimeMake() {
    if (sou_se_fade[7]._0 || sou_se_fade[7]._4) {
        sou_chime_volume *= sou_se_fade[7].volumeScale;
    }
    NA_COMMAND_AUDIO_SUBTRACK_SET_VOL_SCALE(SE_GROUP, NA_SUBTRACK7, sou_chime_volume);
}

void Sou_LevSet(u8 index) {
    u8 v1 = 0, v2 = 0;
    if (!sou_ls_stack[index]._0) {
        return;
    }
    v1 = sou_ls_stack[index]._0;
    if (!sou_lev_se[index].queue0) {
        sou_lev_se[index].queue0 = v1;
    } else if (!sou_lev_se[index].queue1) {
        sou_lev_se[index].queue1 = sou_lev_se[index].queue0;
        sou_lev_se[index].queue0 = v1;
    } else if (!sou_lev_se[index].queue2) {
        sou_lev_se[index].queue2 = sou_lev_se[index].queue1;
        sou_lev_se[index].queue1 = sou_lev_se[index].queue0;
        sou_lev_se[index].queue0 = v1;
    } else if (!sou_lev_se[index].queue3) {
        sou_lev_se[index].queue3 = sou_lev_se[index].queue2;
        sou_lev_se[index].queue2 = sou_lev_se[index].queue1;
        sou_lev_se[index].queue1 = sou_lev_se[index].queue0;
        sou_lev_se[index].queue0 = v1;
    } else if (!sou_lev_se[index].queue4) {
        sou_lev_se[index].queue4 = sou_lev_se[index].queue3;
        sou_lev_se[index].queue3 = sou_lev_se[index].queue2;
        sou_lev_se[index].queue2 = sou_lev_se[index].queue1;
        sou_lev_se[index].queue1 = sou_lev_se[index].queue0;
        sou_lev_se[index].queue0 = v1;
    } else if (!sou_lev_se[index].queue5) {
        sou_lev_se[index].queue5 = sou_lev_se[index].queue4;
        sou_lev_se[index].queue4 = sou_lev_se[index].queue3;
        sou_lev_se[index].queue3 = sou_lev_se[index].queue2;
        sou_lev_se[index].queue2 = sou_lev_se[index].queue1;
        sou_lev_se[index].queue1 = sou_lev_se[index].queue0;
        sou_lev_se[index].queue0 = v1;
    } else if (!sou_lev_se[index].queue6) {
        sou_lev_se[index].queue6 = sou_lev_se[index].queue5;
        sou_lev_se[index].queue5 = sou_lev_se[index].queue4;
        sou_lev_se[index].queue4 = sou_lev_se[index].queue3;
        sou_lev_se[index].queue3 = sou_lev_se[index].queue2;
        sou_lev_se[index].queue2 = sou_lev_se[index].queue1;
        sou_lev_se[index].queue1 = sou_lev_se[index].queue0;
        sou_lev_se[index].queue0 = v1;
    } else if (!sou_lev_se[index].queue7) {
        sou_lev_se[index].queue7 = sou_lev_se[index].queue6;
        sou_lev_se[index].queue6 = sou_lev_se[index].queue5;
        sou_lev_se[index].queue5 = sou_lev_se[index].queue4;
        sou_lev_se[index].queue4 = sou_lev_se[index].queue3;
        sou_lev_se[index].queue3 = sou_lev_se[index].queue2;
        sou_lev_se[index].queue2 = sou_lev_se[index].queue1;
        sou_lev_se[index].queue1 = sou_lev_se[index].queue0;
        sou_lev_se[index].queue0 = v1;
    }
    v2 = v1 & 0x80;
    sou_lev_se[index].echoEnableFlag = v2;
    v1 &= 0x7f;
    NA_COMMAND_AUDIO_SUBTRACK_SET_PORT(SE_GROUP, index + 8, 0, v1);
    sou_ls_stack[index]._0 = sou_ls_stack[index]._1;
    sou_ls_stack[index]._1 = sou_ls_stack[index]._2;
    sou_ls_stack[index]._2 = sou_ls_stack[index]._3;
    sou_ls_stack[index]._3 = 0;
}

void Sou_Insect_Lev_Cont() {
    u8 i = 0;
    for (i = 0; i < 50; i++) {
        if (sou_room_ins[i]._04 == sou_room_ins[i]._05) {
            sou_room_ins[i]._00 = 0;
            sou_room_ins[i]._04 = 0;
            sou_room_ins[i]._05 = 0;
            sou_room_ins[i]._06 = 0;
            sou_room_ins[i]._07 = 0;
        } else {
            sou_room_ins[i]._05 = sou_room_ins[i]._04;
        }
    }
}

void Sou_Ongen_Lev_Cont() {
    u8 i = 0;
    u8 j = 0;
    u8 k = 0;
    u8 found = FALSE;
    u8 old04 = 0;
    u8 old09 = 0;

    for (i = 0; i < ARRAY_COUNT(sou_ongen_entry); i++) {
        if (sou_ongen_entry[i]._00) {
            found = FALSE;
            for (j = 0; j < ARRAY_COUNT(sou_lev_ongen_data); j++) {
                if (sou_ongen_entry[i]._00 == sou_lev_ongen_data[j].entry_id) {
                    found = TRUE;
                }
            }

            if (!found) {
                for (j = 0; j < ARRAY_COUNT(sou_lev_ongen_data); j++) {
                    if (sou_lev_ongen_data[j].entry_id == 0) {
                        sou_lev_ongen_data[j].priority = sou_ongen_entry[i]._04;
                        sou_lev_ongen_data[j].entry_id = sou_ongen_entry[i]._00;
                        sou_lev_ongen_data[j].se_id = sou_ongen_entry[i]._06;
                        sou_lev_ongen_data[j].distance = sou_ongen_entry[i].distance;
                        sou_lev_se[j].pan = sou_ongen_entry[i].pan;

                        sou_lev_ongen_data[j].update_count = 1;
                        sou_lev_ongen_data[j].prev_update_count = 0;
                        sou_lev_ongen_data[j].prev_distance = 9999.f;
                        sou_lev_ongen_data[j].crossed_area_flag = 0;
                        sou_lev_ongen_data[j].state = 0;

                        // exit early
                        j = ARRAY_COUNT(sou_lev_ongen_data);
                    }
                }
            }
        }
    }

    for (i = 0; i < ARRAY_COUNT(sou_ongen_entry); i++) {
        if (sou_ongen_entry[i]._00) {
            if (sou_ongen_entry[i]._09 == sou_ongen_entry[i]._0A) {
                for (j = 0; j < ARRAY_COUNT(sou_lev_ongen_data); j++) {
                    if (sou_lev_ongen_data[j].entry_id == sou_ongen_entry[i]._00) {

                        Sou_LevStop((int)j, sou_lev_ongen_data[j].se_id);

                        old09 = sou_lev_ongen_data[j].priority;
                        sou_lev_ongen_data[j].priority = 0;
                        sou_lev_ongen_data[j].update_count = 0;
                        sou_lev_ongen_data[j].prev_update_count = 0;
                        sou_lev_ongen_data[j].state = 0;
                        sou_lev_ongen_data[j].crossed_area_flag = 0;
                        sou_lev_ongen_data[j].entry_id = 0;
                        sou_lev_ongen_data[j].se_id = 0;
                        sou_lev_ongen_data[j].distance = 9999.f;
                        sou_lev_ongen_data[j].prev_distance = 9999.f;
                        for (k = 0; k < ARRAY_COUNT(sou_lev_ongen_data); k++) {
                            if (sou_lev_ongen_data[k].priority > old09) {
                                sou_lev_ongen_data[k].priority--;
                            }
                        }

                        // exit early
                        j = ARRAY_COUNT(sou_lev_ongen_data);
                    }
                }
                old04 = sou_ongen_entry[i]._04;
                sou_ongen_entry[i]._04 = 0;
                sou_ongen_entry[i]._00 = 0;
                sou_ongen_entry[i]._06 = 0;
                sou_ongen_entry[i].pan = 0;
                sou_ongen_entry[i]._09 = 0;
                sou_ongen_entry[i]._0A = 0;
                sou_ongen_entry[i].distance = 9999.f;
                return;
            }

            for (j = 0; j < ARRAY_COUNT(sou_lev_ongen_data); j++) {
                if (sou_lev_ongen_data[j].entry_id == sou_ongen_entry[i]._00) {
                    sou_lev_ongen_data[j].distance = sou_ongen_entry[i].distance;
                    sou_lev_se[j].pan = sou_ongen_entry[i].pan;
                    sou_lev_ongen_data[j].update_count++;

                    // exit early
                    j = ARRAY_COUNT(sou_lev_ongen_data);
                }
            }
            sou_ongen_entry[i]._0A = sou_ongen_entry[i]._09;
        }
    }
}

void Sou_Ongen_Lev_Prog(u8 index) {
    u8 unused = 0;
    u8 i = 0;
    u8 t = 0;
    if (sou_pause_flag != 1) {
        if (sou_lev_ongen_data[index].entry_id == 0) {
            sou_lev_ongen_data[index].state = 0xff;
        }
        if (sou_lev_ongen_data[index].update_count == sou_lev_ongen_data[index].prev_update_count) {
            if (sou_lev_ongen_data[index].state == 2) {
                sou_lev_ongen_data[index].state = 3;
            }
        } else {
            if (sou_lev_ongen_data[index].state == 0) {
                sou_lev_ongen_data[index].state = 1;
            }
            if (sou_lev_ongen_data[index].state >= 3 && (sou_lev_ongen_data[index].state <= 6)) {
                sou_lev_ongen_data[index].state = 2;
            }
        }

        sou_lev_ongen_data[index].prev_update_count = sou_lev_ongen_data[index].update_count;
        if ((sou_lev_ongen_data[index].prev_distance <= SOU_ONGEN_AREA1) &&
            (sou_lev_ongen_data[index].distance > SOU_ONGEN_AREA1)) {
            sou_lev_ongen_data[index].crossed_area_flag = 0;
        }

        if ((sou_lev_ongen_data[index].prev_distance > SOU_ONGEN_AREA1) &&
            (sou_lev_ongen_data[index].distance <= SOU_ONGEN_AREA1)) {
            sou_lev_ongen_data[index].crossed_area_flag = 1;
        }

        sou_lev_ongen_data[index].prev_distance = sou_lev_ongen_data[index].distance;
        if ((sou_lev_ongen_data[index].state >= 3) && (sou_lev_ongen_data[index].state <= 6)) {
            sou_lev_ongen_data[index].state++;
        }

        if ((sou_lev_ongen_data[index].state == 1) && (sou_lev_ongen_data[index].crossed_area_flag == 1)) {
            Sou_LevStart((int)index, sou_lev_ongen_data[index].se_id);
            sou_lev_ongen_data[index].state = 2;
        }

        if (sou_lev_ongen_data[index].state == 7 || sou_lev_ongen_data[index].state == 0xff) {
            Sou_LevStop((int)index, sou_lev_ongen_data[index].se_id);
            t = sou_lev_ongen_data[index].priority;
            sou_lev_ongen_data[index].priority = 0;
            sou_lev_ongen_data[index].update_count = 0;
            sou_lev_ongen_data[index].prev_update_count = 0;
            sou_lev_ongen_data[index].state = 0;
            sou_lev_ongen_data[index].crossed_area_flag = 0;
            sou_lev_ongen_data[index].entry_id = 0;
            sou_lev_ongen_data[index].se_id = 0;
            sou_lev_ongen_data[index].distance = 9999.f;
            sou_lev_ongen_data[index].prev_distance = 9999.f;
            for (i = 0; i < ARRAY_COUNT(sou_lev_ongen_data); i++) {
                if (sou_lev_ongen_data[i].priority > t) {
                    sou_lev_ongen_data[i].priority--;
                }
            }
        }

        if (sou_lev_ongen_data[index].state != 0) {
            switch (sou_lev_ongen_data[index].se_id) {
                default:
                    sou_lev_se[index].volumeScale = distance2vol(sou_lev_ongen_data[index].distance);
                    break;
                case NA_ONGEN_POS_SE_4E:
                    sou_lev_se[index].volumeScale = distance2vol4MD(sou_lev_ongen_data[index].distance);
                    break;
            }
        }
    }
    return;
}

void Sou_BgmStart(u16 id, u16 fadeTime) {
    sou_now_bgm_num = id;
    if (id == BGM_SILENCE) {
        NA_COMMAND_AUDIO_STOP_SEQ(BGM0_GROUP, 0);
        NA_COMMAND_AUDIO_STOP_SEQ(BGM1_GROUP, 0);
        return;
    }
    u16 oldBGMHandle = sou_now_bgm_handle;
    sou_now_bgm_handle = (sou_now_bgm_handle == BGM0_GROUP) ? BGM1_GROUP : BGM0_GROUP;
    if (id >= BGM_KAPPA_SONG20 && id <= BGM_KAPPA_SONG29) {
        NA_COMMAND_AUDIO_GROUP_SET_PORT(oldBGMHandle, 0, sou_now_bgm_handle);
        NA_COMMAND_AUDIO_GROUP_SET_PORT(oldBGMHandle, 1, SEQ_TABLE[id]);
        Na_BgmMuteClear();
    } else if (id >= BGM_NINTENDO0 && id <= BGM_NINTENDO4) {
        int bb = (u8)(id - BGM_NINTENDO0);
        Na_SysTrgStart(bb + NA_SE_16F);
    } else {
        NA_COMMAND_AUDIO_STOP_SEQ(oldBGMHandle, fadeTime);
        NA_COMMAND_AUDIO_STOP_SEQ(sou_now_bgm_handle, 0);
        id = Sou_BgmTrackMute(id);
        Na_StartSeq(sou_now_bgm_handle, SEQ_TABLE[id], fadeTime);
        Na_StaffRollStart(SEQ_TABLE[id]);
        Na_SetKappaSeqHandle(sou_now_bgm_handle);
    }
}

void Sou_BGMVolMove() {
    f32 volume = 0.f;
    f32 unused = 0.f;
    if (sou_bgm_vol_move_time) {
        switch (sou_now_bgm_handle) {
            case BGM0_GROUP: {
                if (sou_bgm_vol_move_counter == 0) {
                    sou_bgm_vol_move_time = 0;
                    volume = sou_bgm_vol_move_target;
                } else {
                    if (sou_bgm_vol_move_counter == sou_bgm_vol_move_time && sou_bgm_vol_move_time) {
                        if (sou_bgm_vol_move_target - sou_bgm1_vol_now == 0.f) {
                            sou_bgm_vol_move_delta = 0.f;
                            sou_bgm_vol_move_counter = 1;
                        } else {
                            sou_bgm_vol_move_delta =
                                (sou_bgm_vol_move_target - sou_bgm1_vol_now) / (int)sou_bgm_vol_move_time;
                        }
                    }
                    volume = sou_bgm_vol_move_target + (-(sou_bgm_vol_move_delta * (int)sou_bgm_vol_move_counter));
                    sou_bgm_vol_move_counter--;
                    if (volume > 1.f) {
                        volume = 1.f;
                    }
                }
                if (volume > 1.f) {
                    volume = 1.f;
                }
                if (volume < 0.f) {
                    volume = 0.f;
                }
                sou_bgm1_vol_now = volume;
                NA_COMMAND_AUDIO_GRP_FADE_VOLUME_SCALE(BGM0_GROUP, volume);
            } break;
            case BGM1_GROUP: {
                if (sou_bgm_vol_move_counter == 0) {
                    sou_bgm_vol_move_time = 0;
                    volume = sou_bgm_vol_move_target;
                } else {
                    if (sou_bgm_vol_move_counter == sou_bgm_vol_move_time && sou_bgm_vol_move_time) {
                        if (sou_bgm_vol_move_target - sou_bgm2_vol_now == 0) {
                            sou_bgm_vol_move_delta = 0.f;
                            sou_bgm_vol_move_counter = 1;
                        } else {
                            sou_bgm_vol_move_delta =
                                (sou_bgm_vol_move_target - sou_bgm2_vol_now) / (int)sou_bgm_vol_move_time;
                        }
                    }
                    volume = sou_bgm_vol_move_target + (-(sou_bgm_vol_move_delta * (int)sou_bgm_vol_move_counter));
                    sou_bgm_vol_move_counter--;
                    if (volume > 1.f) {
                        volume = 1.f;
                    }
                }
                if (volume > 1.f) {
                    volume = 1.f;
                }
                if (volume < 0.f) {
                    volume = 0.f;
                }
                sou_bgm2_vol_now = volume;
                NA_COMMAND_AUDIO_GRP_FADE_VOLUME_SCALE(BGM1_GROUP, volume);
            } break;
        }
    }
}

void Sou_Na_BgmStart(u16 id) {
    u16 param = 0;
    Sou_BgmStart(id, param);
    if (BGM_IS_ANY_MD(id)) {
        Sou_GroupControl(BGM0_GROUP, 63, 0.f);
        Sou_GroupControl(BGM1_GROUP, 63, 0.f);
    }
}

void Sou_Na_BgmStop(u16 id) {
    sou_now_bgm_fadeout = 1;
    id &= 0xfff;

    if (sou_now_bgm_handle == BGM0_GROUP) {
        NA_COMMAND_AUDIO_STOP_SEQ(BGM0_GROUP, id);
    } else {
        NA_COMMAND_AUDIO_STOP_SEQ(BGM1_GROUP, id);
    }
}

void Sou_SpecialRoutine06() {
    u16 v = 0;
    switch (sou_bgm_call_buffer) {
        case 1: {
            Sou_Na_BgmStart(sou_bgm_call_buffer_u16);
        } break;
        case 2: {
            if (sou_now_bgm_handle == BGM0_GROUP) {
                sou_now_bgm_handle = BGM1_GROUP;
                NA_COMMAND_AUDIO_STOP_SEQ(BGM0_GROUP, 700);
                v = Sou_BgmTrackMute(sou_bgm_call_buffer_u16);
                Na_StartSeq(BGM1_GROUP, SEQ_TABLE[v], 700);
            } else {
                sou_now_bgm_handle = BGM0_GROUP;
                NA_COMMAND_AUDIO_STOP_SEQ(BGM1_GROUP, 700);
                v = Sou_BgmTrackMute(sou_bgm_call_buffer_u16);
                Na_StartSeq(BGM0_GROUP, SEQ_TABLE[v], 700);
            }
        } break;
        case 3: {
            Sou_Na_BgmStop(sou_bgm_call_buffer_fadetime);
        }
    }
}

void Sou_SpecialRoutine07() {
    sou_bgm_call_buffer = 0;
    sou_bgm_call_buffer_u16 = 0;
    sou_bgm_call_buffer_fadetime = 0;
}

void Sou_SeFadeoutRoutine() {
    u8 i = 0;
    f32 v1 = 0.f;
    f32 v2 = 0.f;
    for (i = 0; i < ARRAY_COUNT(sou_se_fade); i++) {
        if (sou_se_fade[i]._0 == 0xffff) {
            sou_se_fade[i].volumeScale = 0.f;
            sou_se_fade[i]._0 = 0;
            if (i >= 8 && i <= 14) {
                // @BUG - 'i' is out of range for sou_lev_se.
                // Level sounds are given to subtracks 8-14, so this index should be i - 8.
                sou_lev_se[i].volumeScale = 0.f;
            }
        } else if (sou_se_fade[i]._0 != 0) {
            if (sou_se_fade[i]._0 == sou_se_fade[i]._2) {
                sou_se_fade[i].volumeScale = 0.f;
                sou_se_fade[i]._0 = 0xffff;
            } else {
                v1 = sou_se_fade[i]._2 - sou_se_fade[i]._0;
                v2 = sou_se_fade[i]._2;
                sou_se_fade[i].volumeScale = v1 / v2;
                sou_se_fade[i]._0++;
            }
        }
    }
}

void Sou_SeFadeinRoutine() {
    u8 i = 0;
    f32 v1 = 0.f;
    f32 v2 = 0.f;
    for (i = 0; i < ARRAY_COUNT(sou_se_fade); i++) {
        if (sou_se_fade[i]._4 == 0xffff) {
            sou_se_fade[i].volumeScale = 1.f;
            sou_se_fade[i]._4 = 0;
            if (i >= 8 && i <= 14) {
                // @BUG - 'i' is out of range for sou_lev_se.
                // Level sounds are given to subtracks 8-14, so this index should be i - 8.
                sou_lev_se[i].volumeScale = 1.f;
            }
        } else if (sou_se_fade[i]._4 != 0) {
            if (sou_se_fade[i]._4 == sou_se_fade[i]._6) {
                sou_se_fade[i].volumeScale = 1.f;
                sou_se_fade[i]._4 = 0xffff;
            } else {
                // @BUG - For a fade in, the volume scale should be current / duration.
                // However, this uses (duration - current) / duration, which is the inverse,
                // and is correctly used for fading out.
                v1 = sou_se_fade[i]._6 - sou_se_fade[i]._4;
                v2 = sou_se_fade[i]._6;
                sou_se_fade[i].volumeScale = v1 / v2;
                sou_se_fade[i]._4++;
            }
        }
    }
}

void Sou_SeVolumeReset() {
    u8 i = 0;
    for (i = 0; i < ARRAY_COUNT(sou_lev_se); i++) {
        sou_se_fade[i + 8]._0 = 0;
        sou_se_fade[i + 8]._4 = 0;
        sou_lev_se[i].volumeScale = 0.f;
        sou_lev_se[i].baseVolumeScale = 1.f;
    }
}

void Sou_SeTrFadeout(u8 index, u16 b) {
    sou_se_fade[index]._0 = 1;
    sou_se_fade[index]._2 = b;
}

void Sou_SeFadeout(u16 a) {
    u8 i = 0;
    sou_se_fadeout_flag = 1;
    for (i = 0; i < ARRAY_COUNT(sou_lev_se); i++) {
        Sou_SeTrFadeout(i + 8, a);
    }
}

void Sou_SpecialRoutine08() {
    if (sou_ongenpos_kill_countdown != 0 && sou_ongenpos_kill_countdown != 1) {
        sou_ongenpos_kill_countdown--;
    }
}

