    if (ret == mCD_RESULT_SUCCESS) {
        mgr->_0014 = mCD_malloc_32(mCD_SD_LAND_SAVE_SIZE);
        bzero(mgr->_0014, mCD_SD_LAND_SAVE_SIZE);
        chan = mCsd_sdcard_slot_chk();
        if (chan >= 0) {
            mCsd_nowdrive_set(chan);
            mgr->_0004 = chan;
            mCsd_mura_read_start();
        } else {
            ret = mCD_RESULT_SD_SLOT;
            fileInfo->_04 = mCD_SD_PROBE_NO_SD;
        }
    }

    return ret;
