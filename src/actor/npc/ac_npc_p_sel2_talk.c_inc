            case 21:
            case 22:
                p_sel2->sd_result = 3;
                break;
            case 7:
                p_sel2->sd_result = 4;
                break;
            case 2:
            case 4:
            case 5:
            case 6:
            case 11:
                p_sel2->sd_result = 2;
                break;
            case mCD_TRANS_ERR_BUSY:
                break;
            default:
                p_sel2->sd_result = 2;
                break;
