#include "ac_museum_fish_priv.h"

void mfish_base_FishMove(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* game) {
    f32 t;
    if (actor->fish_idx == aGYO_TYPE_PIRANHA && actor->currentProcess != mfish_peck_process) {
        actor->speedF *= actor->init_data.speed_decay;
    } else {
        add_calc0(&actor->speedF, 1.0f - actor->init_data.speed_decay, 0.025f);
    }

    actor->speed.x = actor->speedF * sin_s(actor->angle.y);
    actor->speed.z = actor->speedF * cos_s(actor->angle.y);

    add_calc(&actor->speed.y, MAX(ABS(actor->speedF * sin_s(actor->angle.x)), 0.1f), 0.1f, 0.1f, 0.005f);
    add_calc2(&actor->position.y, actor->yOfsSpeed + actor->init_data.depthOfs, 0.1f, actor->speed.y);

    mfish_move_smooth(actor, game);
    mfish_get_flow_vec(actor, game);
    actor->position.x += actor->speed.x + actor->flow_vec.x;
    actor->position.z += actor->speed.z + actor->flow_vec.z;
    actor->position.y = actor->position.y + actor->flow_vec.y;
    actor->position.y = MAX(60, MIN(110, actor->position.y));
}

int mfish_PosWallCheck(MUSEUM_FISH_PRIVATE_DATA* priv, xyz_t* pos) {
    u32 flag = 0;
    xyz_t p = suisou_pos[priv->tank];
    f32 a, b, c, d;

    if (priv->tank < 4) {
        a = priv->init_data.tank_bounds + 45;
        b = priv->init_data.tank_bounds + 45;
        c = priv->init_data.tank_bounds + 45;
        d = priv->init_data.tank_bounds + 45;
    } else {
        a = priv->init_data.tank_bounds + 180;
        b = priv->init_data.tank_bounds + 180;
        c = priv->init_data.tank_bounds + 5;
        d = priv->init_data.tank_bounds + 45;
    }

    if (pos->x > p.x + a) {
        flag |= 4;
    } else if (pos->x < p.x - b) {
        flag |= 2;
    }

    if (pos->z > p.z + c) {
        flag |= 8;
    } else if (pos->z < p.z - d) {
        flag |= 0x10;
    }

    return flag;
}

BOOL mfish_WallCheck(MUSEUM_FISH_PRIVATE_DATA* prv) {
    xyz_t p, p1;

    p = prv->position;

    p.x += sin_s(prv->angle.y) * (GETREG(TAKREG, 70) + 30.0f);
    p.z += cos_s(prv->angle.y) * (GETREG(TAKREG, 70) + 30.0f);

    p1 = p;

    return mfish_PosWallCheck(prv, &p1) ? TRUE : FALSE;
}

s16 mfish_get_hide_camera_angle(MUSEUM_FISH_PRIVATE_DATA* priv) {
    s16 v = priv->angle.y;
    if (v > 0 || (priv->tank == 2 && RANDOM_F(1) < 0.8f)) {
        if (v > DEG2SHORT_ANGLE(90)) {
            v = DEG2SHORT_ANGLE(90) + DEG2SHORT_ANGLE(RANDOM_F(45));
        } else {
            v = DEG2SHORT_ANGLE(90) - DEG2SHORT_ANGLE(RANDOM_F(45));
        }
    } else {
        if (v > DEG2SHORT_ANGLE(-90)) {
            v = DEG2SHORT_ANGLE(-90) + DEG2SHORT_ANGLE(RANDOM_F(45));
        } else {
            v = DEG2SHORT_ANGLE(-90) - DEG2SHORT_ANGLE(RANDOM_F(45));
        }
    }
    return v;
}

void mfish_dummy_process_init(MUSEUM_FISH_PRIVATE_DATA* prv) {
    prv->hide_camera_angle = mfish_get_hide_camera_angle(prv);
    if (prv->tank == 2 && prv->angle.y < 0 && prv->hide_camera_angle > 0) {
        prv->moveSpeed1 = MAX(prv->init_data.speed_base, GETREG(TAKREG, 80) * 0.1f + 1.2f);
    }
    prv->currentProcess = mfish_dummy_process;
}

void mfish_dummy_process(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* game) {
    add_calc_short_angle2(&actor->goalAngle.y, actor->hide_camera_angle, CALC_EASE2(0.2f), DEG2SHORT_ANGLE(3.75f),
                          DEG2SHORT_ANGLE(0.25f));
    actor->targetBodyAngle.z = add_calc_short_angle2(&actor->angle.y, actor->goalAngle.y, CALC_EASE2(0.5f), DEG2SHORT_ANGLE(5.0f),
                                        DEG2SHORT_ANGLE(0.25f));
    add_calc_short_angle2(&actor->bodyAngle.z, actor->targetBodyAngle.z, CALC_EASE2(0.5f), DEG2SHORT_ANGLE(5.0f), DEG2SHORT_ANGLE(0.25f));

    if (actor->tank == mfish_TANK_2) {
        if (actor->goalAngle.y < 0) {
            actor->activityFrameCount--;
        } else {
            add_calc2(&actor->speedF, actor->moveSpeed1, 0.1f, 0.05f);
            add_calc0(&actor->moveSpeed1, 0.05f, 0.1f);
        }
    }
}

void mfish_normal_process_init(MUSEUM_FISH_PRIVATE_DATA* fishActor) {
    f32 ra;
    f32 t;
    f32 temp;

    ra = RANDOM_F(fishActor->init_data.speed_range) + fishActor->init_data.speed_base;
    t = (ra) / MAX(fishActor->init_data.speed_range + fishActor->init_data.speed_base, 1);

    if (ra > fishActor->speedF) {
        fishActor->moveSpeed1 = ra;
    }

    fishActor->yOfsSpeed = Rnd_EX_fx(10.0f) * t;

    fishActor->goalAngle.x =
        atans_table(fishActor->speedF, fishActor->yOfsSpeed + fishActor->init_data.depthOfs - fishActor->position.y) >> 4;
    fishActor->speed.y = 0;

    if (RANDOM_F(1) > fishActor->init_data.turn_probability) {
        int diff;

        fishActor->goalAngle.y += (s16)Rnd_EX_fx(fishActor->init_data.turn_angle_range * 2.0f);
        diff = fishActor->goalAngle.y - fishActor->angle.y;
        if (ABS((s16)diff) < DEG2SHORT_ANGLE(20)) {
            if ((s16)diff > 0) {
                fishActor->goalAngle.y += DEG2SHORT_ANGLE(20);
            } else {
                fishActor->goalAngle.y += DEG2SHORT_ANGLE(-20);
            }
        }

        fishActor->wobbleStrength = DEG2SHORT_ANGLE(t * 30.f + 20.0f);
    } else {
        if ((s16)(fishActor->goalAngle.y - fishActor->angle.y) > 0) {
            fishActor->goalAngle.y += DEG2SHORT_ANGLE(15);
        } else {
            fishActor->goalAngle.y += DEG2SHORT_ANGLE(-15);
        }

        fishActor->wobbleStrength = DEG2SHORT_ANGLE((GETREG(TAKREG, 42) + 40.0f) * t + 30.0f);
    }
    if ((s16)(fishActor->angle.y - fishActor->goalAngle.y) > 0) {
        fishActor->wobblePhase = DEG2SHORT_ANGLE(0);
    } else {
        fishActor->wobblePhase = DEG2SHORT_ANGLE(-180);
    }

    fishActor->flags &= ~0xC0;
    fishActor->currentProcess = mfish_normal_process;
}

void mfish_normal_process(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* game) {
    if (actor->wobbleStrength > DEG2SHORT_ANGLE(20)) {
        add_calc(&actor->speedF, actor->moveSpeed1, CALC_EASE(0.2f),
                 (((actor->wobbleStrength - DEG2SHORT_ANGLE(20)) / DEG2SHORT_ANGLE(2)) * 0.04f + 0.1f) * 0.5f, 0.05f);
    } else if (actor->activityFrameCount > actor->savedActivityFrameCount - 10) {
        add_calc(&actor->speedF, actor->moveSpeed1, CALC_EASE(0.5f), 0.75f, 0.05f);
    }
    add_calc_short_angle2(&actor->wobbleStrength, 0, CALC_EASE2(0.5f), DEG2SHORT_ANGLE(1.25f), DEG2SHORT_ANGLE(0.25f));
    actor->wobblePhase += DEG2SHORT_ANGLE(10.0f);
    actor->targetBodyAngle.z = add_calc_short_angle2(&actor->angle.y, actor->goalAngle.y + (s16)(actor->wobbleStrength * sin_s(actor->wobblePhase)),
                                        CALC_EASE2(0.5f), DEG2SHORT_ANGLE(6.25f), 45);
    add_calc_short_angle2(&actor->bodyAngle.z, actor->targetBodyAngle.z, CALC_EASE2(0.5f), DEG2SHORT_ANGLE(3.75f), 45);

    if (actor->speedF < 0.01f || actor->tank == mfish_TANK_2 && actor->speedF < 0.05f) {
        mfish_dummy_process_init(actor);
    } else if (actor->speedF > 1.0f && actor->flags & 0x1e) {
        if ((s16)(actor->angle.y - actor->avoid_angle) > 0) {
            actor->goalAngle.y = actor->avoid_angle + DEG2SHORT_ANGLE(112.5f);
        } else {
            actor->goalAngle.y = actor->avoid_angle - DEG2SHORT_ANGLE(112.5f);
        }
        actor->wobbleStrength = 0;
    }
}

void mfish_turn_process_init(MUSEUM_FISH_PRIVATE_DATA* actor) {
    s16 v = DEG2SHORT_ANGLE(RANDOM_F(75.0f)) + DEG2SHORT_ANGLE(45);
    actor->bodyAngle.y =
        DEG2SHORT_ANGLE(((actor->speedF + 0.5f) / (actor->init_data.speed_base + actor->init_data.speed_range + 0.5f)) * 7.5f + 7.5f);

    if (actor->flags & 0xC0) {
        if (actor->flags & 0x40) {
            v = ABS(v);
        } else {
            v = -ABS(v);
        }
    } else if (actor->flags & 0x1e) {
        if ((s16)(actor->angle.y - actor->avoid_angle) < 0) {
            v = -v;
        } else {
            v = v;
        }
    } else if (actor->flags & 0x20) {
        if ((s16)(actor->escape_angle - actor->angle.y) < 0) {
            v = -v;
        } else {
            v = v;
        }
    }

    if (v > 0) {
        actor->flags |= 0x40;
    } else {
        actor->flags |= 0x80;
    }

    actor->goalAngle.y += v;

    if (actor->tank == mfish_TANK_2) {
        s16 tmp = actor->goalAngle.y + DEG2SHORT_ANGLE(90);
        if (tmp > DEG2SHORT_ANGLE(135)) {
            actor->goalAngle.y = DEG2SHORT_ANGLE(-45);
        } else if (tmp > DEG2SHORT_ANGLE(-135)) {
            actor->goalAngle.y = DEG2SHORT_ANGLE(-135);
        }
    }

    actor->moveSpeed1 = actor->init_data.speed_base + actor->init_data.speed_range * 0.7f;

    if (RANDOM_F(1.0f) < 0.2f) {
        actor->processTimer = RANDOM_F(3.0f) + 1.0f;
    } else {
        actor->processTimer = 0;
    }
    actor->currentProcess = mfish_turn_process;
}

void mfish_turn_process(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* game) {
    if (ABS(actor->targetBodyAngle.z) > DEG2SHORT_ANGLE(20)) {
        add_calc(&actor->speedF, actor->moveSpeed1, CALC_EASE(0.1f), (GETREG(TAKREG, 0x4e) * 0.01f + 0.5f) * 0.5f, 0.05f);
    }
    add_calc2(&actor->moveSpeed1, MAX(actor->init_data.speed_base, 0.0f), 0.5f, 0.2f);
    add_calc_short_angle2(&actor->wobbleStrength, 0, CALC_EASE2(0.5f), DEG2SHORT_ANGLE(2.5f), DEG2SHORT_ANGLE(0.25f));
    actor->targetBodyAngle.z = add_calc_short_angle2(&actor->angle.y, actor->goalAngle.y + (s16)(actor->wobbleStrength * sin_s(actor->wobblePhase)),
                                        CALC_EASE(0.2f), actor->bodyAngle.y >> 1, DEG2SHORT_ANGLE(0.25f));
    add_calc_short_angle2(&actor->bodyAngle.z, actor->targetBodyAngle.z, CALC_EASE2(0.4f), DEG2SHORT_ANGLE(3.75f),
                          DEG2SHORT_ANGLE(0.25f));

    if (ABS((s16)(actor->angle.y - actor->goalAngle.y)) < DEG2SHORT_ANGLE(2) && actor->speedF < 0.1f) {
        if (actor->processTimer > 0) {
            if (mfish_WallCheck(actor)) {
                mfish_turn_process_init(actor);
            } else {
                mfish_normal_process_init(actor);
            }
            actor->processTimer--;
        } else {
            mfish_dummy_process_init(actor);
        }
    }
}

void mfish_peck_process_init(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* game) {
    f32 fVar8;
    f32 fVar9;
    int t;
    s16 atanx;
    s16 atany;
    f32 dist;

    actor->speed.y = 0.0f;
    mfish_get_player_angle(actor, game, &atanx, &atany, &dist);
    fVar9 = (actor->init_data).speed_range + (actor->init_data).speed_base;

    if (dist < 20.0f) {
        fVar9 *= 0.75f;
        actor->moveSpeed1 = MAX(fVar9, 0.5f);
    }

    if (fVar9 > actor->speedF) {
        actor->moveSpeed1 = fVar9;
    }

    fVar8 = (fVar9 / 8.0f);

    if (ABS((s16)(atanx - actor->angle.y)) < actor->init_data.turn_angle_range) {
        actor->goalAngle.y = atanx;
    } else if ((s16)(atanx - actor->angle.y) > 0) {
        actor->goalAngle.y = actor->angle.y + actor->init_data.turn_angle_range;
    } else {
        actor->goalAngle.y = actor->angle.y - actor->init_data.turn_angle_range;
    }

    if (atany < 0) {
        actor->yOfsSpeed = actor->yOfsSpeed + RANDOM_F(2.5f);
        actor->yOfsSpeed = MAX(MIN(10, actor->yOfsSpeed), -10);

    } else {
        actor->yOfsSpeed = actor->yOfsSpeed - RANDOM_F(2.5f);
        actor->yOfsSpeed = MAX(MIN(10, actor->yOfsSpeed), -10);
    }

    actor->wobbleStrength = DEG2SHORT_ANGLE((fVar8 * 30.0f) + 20.0f);

    if (qrand() & 0x8000) {
        actor->wobblePhase = DEG2SHORT_ANGLE(90);
    } else {
        actor->wobblePhase = DEG2SHORT_ANGLE(-90);
    }

    actor->flags &= ~0xC0;
    actor->currentProcess = mfish_peck_process;
}

void mfish_peck_process(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* gamex) {
    s16 atanx;
    s16 atany;
    f32 dist;

    mfish_get_player_angle(actor, gamex, &atanx, &atany, &dist);

    if (actor->wobbleStrength > DEG2SHORT_ANGLE(15)) {
        add_calc(&actor->speedF, actor->moveSpeed1, CALC_EASE(0.25f),
                 (((actor->wobbleStrength - DEG2SHORT_ANGLE(20)) / DEG2SHORT_ANGLE(2)) * 0.04f + 0.1f) * 0.5f, 0.05f);
    } else if (actor->activityFrameCount > actor->savedActivityFrameCount - 16) {
        add_calc(&actor->speedF, actor->moveSpeed1, CALC_EASE(0.1f), 0.5f, 0.05f);
    } else if (dist > 20) {
        add_calc2(&actor->speedF, MAX(actor->speedF, 0.4f), 0.25f, 0.05f);
    }

    add_calc_short_angle2(&actor->wobbleStrength, 0, CALC_EASE2(0.25f), DEG2SHORT_ANGLE(0.75f), DEG2SHORT_ANGLE(0.25f));
    actor->wobblePhase += DEG2SHORT_ANGLE(10);
    actor->targetBodyAngle.z = add_calc_short_angle2(&actor->angle.y, actor->goalAngle.y + (s16)(sin_s(actor->wobblePhase) * actor->wobbleStrength),
                                        CALC_EASE2(0.5f), DEG2SHORT_ANGLE(6.25f), DEG2SHORT_ANGLE(0.25f));
    add_calc_short_angle2(&actor->bodyAngle.z, actor->targetBodyAngle.z, CALC_EASE2(0.5f), DEG2SHORT_ANGLE(3.75f),
                          DEG2SHORT_ANGLE(0.25f));

    if (mfish_peck_wall_check(actor, gamex)) {
        if (RANDOM_F(1.0f) < 0.9f) {
            actor->speedF = -0.3f - RANDOM_F(0.3f);
            actor->activityFrameCount = 10;
        } else {
            actor->speedF = -0.5f;
            actor->activityFrameCount =
                actor->init_data.activeFramesMin + (s16)RANDOM_F(actor->init_data.activeFramesRange);
            actor->activityFrameCount >>= 3;
        }
        actor->savedActivityFrameCount = actor->activityFrameCount;
        actor->moveSpeed1 = 0.0f;
    }
}

void mfish_ground_peck_process_init(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* gamex) {
    xyz_t p = suisou_pos[actor->tank];
    xyz_t_sub(&p, &actor->position, &p);

    actor->yOfsSpeed = ((actor->init_data.collision_size * 0.3f + 65.0f) - MAX(ABS(p.x), ABS(p.z)) * 0.15f) - actor->init_data.depthOfs;
    actor->goalAngle.x = DEG2SHORT_ANGLE(60);
    actor->activityFrameCount = (int)(Rnd_EX_f(30.0f) + 15.0f) << 1;

    if (actor->currentProcess != mfish_ground_peck_process) {
        actor->processTimer = RANDOM_F(2.0f) + 3.0f;
    } else {
        actor->processTimer--;
    }

    actor->moveSpeed1 = 0.5f;
    actor->currentProcess = mfish_ground_peck_process;
}

void mfish_ground_peck_process(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* gamex) {
    xyz_t p = suisou_pos[actor->tank];
    xyz_t_sub(&p, &actor->position, &p);
    actor->yOfsSpeed = ((actor->init_data.collision_size * 0.3f + 65.0f) - (MAX(ABS(p.x), ABS(p.z)) * 0.15f)) - actor->init_data.depthOfs;
    xyz_t_mult_v(&actor->flow_vec, 0.1f);

    if (actor->position.y > actor->yOfsSpeed + actor->init_data.depthOfs + 4.0f) {
        if (actor->goalAngle.x < DEG2SHORT_ANGLE(40)) {
            actor->goalAngle.x = DEG2SHORT_ANGLE(40);
        }
        actor->activityFrameCount++;
        add_calc2(&actor->moveSpeed1, 0.5f, 0.6f, 0.5f);
    } else if ((s16)(actor->goalAngle.x - actor->angle.x) > 0) {
        add_calc2(&actor->moveSpeed1, 0.2f, 0.5f, 0.4f);
    } else {
        if (actor->speedF > 0) {
            actor->speedF = -0.2f;
        } else {
            add_calc0(&actor->moveSpeed1, 0.2f, 0.1f);
        }
    }

    if (actor->goalAngle.x < DEG2SHORT_ANGLE(15)) {
        actor->goalAngle.x = DEG2SHORT_ANGLE(15);
    }

    add_calc(&actor->speedF, actor->moveSpeed1 * cos_s(actor->angle.x), CALC_EASE(0.5f), 0.25f, 0.05f);

    mfish_dummy_process(actor, gamex);
}

void mfish_base_ct(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* gamex) {
    GAME_PLAY* play = (GAME_PLAY*)gamex;
    f32 f = RANDOM_F(2.0f);
    f32 s;
    s16 q = qrand();
    actor->speedF = f;
    actor->speed.x = cos_s(q) * f;
    actor->speed.z = sin_s(q) * f;
    actor->angle.y = q;
    actor->goalAngle.y = actor->angle.y;
    if (actor->fish_idx == aGYO_TYPE_CATFISH || actor->fish_idx == aGYO_TYPE_GIANT_CATFISH) {
        actor->yOfsSpeed = 0.0f;
    } else if (actor->fish_idx == aGYO_TYPE_FRESHWATER_GOBY) {
        actor->yOfsSpeed = RANDOM_F(5.0f);
    } else {
        actor->yOfsSpeed = RANDOM2_F(10.0f);
    }
    actor->speed.y = 0.0;
    actor->bobOfs = ZeroVec;
    actor->bobPhase = qrand();
    actor->targetBodyAngle.z = actor->angle.y;
}

void mfish_base_mv(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* gamex) {
    GAME_PLAY* game = (GAME_PLAY*)gamex;

    if (actor->collisionPatience > actor->init_data.collision_size * 20.0f) {
        actor->collisionPatience = 0.0f;
        actor->activityFrameCount = 0;
    }

    if (actor->activityFrameCount-- <= 0) {
        actor->activityFrameCount =
            actor->init_data.activeFramesMin + (s16)RANDOM_F(actor->init_data.activeFramesRange);
        actor->savedActivityFrameCount = actor->activityFrameCount;
        if (mfish_peck_check(actor, gamex)) {
            actor->activityFrameCount >>= 2;
            actor->savedActivityFrameCount = actor->activityFrameCount;
            mfish_peck_process_init(actor, gamex);
        } else if (mfish_WallCheck(actor)) {
            mfish_turn_process_init(actor);
        } else if (mfish_ground_peck_before_check(actor, gamex)) {
            mfish_ground_peck_process_init(actor, gamex);
        } else {
            mfish_normal_process_init(actor);
        }
    } else if (actor->currentProcess == mfish_normal_process) {
        if ((actor->flags & 0x1E && ABS((s16)(actor->avoid_angle - actor->angle.y)) < DEG2SHORT_ANGLE(30)) ||
            (actor->flags & 0x20 &&
             ABS((s16)(actor->escape_angle + DEG2SHORT_ANGLE(180) - actor->angle.y)) < DEG2SHORT_ANGLE(30))) {
            actor->activityFrameCount =
                actor->init_data.activeFramesMin + (s16)RANDOM_F(actor->init_data.activeFramesRange);
            actor->savedActivityFrameCount = actor->activityFrameCount;
            mfish_turn_process_init(actor);
        }
    }

    if (actor->fishType == 10) {
        actor->bobOfs.y = 0;
        actor->position.y = actor->init_data.depthOfs;
    } else if (actor->tank == mfish_TANK_2) {
        actor->bobOfs.y = sin_s(actor->bobPhase) * 0.2f;
    } else {
        actor->bobOfs.y = 0;
    }

    actor->bobPhase += DEG2SHORT_ANGLE(10);
    actor->currentProcess(actor, gamex);

    if (ABS(actor->bodyAngle.z) > ABS(actor->targetBodyAngle.z)) {
        add_calc2(&actor->speedF, MIN(GETREG(TAKREG, 19) * 0.1f + 0.2f, actor->speedF), 0.2f, 0.5f);
    }

    add_calc_short_angle2(&actor->angle.x, actor->goalAngle.x, CALC_EASE(0.1f), DEG2SHORT_ANGLE(5), DEG2SHORT_ANGLE(0.5f));
    add_calc_short_angle2(&actor->goalAngle.x, 0, CALC_EASE(0.1f), DEG2SHORT_ANGLE(2.5f), DEG2SHORT_ANGLE(0.5f));
    mfish_base_FishMove(actor, gamex);
}

void mfish_onefish_ct(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* gamex) {
    GAME_PLAY* game = (GAME_PLAY*)gamex;
    mfish_keyframe_c* s = &actor->kf;
    cKF_SkeletonInfo_R_ct(&s->keyframe, s->skeleton, s->animation[0], s->work, s->morph);
    cKF_SkeletonInfo_R_init_standard_repeat_speedsetandmorph(&s->keyframe, s->animation[0], NULL, 1.0f, 0.0f);
    actor->activityFrameCount = actor->init_data.activeFramesMin + (s16)RANDOM_F(actor->init_data.activeFramesRange);
    actor->savedActivityFrameCount = actor->activityFrameCount;
    actor->angle.x = DEG2SHORT_ANGLE(0);
    actor->angle.y = DEG2SHORT_ANGLE(-90);
    actor->angle.z = DEG2SHORT_ANGLE(0);
    actor->flow_vec = ZeroVec;
    return;
}

void mfish_onefish_mv(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* gamex) {
    cKF_SkeletonInfo_R_play(&actor->kf.keyframe);
}

int mfish_before_disp(GAME* game, cKF_SkeletonInfo_R_c* keyframe, int joint_idx, Gfx** joint_shape, u8* joint_flags,
                      void* arg, s_xyz* joint_rot, xyz_t* joint_pos) {
    MUSEUM_FISH_PRIVATE_DATA* actor = (MUSEUM_FISH_PRIVATE_DATA*)arg;
    if (joint_idx == 2) {
        int v, t;

        if (actor->tank != mfish_TANK_4) {
            v = 2;
        } else if (actor->init_data.fish_strength > 0.7f) {
            v = 1;
        } else if (actor->init_data.fish_strength > 0.5f) {
            v = 2;
        } else {
            v = 3;
        }

        t = joint_rot->y - (actor->bodyAngle.z * v);
        joint_rot->y = MY_CLAMP(t, DEG2SHORT_ANGLE(-60), DEG2SHORT_ANGLE(60));
        t = joint_rot->x - (actor->bodyAngle.z >> 1);
        joint_rot->x = MY_CLAMP(t, DEG2SHORT_ANGLE(-25), DEG2SHORT_ANGLE(25));
    }
    return TRUE;
}

void mfish_onefish_dw(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* gamex) {
    mfish_keyframe_c* skele;
    Mtx* mtx;
    GRAPH* graph;
    GAME_PLAY* play;

    play = (GAME_PLAY*)gamex;
    skele = &actor->kf;

    if (play->game.frame_counter % 2 != 0) {
        mtx = skele->mtx[0];
    } else {
        mtx = skele->mtx[1];
    }

    graph = play->game.graph;

    Matrix_translate(actor->position.x, actor->position.y + actor->bobOfs.y, actor->position.z, MTX_LOAD);
    Matrix_RotateY(actor->angle.y, MTX_MULT);

    Matrix_translate(0.0f, 0.25f * actor->init_data.ofs_y, 1.5f * actor->init_data.ofs_z, MTX_MULT);
    Matrix_RotateX(actor->angle.x, MTX_MULT);
    Matrix_RotateZ(MY_CLAMP(-(actor->bodyAngle.z >> 1), DEG2SHORT_ANGLE(-20), DEG2SHORT_ANGLE(20)), MTX_MULT);
    Matrix_translate(0.0f, 0.25f * -actor->init_data.ofs_y, 0.5f * -actor->init_data.ofs_z, MTX_MULT);
    Matrix_scale(actor->init_data.renderScale, actor->init_data.renderScale, actor->init_data.renderScale, MTX_MULT);

    OPEN_DISP(graph);
    gSPMatrix(NEXT_POLY_OPA_DISP, _Matrix_to_Mtx_new(play->game.graph), G_MTX_NOPUSH | G_MTX_LOAD | G_MTX_MODELVIEW);
    CLOSE_DISP(graph);

    cKF_Si3_draw_R_SV(&play->game, &skele->keyframe, mtx, &mfish_before_disp, 0, actor);
}

void mfish_ani_base_ct(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* gamex) {
    mfish_onefish_ct(actor, gamex);
    mfish_base_ct(actor, gamex);
    actor->currentProcess = mfish_normal_process;
    actor->fishType = 0;
}

void mfish_ani_base_mv(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* gamex) {
    GAME_PLAY* play = (GAME_PLAY*)gamex;
    mfish_onefish_mv(actor, gamex);
    mfish_base_mv(actor, gamex);
    Museum_Fish_BGCheck(actor, gamex);

    if (actor->tank == mfish_TANK_2) {
        actor->kf.keyframe.frame_control.speed =
            (actor->speedF * 3.0f) / (actor->init_data.speed_base + actor->init_data.speed_range) + 1.0f;
    } else if (actor->fish_idx == aGYO_TYPE_BITTERLING || actor->fish_idx == aGYO_TYPE_BROOK_TROUT ||
               actor->fish_idx == aGYO_TYPE_CRUCIAN_CARP) {
        if (actor->moveSpeed1 - 0.1f > actor->speedF && actor->currentProcess == mfish_normal_process &&
            actor->activityFrameCount > actor->savedActivityFrameCount - 10) {
            actor->kf.keyframe.frame_control.speed =
                ((actor->moveSpeed1 - actor->speedF) * 3.0f) / (actor->init_data.speed_base + actor->init_data.speed_range) + 1.5f;
        } else {
            add_calc2(&actor->kf.keyframe.frame_control.speed, 2.0f * actor->speedF + 0.5f, 0.2f, 0.1f);
        }
    } else {
        if (actor->activityFrameCount > actor->savedActivityFrameCount - 10 && actor->moveSpeed1 > 0) {
            actor->kf.keyframe.frame_control.speed =
                (actor->speedF * 4.0f) / (actor->init_data.speed_base + actor->init_data.speed_range) + 1.25f;
        } else {
            add_calc2(&actor->kf.keyframe.frame_control.speed, 2.0f * actor->speedF + 0.5f, 0.2f, 0.1f);
        }
    }

    mfish_body_wind_anime_play(actor, gamex);
}

void mfish_ani_base_dw(MUSEUM_FISH_PRIVATE_DATA* actor, GAME* gamex) {
    mfish_onefish_dw(actor, gamex);
}
