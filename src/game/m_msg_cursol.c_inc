static int mMsgTag_Jump_Ifhf(mMsg_Window_c* msg_p, int* idx_p) {
    static const mActor_name_t fruits_tbl[] = {
        EMPTY_NO,
        ITM_FOOD_APPLE,
        ITM_FOOD_ORANGE,
        ITM_FOOD_CHERRY,
        ITM_FOOD_PEAR,
        ITM_FOOD_PEACH,
        ITM_FOOD_COCONUT,
    };

    u8* data = msg_p->msg_data->text_buf.data + *idx_p;
    u8 fruit_idx;
    u16 msg_no;

    mFont_Get_TagPrmU8U16(data, &fruit_idx, &msg_no);
    if (mPr_GetPossessionItemIdx(Now_Private, fruits_tbl[fruit_idx]) >= 0) {
        mMsg_Set_continue_msg_num(msg_p, msg_no);
        (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
        return mMsg_RESULT_VOID;
    }

    return mMsgTag_dummy_proc(msg_p, idx_p);
}

static int mMsgTag_Jump_Ifmd(mMsg_Window_c* msg_p, int* idx_p) {
    u8* data = msg_p->msg_data->text_buf.data + *idx_p;
    u8 type;
    u16 msg_no;
    int match = FALSE;

    mFont_Get_TagPrmU8U16(data, &type, &msg_no);
    if (type == 1) {
        if (Now_Private->cloth.item == RSV_CLOTH) {
            match = TRUE;
        }
    } else if (type == 2) {
        if (ITEM_IS_MYUMBRELLA_TOOL((mActor_name_t)Now_Private->equipment)) {
            match = TRUE;
        }
    } else if (type == 3) {
        int door;
        mHm_hs_c* house = Common_Get(now_home);

        if (house != NULL) {
            door = house->door_original;
        } else {
            door = 0xFF;
        }

        if (door != 0xFF) {
            match = TRUE;
        }
    } else if (type == 4) {
        if (mRmTp_CheckNowPlayerHouseCarpet_MyOriginal() != 0) {
            match = TRUE;
        }
    } else if (type == 5) {
        if (mRmTp_CheckNowPlayerHouseWall_MyOriginal() != 0) {
            match = TRUE;
        }
    }

    if (match) {
        mMsg_Set_continue_msg_num(msg_p, msg_no);
        (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
        return mMsg_RESULT_VOID;
    }

    return mMsgTag_dummy_proc(msg_p, idx_p);
}

static int mMsgTag_Jump_Ifsd(mMsg_Window_c* msg_p, int* idx_p) {
    u8* data = msg_p->msg_data->text_buf.data + *idx_p;
    Animal_c* animal = NULL;
    int cloth_type = mNT_get_cloth_type(Now_Private->cloth.item, Now_Private->cloth.idx & 0xFF);
    NPC_ACTOR* npc = (NPC_ACTOR*)msg_p->client_actor_p;
    int cloth_l_attr;
    int cloth_h_attr;
    u16 msg0;
    u16 msg1;
    u16 msg2;
    u16 msg_no;

    if (npc != NULL && npc->actor_class.part == ACTOR_PART_NPC) {
        animal = npc->npc_info.animal_orig;
    }

    cloth_l_attr = mNpc_GetDefAnimalClothLAttr(animal);
    cloth_h_attr = mNpc_GetDefAnimalClothHAttr(animal);
    mFont_Get_TagPrmU16U16U16(data, &msg0, &msg1, &msg2);
    if (cloth_type == cloth_l_attr) {
        msg_no = msg0;
    } else if (cloth_type == cloth_h_attr) {
        msg_no = msg2;
    } else {
        msg_no = msg1;
    }

    mMsg_Set_continue_msg_num(msg_p, msg_no);
    (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
    return mMsg_RESULT_VOID;
}

static int mMsgTag_Jump_Ifpl(mMsg_Window_c* msg_p, int* idx_p) {
    u8* data = msg_p->msg_data->text_buf.data + *idx_p;
    NPC_ACTOR* npc = (NPC_ACTOR*)msg_p->client_actor_p;
    Animal_c* animal = NULL;
    u16 msg_match;
    u16 msg_not_match;
    u16 id;
    u8 cloth_name[mIN_ITEM_NAME_LEN];

    if (npc != NULL && npc->actor_class.part == ACTOR_PART_NPC) {
        animal = npc->npc_info.animal_orig;
    }

    mFont_Get_TagPrmU16U16(data, &msg_match, &msg_not_match);
    if (animal->cloth == Now_Private->cloth.item) {
        id = msg_match;
    } else {
        id = msg_not_match;
    }

    mMsg_Set_continue_msg_num(msg_p, id);
    (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
    mIN_copy_cloth_name_str(cloth_name, animal->cloth, animal->cloth_original_id);
    mMsg_Set_free_str(msg_p, mMsg_FREE_STR0, cloth_name, mIN_ITEM_NAME_LEN);
    mIN_copy_cloth_name_str(cloth_name, Now_Private->cloth.item, Now_Private->cloth.idx);
    mMsg_Set_free_str(msg_p, mMsg_FREE_STR1, cloth_name, mIN_ITEM_NAME_LEN);
    return mMsg_RESULT_VOID;
}

static int mMsgTag_Jump_Ifmo(mMsg_Window_c* msg_p, int* idx_p) {
    u8* data;
    u8* data_p;
    mActor_name_t monument;
    u16 msg_match;
    u16 msg_not_match;
    u16 id;

    data = msg_p->msg_data->text_buf.data;
    data_p = data + *idx_p;
    monument = mMM_check_monument_in_npc_house_block(msg_p->client_actor_p);
    mFont_Get_TagPrmU16U16(data_p, &msg_match, &msg_not_match);
    if (monument != EMPTY_NO) {
        id = msg_match;
        mMM_set_monument_name_str((mActor_name_t)monument, mMsg_FREE_STR0);
    } else {
        id = msg_not_match;
    }

    mMsg_Set_continue_msg_num(msg_p, id);
    (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
    return mMsg_RESULT_VOID;
}

static int mMsgTag_Jump_ChkBKey(mMsg_Window_c* msg_p, int* idx_p) {
    u8* data = msg_p->msg_data->text_buf.data;
    u8 key_min;
    u16 msg_no;

    mFont_Get_TagPrmU8U16(data + *idx_p, &key_min, &msg_no);
    if (msg_p->keyCnt_b >= key_min) {
        mMsg_Set_continue_msg_num(msg_p, msg_no);
        (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
        return mMsg_RESULT_VOID;
    }

    return mMsgTag_dummy_proc(msg_p, idx_p);
}

static int mMsgTag_Jump_ChkAllKey(mMsg_Window_c* msg_p, int* idx_p) {
    u8* data = msg_p->msg_data->text_buf.data;
    u8 key_min;
    u16 msg_no;
    int key_sum;

    key_sum = msg_p->keyCnt_a + msg_p->keyCnt_b + msg_p->keyCnt_x + msg_p->keyCnt_y + msg_p->keyCnt_other;
    mFont_Get_TagPrmU8U16(data + *idx_p, &key_min, &msg_no);
    if (key_sum >= key_min) {
        mMsg_Set_continue_msg_num(msg_p, msg_no);
        (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
        return mMsg_RESULT_VOID;
    }

    return mMsgTag_dummy_proc(msg_p, idx_p);
}

static int mMsgTag_Jump_Happy(mMsg_Window_c* msg_p, int* idx_p) {
    u8* data = msg_p->msg_data->text_buf.data;
    u8* data_p = data + *idx_p;
    u16 msg_hra;
    u16 msg_no_hra;
    u16 id;
    int hra_check;

    if (mEv_CheckArbeit() == FALSE) {
        hra_check = TRUE;
    } else {
        hra_check = FALSE;
    }

    mFont_Get_TagPrmU16U16(data_p, &msg_hra, &msg_no_hra);
    if (hra_check) {
        id = msg_hra;
    } else {
        id = msg_no_hra;
    }

    mMsg_Set_continue_msg_num(msg_p, id);
    (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
    return mMsg_RESULT_VOID;
}

static int mMsgTag_Jump(mMsg_Window_c* msg_p, int* idx_p) {
    static const mMsg_CONTROL_CODE_PROC proc[mFont_TAG_JUMP_NUM] = {
        &mMsgTag_Jump_NextForce,
        &mMsgTag_Jump_NextRandSec,
        &mMsgTag_Jump_NextRand2,
        &mMsgTag_Jump_NextRand3,
        &mMsgTag_Jump_NextRand4,
        &mMsgTag_Jump_Ifsj,
        &mMsgTag_Jump_Ifjj,
        &mMsgTag_Jump_Ifsx,
        &mMsgTag_Jump_Iftl,
        &mMsgTag_Jump_Ifhl,
        &mMsgTag_Jump_Ifbl,
        &mMsgTag_Jump_Ifil,
        &mMsgTag_Jump_Ific,
        &mMsgTag_Jump_Iffc,
        &mMsgTag_Jump_Ifpn,
        &mMsgTag_Jump_Ifdj,
        &mMsgTag_Jump_Ifkj,
        &mMsgTag_Jump_Ifgk,
        &mMsgTag_Jump_Ifmt,
        &mMsgTag_Jump_Ifda,
        &mMsgTag_Jump_Iftm,
        &mMsgTag_Jump_Ifwj,
        &mMsgTag_Jump_Ifhf,
        &mMsgTag_Jump_Ifmd,
        &mMsgTag_Jump_Ifsd,
        &mMsgTag_Jump_Ifpl,
        &mMsgTag_Jump_Ifmo,
        &mMsgTag_Jump_ChkBKey,
        &mMsgTag_Jump_ChkAllKey,
        &mMsgTag_Jump_Happy,
    };

    int id = mFont_Get_TagId(msg_p->msg_data->text_buf.data + *idx_p);
    return (*proc[id])(msg_p, idx_p);
}

static int mMsgTag_Talk3_3pbj(mMsg_Window_c* msg_p, int* idx_p) {
    u8* data = msg_p->msg_data->text_buf.data + *idx_p;
    u16 msg_no = mFont_Get_TagPrmU16(data);
    u8 feel = 0;
    u16 id;

    // @BUG - I have no clue if this is feel info or looks type... but it's a bug.
    feel = NPC_CLIP->get_talk_feel_proc();
    if (feel >= mNpc_FEEL_NUM) {
        feel = 0;
    }

    id = msg_no + feel;
    mMsg_Set_continue_msg_num(msg_p, id);
    (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
    return mMsg_RESULT_VOID;
}

