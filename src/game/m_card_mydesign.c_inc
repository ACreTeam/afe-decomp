static char l_comment_md_0_str1[32] ATTRIBUTE_ALIGN(4) = "āfāUāCāōé╠Ģ█æČéP";
static char l_comment_md_0_str2[32] ATTRIBUTE_ALIGN(4) = "āfāUāCāōé╠Ģ█æČéQ";
