    u16 not_found_id;
    u16 id;
    u8* data = msg_p->msg_data->text_buf.data + *idx_p;

    mFont_Get_TagPrmU8U16U16(data, &race, &found_id, &not_found_id);
    race--;
    if (CLIP(quest_manager_clip)->race2name_proc(name, race)) {
        mMsg_Set_free_str(msg_p, mMsg_FREE_STR0, name, ANIMAL_NAME_LEN);
        id = found_id;
    } else {
