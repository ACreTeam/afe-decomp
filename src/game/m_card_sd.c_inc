    S_SDprobe_fg = mSD_mura_nextname_get_common(mgr->sd_eng_name, &mgr->init_game_start_info._24);
}

extern int mSdcard_thread_init(int proc) {
    int started = TRUE;
    OSThread* thread = &MemCardThread;

    if (S_SDthread_use_fg == 0) {
        static void (*thread_proc[])(void*) = {
            mSdcardthread_main,    mSdtr_tiff_write_main, mSdtr_mura_write_main,
            mSdtr_sd_format_main,  mSdtr_mura_read_main,  mSdtr_sd_tiff_read,
            mSdtr_sd_CheckStation, mSdtr_sd_allcount_get, mSdtr_sd_nextname_get,
        };

        S_SDthread_use_fg = 1;
        S_SDprobe_fg = 0;
        osCreateThread2(thread, 15, thread_proc[proc], NULL, MemCardStack + sizeof(MemCardStack), sizeof(MemCardStack),
                        5);
        osStartThread(thread);
    } else {
        started = FALSE;
    }

    return started;
}

extern int mSdcard_thread_endchk(void) {
    int terminated = FALSE;

    if (OSIsThreadTerminated(&MemCardThread)) {
        terminated = TRUE;
        S_SDthread_use_fg = 0;
    }

    return terminated;
}

#define mCD_RESULT_SD_SLOT (-2)
#define mCD_SD_FILE_MAGIC 0x8936
#define mCD_SD_SAVE_DATA_SIZE 0x2E000
#define mCD_SD_ENCODE_BUF_SIZE 0xE22BC
#define mCD_SD_DIARY_READ_SIZE 0x20000
#define mCD_SD_DIARY_DATA_OFS 0x1460

typedef int (*mCD_SAVEHOME_PROC)(mCD_memMgr_c*, mCD_memMgr_fileInfo_c*);

typedef struct {
    /* 0x000 */ u16 checksum;
    /* 0x002 */ mLd_land_info_c land_info;
    /* 0x00C */ u16 field_38;
    /* 0x00E */ u16 _E;
    /* 0x010 */ u16 magic;
    /* 0x012 */ u8 save_compressed;
    /* 0x013 */ u8 diary_compressed;
} mCD_SD_file_hdr_c;

typedef struct sd_save_s {
    /* 0x00000 */ mCD_SD_file_hdr_c hdr;
    /* 0x00014 */ u8 save_data[mCD_SD_SAVE_DATA_SIZE];
    /* 0x2E014 */ u8 diary_data[ALIGN_NEXT(sizeof(mCD_keep_diary_c), 32)];
} SDSave_t;

typedef union sd_save_u {
    SDSave_t save;
    u8 __align[ALIGN_NEXT(sizeof(SDSave_t), mCD_MEMCARD_SECTORSIZE)];
} SDSave_u;

#define mCD_SD_FILE_DIARY_OFS (sizeof(mCD_SD_file_hdr_c) + mCD_SD_SAVE_DATA_SIZE)

