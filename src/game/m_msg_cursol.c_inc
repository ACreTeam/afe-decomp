static int mMsgTag_Str_NpcNamePersonal(mMsg_Window_c* msg_p, int* idx_p) {
    u8 name[ANIMAL_NAME_LEN];
    u8 looks;
    u16 found_id;
    u16 not_found_id;
    int id;
    u8* data = msg_p->msg_data->text_buf.data + *idx_p;

    mFont_Get_TagPrmU8U16U16(data, &looks, &found_id, &not_found_id);
    looks--;
    if (CLIP(quest_manager_clip)->looks2name_proc(name, looks)) {
        mMsg_Set_free_str(msg_p, mMsg_FREE_STR0, name, ANIMAL_NAME_LEN);
        id = found_id;
    } else {
        id = not_found_id;
    }

    mMsg_Set_continue_msg_num(msg_p, id);
    (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
    return mMsg_RESULT_VOID;
}

static int mMsgTag_Str_NpcNameTribe(mMsg_Window_c* msg_p, int* idx_p) {
    u8 name[ANIMAL_NAME_LEN];
    u8 race;
