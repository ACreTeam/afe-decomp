static int mCD_SD_CheckStation_sdmura_read_wait(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int ret = mCD_RESULT_BUSY;

    if (mCsd_thread_result_chk() != mCD_RESULT_ERROR) {
        if (mSdcardprobe_fg_chk() == 0) {
            ret = mCD_RESULT_SUCCESS;
            fileInfo->proc++;
        } else {
            mgr->chan = mCsd_nowdrive_get();
            fileInfo->_04 = mSdcardprobe_fg_chk();
            if (fileInfo->_04 == 41) {
                fileInfo->_04 = mCD_TRANS_ERR_CORRUPT;
            }
            ret = mCD_RESULT_SD_SLOT;
