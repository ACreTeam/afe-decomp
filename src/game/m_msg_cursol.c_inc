        EMPTY_NO,
        TREE_APPLE_FRUIT,
        TREE_ORANGE_FRUIT,
        TREE_CHERRY_FRUIT,
        TREE_PEAR_FRUIT,
        TREE_PEACH_FRUIT,
        TREE_PALM_FRUIT,
    };

    u8* data = msg_p->msg_data->text_buf.data + *idx_p;
    u8 fruit_idx;
    u16 msg_no;

    mFont_Get_TagPrmU8U16(data, &fruit_idx, &msg_no);
    if (mFI_GetItemNumField_BCT(fruit_start[fruit_idx], fruit_end[fruit_idx]) != 0) {
