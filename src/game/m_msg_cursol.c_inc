static int mMsgTag_Jump_NextRandSec(mMsg_Window_c* msg_p, int* idx_p) {
    u8* data = msg_p->msg_data->text_buf.data + *idx_p;
    u16 msg_min;
    u16 msg_max;

    mFont_Get_TagPrmU16U16(data, &msg_min, &msg_max);
    mMsg_Set_continue_msg_num(msg_p, (u16)get_random_timer(msg_min, (msg_max - msg_min) + 1));
    (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
    return mMsg_RESULT_VOID;
}

