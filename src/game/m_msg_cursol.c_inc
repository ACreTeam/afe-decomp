        (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
        return mMsg_RESULT_VOID;
    }

    return mMsgTag_dummy_proc(msg_p, idx_p);
}

static int mMsgTag_Jump_Ifgk(mMsg_Window_c* msg_p, int* idx_p) {
    static const s8 feel1_tbl[mNpc_FEEL_NUM] = {
        mNpc_FEEL_NORMAL, // mNpc_FEEL_NORMAL
        mNpc_FEEL_HAPPY, // mNpc_FEEL_HAPPY
        mNpc_FEEL_ANGRY, // mNpc_FEEL_ANGRY
        mNpc_FEEL_SAD, // mNpc_FEEL_SAD
        mNpc_FEEL_SLEEPY, // mNpc_FEEL_SLEEPY
        mNpc_FEEL_NORMAL, // mNpc_FEEL_PITFALL
    };

    u8* data = msg_p->msg_data->text_buf.data + *idx_p;
    u8 feel_type;
    u16 msg_no;
    u32 feel = 0;

    if (msg_p->client_actor_p != NULL && msg_p->client_actor_p->part == ACTOR_PART_NPC) {
        feel = CLIP(npc_clip)->get_feel_info_proc((NPC_ACTOR*)msg_p->client_actor_p);
    }
    
    mFont_Get_TagPrmU8U16(data, &feel_type, &msg_no);
    if (feel >= 6) {
        feel = 0;
    }
    if (feel_type == feel1_tbl[feel]) {
        mMsg_Set_continue_msg_num(msg_p, msg_no);
        (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
        return mMsg_RESULT_VOID;
    }

    return mMsgTag_dummy_proc(msg_p, idx_p);
}

