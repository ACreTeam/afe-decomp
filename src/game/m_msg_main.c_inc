static int mMsg_Main_KeyCnt_a(mMsg_Window_c* msg_p, GAME* game) {
    if (chkTrigger(BUTTON_A)) {
        msg_p->keyCnt_a++;
        if (msg_p->keyCnt_a > mMsg_KEY_MAX) {
            msg_p->keyCnt_a = mMsg_KEY_MAX;
        }

        return TRUE;
    }

    return FALSE;
}

static int mMsg_Main_KeyCnt_b(mMsg_Window_c* msg_p, GAME* game) {
    if (chkTrigger(BUTTON_B)) {
        msg_p->keyCnt_b++;
        if (msg_p->keyCnt_b > mMsg_KEY_MAX) {
            msg_p->keyCnt_b = mMsg_KEY_MAX;
        }

        return TRUE;
    }

    return FALSE;
}

static int mMsg_Main_KeyCnt_x(mMsg_Window_c* msg_p, GAME* game) {
    if (chkTrigger(BUTTON_X)) {
        msg_p->keyCnt_x++;
        if (msg_p->keyCnt_x > mMsg_KEY_MAX) {
            msg_p->keyCnt_x = mMsg_KEY_MAX;
        }

        return TRUE;
    }

    return FALSE;
}

static int mMsg_Main_KeyCnt_y(mMsg_Window_c* msg_p, GAME* game) {
    if (chkTrigger(BUTTON_Y)) {
        msg_p->keyCnt_y++;
        if (msg_p->keyCnt_y > mMsg_KEY_MAX) {
            msg_p->keyCnt_y = mMsg_KEY_MAX;
        }

        return TRUE;
    }

    return FALSE;
}

static int mMsg_Main_KeyCnt_other(mMsg_Window_c* msg_p, GAME* game) {
    int stickX;
    int stickY;
    int stickDir;
    int count = 0;

    if (chkTrigger(BUTTON_DUP) || chkTrigger(BUTTON_DDOWN) || chkTrigger(BUTTON_DLEFT) || chkTrigger(BUTTON_DRIGHT)) {
        count++;
    }

    if (chkTrigger(BUTTON_CLEFT) || chkTrigger(BUTTON_CDOWN) || chkTrigger(BUTTON_CUP) || chkTrigger(BUTTON_CRIGHT)) {
        count++;
    }

    if (chkTrigger(BUTTON_START)) {
        count++;
    }

    if (chkTrigger(BUTTON_Z)) {
        count++;
    }

    if (chkTrigger(BUTTON_L)) {
        count++;
    }

    if (chkTrigger(BUTTON_R)) {
        count++;
    }

    stickX = getJoystick_X();
    stickY = getJoystick_Y();
    if (stickX > -25 && stickX < 25 && stickY > -25 && stickY < 25) {
        stickDir = mMsg_STICK_NEUTRAL; // none
    } else if (stickX >= 0 && stickY >= 0) {
        stickDir = mMsg_STICK_BOT_RIGHT;
    } else if (stickX < 0 && stickY >= 0) {
        stickDir = mMsg_STICK_BOT_LEFT;
    } else if (stickX < 0 && stickY < 0) {
        stickDir = mMsg_STICK_TOP_LEFT;
    } else {
        stickDir = mMsg_STICK_TOP_RIGHT;
    }

    if (msg_p->keyCnt_stickDir != stickDir) {
        if (stickDir != mMsg_STICK_NEUTRAL) {
            count++;
        }

        msg_p->keyCnt_stickDir = stickDir;
    }

    if (count != 0) {
        msg_p->keyCnt_other += count;
        if (msg_p->keyCnt_other > mMsg_KEY_MAX) {
            msg_p->keyCnt_other = mMsg_KEY_MAX;
        }

        return TRUE;
    }

    return FALSE;
}

/**
 * @brief Updates key count statistics for the message window
 *
 * Tracks button presses and joystick movements for the message system.
 * Only updates counts when the key count flag is enabled.
 *
 * @param msg_p Pointer to the message window structure
 * @param game Pointer to the game structure
 */
extern void mMsg_Main_KeyCnt(mMsg_Window_c* msg_p, GAME* game) {
    if ((msg_p->status_flags & mMsg_STATUS_FLAG_KEYCNT) != 0) {
        mMsg_Main_KeyCnt_a(msg_p, game);
        mMsg_Main_KeyCnt_b(msg_p, game);
        mMsg_Main_KeyCnt_x(msg_p, game);
        mMsg_Main_KeyCnt_y(msg_p, game);
        mMsg_Main_KeyCnt_other(msg_p, game);
    } else {
        msg_p->keyCnt_stickDir = mMsg_STICK_NEUTRAL;
    }
}
