static aRST_THINK_PROC proc_table[11] = {
    (aRST_THINK_PROC)none_proc1,
    aRST_ready_sailing,
    aRST_sailing,
    aRST_settlement,
    aRST_hide,
    aRST_return,
    aRST_reset_ainote,
    aRST_racket_ainote,
    aRST_hunt,
    aRST_remain,
    aRST_timer,
};

typedef void (*aRST_THINK_INIT_PROC)(NPC_RESET_ACTOR* actor, GAME_PLAY* play);

static aRST_THINK_INIT_PROC init_table[12] = {
    (aRST_THINK_INIT_PROC)none_proc1,
    aRST_normal_wait_init,
    aRST_ready_sailing_init,
    aRST_sailing_init,
    aRST_settlement_init,
    aRST_hide_init,
    aRST_return_init,
    aRST_end_init,
    aRST_start_init,
    aRST_start2_init,
    aRST_start3_init,
    aRST_timer_sailing_init,
};

static void aRST_setup_think_proc(NPC_RESET_ACTOR* actor, GAME_PLAY* play, u8 think_idx) {
    static aNPC_TALK_REQUEST_PROC talk_request_table[] = {
        (aNPC_TALK_REQUEST_PROC)none_proc1,
        aRST_norm_talk_request,
        aRST_force_talk_request,
    };

    aRST_think_data_c* data_p = &dt_tbl[think_idx];

    actor->think_idx = think_idx;
    actor->think_proc = proc_table[data_p->think_proc];
    actor->npc_class.talk_info.talk_request_proc = talk_request_table[data_p->talk_req_type];
    actor->msg_type = data_p->msg_type;
    actor->think_after_talk_idx = data_p->think_after_talk_idx;
    (*init_table[data_p->think_init_proc])(actor, play);
    actor->think_changed = TRUE;
}

static void aRST_think_proc(NPC_ACTOR* nactorx, GAME_PLAY* play, int think_proc_type) {
    switch (think_proc_type) {
        case aNPC_THINK_PROC_INIT:
            aRST_think_init_proc(nactorx, play);
            break;
        case aNPC_THINK_PROC_MAIN:
            aRST_think_main_proc(nactorx, play);
            break;
    }
}

static void aRST_schedule_init_proc(NPC_ACTOR* nactorx, GAME_PLAY* play) {
    nactorx->think.think_proc = aRST_think_proc;
    NPC_CLIP->think_proc(nactorx, play, aNPC_THINK_IN_BLOCK, aNPC_THINK_TYPE_INIT);
}

static void aRST_schedule_main_proc(NPC_ACTOR* nactorx, GAME_PLAY* play) {
    if (!NPC_CLIP->think_proc(nactorx, play, -1, aNPC_THINK_TYPE_CHK_INTERRUPT)) {
        NPC_CLIP->think_proc(nactorx, play, -1, aNPC_THINK_TYPE_MAIN);
    }
}

static void aRST_schedule_proc(NPC_ACTOR* nactorx, GAME_PLAY* play, int sched_proc_type) {
    switch (sched_proc_type) {
        case aNPC_SCHEDULE_PROC_INIT:
            aRST_schedule_init_proc(nactorx, play);
            break;
        case aNPC_SCHEDULE_PROC_MAIN:
            aRST_schedule_main_proc(nactorx, play);
            break;
    }
}
