#ifdef __INTELLISENSE__
#include "m_player.h"
#include "m_common_data.h"
#endif

static int Player_actor_request_main_pull_cracker_all(GAME* game, int prio) {
    PLAYER_ACTOR* player;
    if (Player_actor_check_request_main_able(game, mPlayer_INDEX_PULL_CRACKER, prio)) {
        Player_actor_request_main_index(game, mPlayer_INDEX_PULL_CRACKER, prio);
        return TRUE;
    } else {
        return FALSE;
    }
}

static void Player_actor_setup_main_Pull_cracker(ACTOR* actor, GAME* game) {
    Player_actor_InitAnimation_Base2(actor, game, mPlayer_ANIM_CRACKER_FIRE1, mPlayer_ANIM_CRACKER_FIRE1, 1.0f, 1.0f,
                                     0.5f, -5.0f, cKF_FRAMECONTROL_STOP, mPlayer_PART_TABLE_NORMAL);
    Player_actor_setup_main_Base(actor, game);
}

static void Player_actor_Movement_Pull_cracker(ACTOR* actor) {
    Player_actor_Movement_Base_Braking_common(actor, 0.435f * 0.75f);
}

static int Player_actor_CulcAnimation_Pull_cracker(ACTOR* actor, f32* frame_calc) {
    return Player_actor_CulcAnimation_Base2(actor, frame_calc);
}

static void Player_actor_SetSound_Pull_cracker(ACTOR* actor) {
    PLAYER_ACTOR* player = (PLAYER_ACTOR*)actor;
    cKF_SkeletonInfo_R_c* kf0_p = &player->keyframe0;
    cKF_FrameControl_c* fc0_p = &kf0_p->frame_control;

    if (Player_actor_Check_AnimationFrame(fc0_p, 19.0f)) {
        Player_actor_sound_cracker(actor);
    }
}

static void Player_actor_SetEffect_Pull_cracker(ACTOR* actor, GAME* game) {
    PLAYER_ACTOR* player = (PLAYER_ACTOR*)actor;
    cKF_SkeletonInfo_R_c* kf0_p = &player->keyframe0;
    cKF_FrameControl_c* fc0_p = &kf0_p->frame_control;

    if (Player_actor_Check_AnimationFrame(fc0_p, 19.0f)) {
        eEC_CLIP->effect_make_proc(eEC_EFFECT_CLACKER, player->right_hand_pos, 2, actor->shape_info.rotation.y, game, RSV_NO, 0, 0);
    }
}

static void Player_actor_ChangeItemNo_Pull_cracker(ACTOR* actor) {
    PLAYER_ACTOR* player = (PLAYER_ACTOR*)actor;
    cKF_SkeletonInfo_R_c* kf0_p = &player->keyframe0;
    cKF_FrameControl_c* fc0_p = &kf0_p->frame_control;

    if (Player_actor_Check_AnimationFrame(fc0_p, 19.0f)) {
        Player_actor_Set_ItemNoSubmenu(EMPTY_NO);
    }
}

static void Player_actor_SearchAnimation_Pull_cracker(ACTOR* actor, GAME* game, float frame) {
    if (!Player_actor_Check_AnimationFrame_PerfectEquel(actor, frame)) {
        Player_actor_SetSound_Pull_cracker(actor);
        Player_actor_SetEffect_Pull_cracker(actor, game);
        Player_actor_ChangeItemNo_Pull_cracker(actor);
    }
}

static void Player_actor_ObjCheck_Pull_cracker(ACTOR* actor, GAME* game) {
    Player_actor_Excute_Corect_forStand(actor, game);
}

static void Player_actor_BGcheck_Pull_cracker(ACTOR* actor) {
    Player_actor_BGcheck_common_type1(actor);
}

static void Player_actor_request_proc_index_fromPull_cracker(ACTOR* actor, GAME* game, int end_flag) {
    if (end_flag) {
        Player_actor_SettleRequestMainIndexPriority(actor);
        Player_actor_request_main_wait_all(game, -5.0f, 0.0f, 0, mPlayer_REQUEST_PRIORITY_1);
    }
}

static void Player_actor_main_Pull_cracker(ACTOR* actor, GAME* game) {
    int end_flag;
    float frame_calc;

    Player_actor_Movement_Pull_cracker(actor);
    Player_actor_Reinput_force_position_angle(actor, game);
    end_flag = Player_actor_CulcAnimation_Pull_cracker(actor, &frame_calc);
    Player_actor_SearchAnimation_Pull_cracker(actor, game, frame_calc);
    Player_actor_recover_lean_angle(actor);
    Player_actor_set_tex_anime_pattern(actor);
    Player_actor_ObjCheck_Pull_cracker(actor, game);
    Player_actor_BGcheck_Pull_cracker(actor);
    Player_actor_Item_main(actor, game);
    Player_actor_request_proc_index_fromPull_cracker(actor, game, end_flag);
}
