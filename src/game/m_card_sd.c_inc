    }

    return ret;
}

static int mCD_SD_CheckStation_check_this_land_sd(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int ret;

    ret = mCD_SD_get_this_land_slot_no_game_start(mgr);
    if (ret == mCD_RESULT_SUCCESS && mgr->chan != -1) {
        Save_t* save = (Save_t*)mgr->workArea;
        if (save->copy_protect == Common_Get(copy_protect)) {
            mgr->chan = ~mgr->chan & 1;
            fileInfo->proc++;
            ret = mCD_RESULT_SUCCESS;
        } else {
            fileInfo->_04 = mCD_TRANS_ERR_WRONG_LAND;
            ret = mCD_RESULT_SD_SLOT;
        }
    } else {
        s32 chan = mgr->chan;

        fileInfo->_04 = mCD_TRANS_ERR_NOCARD;
        if (chan != -1) {
            mCD_memMgr_card_info_c* card = &mgr->cards[chan];

            fileInfo->_04 = card->game_result;
        }
        ret = mCD_RESULT_SD_SLOT;
    }

    return ret;
}

static int mCD_SD_CheckStation_check_this_land(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int ret;

    if (mCD_movingInfo_get() == 2) {
        ret = mCD_CheckStation_check_this_land(mgr, fileInfo);
        if (ret <= -1) {
            fileInfo->_04 = mCD_TRANS_ERR_NOCARD;
        }
        return ret;
    }

    return mCD_SD_CheckStation_check_this_land_sd(mgr, fileInfo);
}

static int mCdsd_rent_code_chk(SDSave_t* sd_save) {
    Save_t* save = Common_GetPointer(save.save);
    mCD_SD_file_hdr_c* hdr = &sd_save->hdr;
    SDSaveInfo_c* sd_save_info = &save->sd_save_info;
    int ret = mCD_RESULT_SUCCESS;
    int i;

    for (i = 0; i < 8; i++) {
        if (hdr->field_38 == sd_save_info->_00003C[i] && hdr->_E != sd_save_info->_00004C[i]) {
            ret = mCD_RESULT_BUSY;
            break;
        }
    }

    return ret;
}

static int mCD_SD_CheckStation_check_next_land_sd(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    s32 chan;
    Save_t* save;
    SDSave_t* sd_save;
    mCD_memMgr_card_info_c* card;
    u16 checksum;
    int ret = mCD_RESULT_SUCCESS;

    chan = mgr->chan;
    if (mgr->workArea != NULL && chan != -1 && mCsd_sdcard_sweet_chk() == TRUE) {
        bzero(mgr->workArea, mgr->workArea_size);
        card = &mgr->cards[chan];
        card->_8C = 0;
        mCsd_nowdrive_set(chan);
        if (mgr->_0014 != NULL) {
            sd_save = (SDSave_t*)mgr->_0014;
            if (mFRm_ReturnCheckSum((u16*)mgr->_0014, mCD_SD_LAND_SAVE_SIZE) == 0) {
                if (sd_save->hdr.save_compressed == 1) {
                    decode_asr(sd_save->save_data, (u8*)mgr->workArea);
                } else {
                    memcpy(mgr->workArea, sd_save->save_data, mCD_SD_SAVE_DATA_SIZE);
                }

                checksum = mFRm_ReturnCheckSum((u16*)mgr->workArea, mgr->workArea_size);
                save = (Save_t*)mgr->workArea;
                if (checksum == 0) {
                    if (mLd_CheckId(save->land_info.id) == TRUE) {
                        if (mLd_CheckThisLand(save->land_info.name, save->land_info.id) == FALSE) {
                            if (mCdsd_rent_code_chk(sd_save) == mCD_RESULT_SUCCESS) {
                                fileInfo->_04 = mCD_TRANS_ERR_NONE_NEXTLAND;
                                fileInfo->proc = 4;
                                return mCD_RESULT_SUCCESS;
                            } else {
                                fileInfo->_04 = 31;
                                return mCD_RESULT_SD_SLOT;
                            }
                        } else {
                            fileInfo->_04 = 26;
                            return mCD_RESULT_SD_SLOT;
                        }
                    } else {
                        fileInfo->_04 = mCD_TRANS_ERR_CORRUPT;
                        return mCD_RESULT_SD_SLOT;
                    }
                } else {
                    fileInfo->_04 = mCD_TRANS_ERR_CORRUPT;
                    return mCD_RESULT_SD_SLOT;
                }
            } else {
                fileInfo->_04 = mCD_TRANS_ERR_CORRUPT;
                return mCD_RESULT_SD_SLOT;
            }
        } else {
            fileInfo->_04 = 41;
            return mCD_RESULT_SD_SLOT;
        }
    } else {
        fileInfo->_04 = mCD_TRANS_ERR_NO_TOWN_DATA;
        return mCD_RESULT_SD_SLOT;
    }

    fileInfo->_04 = mCD_TRANS_ERR_NONE_NEXTLAND;
    fileInfo->proc = 4;
    return ret;
}

static int mCD_SD_CheckStation_check_next_land(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    Save_t* save;
    int ret;

    if (mCD_movingInfo_get() == 2) {
        ret = mCD_SD_CheckStation_check_next_land_sd(mgr, fileInfo);
    } else {
        ret = mCD_CheckStation_check_next_land(mgr, fileInfo);
        if (ret == mCD_RESULT_SUCCESS) {
            save = (Save_t*)mgr->workArea;
            if (memcmp(&S_keep_landinfo, &save->land_info, sizeof(S_keep_landinfo)) != 0) {
                ret = mCD_RESULT_ERROR;
                fileInfo->_04 = 30;
            } else {
                fileInfo->proc = 4;
            }
        } else {
            switch (fileInfo->_04) {
                case mCD_TRANS_ERR_TRAVEL_DATA_MISSING:
                case mCD_TRANS_ERR_NO_SPACE:
                case mCD_TRANS_ERR_NO_TOWN_DATA:
                    fileInfo->_04 = 30;
                    break;
                default:
                    break;
            }
        }
    }

    return ret;
}

extern int mCD_SD_CheckStation_bg(mCD_sd_card_info_c* sd_info) {
    mCD_memMgr_c* mgr = &l_memMgr;
    mCD_memMgr_fileInfo_c* fileInfo = &mgr->init_game_start_info;
    u8 proc;
    int res;
    int ret = mCD_SD_BG_BUSY;

    proc = (u8)fileInfo->proc;
    fileInfo->_04 = mCD_TRANS_ERR_NOCARD;
    sd_info->exist = FALSE;
    if (proc < 4) {
        // clang-format off
        static mCD_CHECKSTATION_PROC check_proc[] = {
            mCD_SD_CheckStation_get_area,
            mCD_SD_CheckStation_sdmura_read_wait,
            mCD_SD_CheckStation_check_this_land,
            mCD_SD_CheckStation_check_next_land,
        };
        // clang-format on

        res = (*check_proc[proc])(mgr, fileInfo);
        if (res == mCD_RESULT_SUCCESS) {
            if (fileInfo->proc == 4) {
                sd_info->chan = mgr->chan;
                ret = fileInfo->_04;
                mCD_ClearMemMgr_com2(mgr);
            }
        } else if (res != mCD_RESULT_BUSY) {
            sd_info->chan = mgr->chan;
            if (res == mCD_RESULT_SD_SLOT) {
                sd_info->chan = mCsd_nowdrive_get();
                sd_info->exist = TRUE;
            }
            ret = fileInfo->_04;
            mCD_ClearMemMgr_com2(mgr);
        }
    } else {
        sd_info->chan = mgr->chan;
        ret = mCD_TRANS_ERR_NOCARD;
        mCD_ClearMemMgr_com2(mgr);
    }

    if (ret != mCD_SD_BG_BUSY) {
        SoftResetEnable = TRUE;
    }

    return ret;
}

#pragma optimizewithasm off
static int mCD_SD_CheckStation_bg_thread(void) {
    mCD_sd_card_info_c sd_info;
    mCD_memMgr_c* mgr = &l_memMgr;
    mCD_memMgr_fileInfo_c* fileInfo = &mgr->init_game_start_info;
    register mCD_sd_card_info_c* sd_info_p;
    u8 proc;
    int res;
    int ret = mCD_SD_BG_BUSY;

    sd_info_p = &sd_info;
    proc = (u8)fileInfo->proc;
    fileInfo->_04 = mCD_TRANS_ERR_NOCARD;
    sd_info_p->exist = FALSE;
    if (proc < 4) {
        // clang-format off
        static mCD_CHECKSTATION_PROC check_proc[] = {
            mCD_SD_CheckStation_get_area,
            mCD_SD_CheckStation_check_this_land,
            mCD_SD_CheckStation_check_next_land,
            NULL,
        };
        // clang-format on

        res = (*check_proc[proc])(mgr, fileInfo);
        if (res == mCD_RESULT_SUCCESS) {
            if (fileInfo->proc == 4) {
                ret = fileInfo->_04;
                sd_info_p->chan = mgr->chan;
                mCD_ClearMemMgr_com2(mgr);
            }
        } else if (res != mCD_RESULT_BUSY) {
            sd_info_p->chan = mgr->chan;
            if (res == mCD_RESULT_SD_SLOT) {
                // TODO: This forces the compiler to store the result of mCsd_nowdrive_get into
                // chan immediately. Otherwise, the '1' literal immediate is loaded into r0
                // before the store instruction.
#if defined(MUST_MATCH) && defined(__MWERKS__)
                register int tmp = mCsd_nowdrive_get();
                asm {
                    stw tmp, (mCD_sd_card_info_c.chan)(sd_info_p)
                }
#else
                sd_info.chan = mCsd_nowdrive_get();
#endif
                sd_info.exist = TRUE;
            }
            ret = fileInfo->_04;
            mCD_ClearMemMgr_com2(mgr);
        }
    } else {
        sd_info_p->chan = mgr->chan;
        ret = mCD_TRANS_ERR_NOCARD;
        mCD_ClearMemMgr_com2(mgr);
    }

    if (ret != mCD_SD_BG_BUSY) {
        SoftResetEnable = TRUE;
    }

    return ret;
}
#pragma optimizewithasm reset

static int mCD_SD_SaveStation_NextLand_get_area(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    Save_t* save;
    s32 chan;
    int ret;

    ret = mCD_bg_get_area_common(mgr, fileInfo, mCD_FILE_SD_LAND, 0);
    if (ret == mCD_RESULT_SUCCESS) {
        SoftResetEnable = FALSE;
        if (mCD_movingInfo_get() == 2) {
            if (mCD_get_this_land_slot_no_nes(mgr) == mCD_RESULT_SUCCESS) {
                save = (Save_t*)mgr->workArea;
                if (mCD_check_copyProtect(save, mgr->chan) == TRUE) {
                    memcpy(&S_keep_landinfo, Save_GetPointer(land_info), sizeof(S_keep_landinfo));
                } else {
                    ret = mCD_RESULT_ERROR;
                    fileInfo->_04 = mCD_TRANS_ERR_WRONG_LAND;
                }
            } else {
                ret = mCD_RESULT_ERROR;
                fileInfo->_04 = mCD_TRANS_ERR_NOCARD;
            }
        } else {
            fileInfo->proc = 3;
        }
    } else if (ret != mCD_RESULT_BUSY) {
        ret = mCD_RESULT_ERROR;
        fileInfo->_04 = mCD_TRANS_ERR_NOCARD;
    }

    if (ret == mCD_RESULT_SUCCESS) {
        mgr->_0014 = mCD_malloc_32(mCD_SD_LAND_SAVE_SIZE);
        bzero(mgr->_0014, mCD_SD_LAND_SAVE_SIZE);
        chan = mCsd_sdcard_slot_chk();
        if (chan >= 0) {
            mCsd_nowdrive_set(chan);
            mgr->_0004 = chan;
            mCsd_mura_read_start();
        } else {
            ret = mCD_RESULT_SD_SLOT;
            fileInfo->_04 = mCD_TRANS_ERR_NOCARD;
        }
    }

    return ret;
}

static int mCD_SD_SaveStation_NextLand_check_repair_land(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int ret = mCD_RESULT_BUSY;

    if (mCsd_thread_result_chk() != mCD_RESULT_ERROR) {
        if (mSdcardprobe_fg_chk() == 0) {
            if (mCD_check_broken_land(mgr) == TRUE) {
                if (mCD_repair_load_land(mgr) == TRUE) {
                    fileInfo->proc++;
                } else {
                    fileInfo->proc = 3;
                    mgr->chan = ~mgr->chan & 1;
                    mgr->loaded_file_type = mCD_FILE_SAVE_MAIN;
                    mgr->workArea_size = mCD_get_size(mgr->loaded_file_type);
                }
            } else {
                fileInfo->proc = 3;
                mgr->chan = ~mgr->chan & 1;
                mgr->loaded_file_type = mCD_FILE_SAVE_MAIN;
                mgr->workArea_size = mCD_get_size(mgr->loaded_file_type);
            }
            ret = mCD_RESULT_SUCCESS;
        } else {
            fileInfo->_04 = mSdcardprobe_fg_chk();
            ret = mCD_RESULT_SD_SLOT;
        }
    }

    return ret;
}

static int mCD_SD_SaveStation_NextLand_get_next_land_data_common(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    Save_t* save;
    mCD_memMgr_card_info_c* card;
    s32 chan;
    int i;
    int ret = mCD_RESULT_ERROR;

    chan = mgr->chan;
    if (mgr->workArea != NULL && chan != -1) {
        bzero(mgr->workArea, mgr->workArea_size);
        card = &mgr->cards[chan];
        card->_8C = 0;
        for (i = 0; i < 2; i++) {
            if (mCD_load_file(mgr->workArea, mCD_FILE_SAVE_MAIN + i, chan, &card->result) == mCD_RESULT_SUCCESS) {
                u16 checksum = mFRm_ReturnCheckSum((u16*)mgr->workArea, mgr->workArea_size);
                save = (Save_t*)mgr->workArea;
                if (checksum == 0) {
                    if (mLd_CheckId(save->land_info.id) == TRUE) {
                        if (mLd_CheckThisLand(save->land_info.name, save->land_info.id) == FALSE) {
                            if (memcmp(&S_keep_landinfo, &save->land_info, sizeof(S_keep_landinfo)) != 0) {
                                fileInfo->_04 = 30;
                                ret = mCD_RESULT_ERROR;
                                break;
                            }

                            fileInfo->proc++;
                            bcopy(save, &l_keepSave, sizeof(Save));
                            l_keepSave_set = TRUE;
                            ret = mCD_RESULT_SUCCESS;
                            break;
                        }

                        fileInfo->_04 = mCD_TRANS_ERR_NO_TOWN_DATA;
                        ret = mCD_RESULT_ERROR;
                        continue;
                    } else {
                        fileInfo->_04 = mCD_TRANS_ERR_CORRUPT;
                        ret = mCD_RESULT_ERROR;
                        continue;
                    }
                } else {
                    fileInfo->_04 = mCD_TRANS_ERR_CORRUPT;
                    ret = mCD_RESULT_ERROR;
                    continue;
                }
            } else {
                card->_8C++;
                ret = mCD_RESULT_ERROR;
                continue;
            }
        }

        if (card->_8C == 2) {
            switch (card->result) {
                case CARD_RESULT_WRONGDEVICE:
                    fileInfo->_04 = mCD_TRANS_ERR_WRONGDEVICE;
                    break;
                case CARD_RESULT_NOCARD:
                    fileInfo->_04 = mCD_TRANS_ERR_NO_TOWN_DATA;
                    break;
                case CARD_RESULT_IOERROR:
                    fileInfo->_04 = mCD_TRANS_ERR_DAMAGED;
                    break;
                case CARD_RESULT_ENCODING:
                case CARD_RESULT_BROKEN:
                    fileInfo->_04 = mCD_TRANS_ERR_BROKEN_WRONGENCODING;
                    break;
                default:
                    if (l_mcd_keep_startCond == 3) {
                        fileInfo->_04 = mCD_TRANS_ERR_TRAVEL_DATA_MISSING;
                    } else {
                        fileInfo->_04 = mCD_TRANS_ERR_NO_TOWN_DATA;
                    }
                    break;
            }
            return mCD_RESULT_ERROR;
        }
    } else {
        fileInfo->_04 = mCD_TRANS_ERR_NO_TOWN_DATA;
        return mCD_RESULT_ERROR;
    }

    return ret;
}

static int mCD_SD_SaveStation_NextLand_get_next_land_data(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    SDSave_t* sd_save;
    Save_t* save;
    mCD_memMgr_card_info_c* card;
    s32 chan;
    int ret = mCD_RESULT_BUSY;
    u16 checksum;

    chan = mgr->chan;
    if (mCD_movingInfo_get() == 2) {
        if (mgr->workArea != NULL && chan != -1 && mCsd_sdcard_sweet_chk() == TRUE) {
            bzero(mgr->workArea, mgr->workArea_size);
            card = &mgr->cards[chan];
            card->_8C = 0;
            mCsd_nowdrive_set(chan);
            if (mgr->_0014 != NULL) {
                sd_save = (SDSave_t*)mgr->_0014;
                if (mFRm_ReturnCheckSum((u16*)sd_save, mCD_SD_LAND_SAVE_SIZE) == 0) {
                    if (sd_save->hdr.save_compressed == 1) {
                        decode_asr(sd_save->save_data, (u8*)mgr->workArea);
                    } else {
                        memcpy(mgr->workArea, sd_save->save_data, mCD_SD_SAVE_DATA_SIZE);
                    }

                    checksum = mFRm_ReturnCheckSum((u16*)mgr->workArea, mgr->workArea_size);
                    save = (Save_t*)mgr->workArea;
                    if (checksum == 0) {
                        if (mLd_CheckId(save->land_info.id) == TRUE) {
                            if (mLd_CheckThisLand(save->land_info.name, save->land_info.id) == FALSE) {
                                if (mCdsd_rent_code_chk(sd_save) == mCD_RESULT_SUCCESS) {
                                    fileInfo->proc++;
                                    bcopy(save, &l_keepSave, sizeof(Save));
                                    l_keepSave_set = TRUE;
                                    mCD_set_init_diary_data((mCD_keep_diary_c*)&l_keepDiary);
                                    memset(mgr->workArea, 0, l_aram_real_size_32_table[mCD_ARAM_DATA_DIARY]);
                                    if (sd_save->hdr.diary_compressed == 1) {
                                        decode_asr(sd_save->diary_data, (u8*)mgr->workArea);
                                    } else {
                                        memcpy(mgr->workArea, sd_save->diary_data,
                                               l_aram_real_size_32_table[mCD_ARAM_DATA_DIARY]);
                                    }

                                    if (mFRm_ReturnCheckSum((u16*)mgr->workArea,
                                                            l_aram_real_size_32_table[mCD_ARAM_DATA_DIARY]) == 0) {
                                        bcopy(mgr->workArea, &l_keepDiary,
                                              l_aram_real_size_32_table[mCD_ARAM_DATA_DIARY]);
                                        ret = mCD_RESULT_SUCCESS;
                                    } else {
                                        ret = mCD_RESULT_SD_SLOT;
                                        fileInfo->_04 = mCD_TRANS_ERR_CORRUPT;
                                    }
                                } else {
                                    ret = mCD_RESULT_SD_SLOT;
                                    fileInfo->_04 = 31;
                                }
                            } else {
                                ret = mCD_RESULT_SD_SLOT;
                                fileInfo->_04 = mCD_TRANS_ERR_NO_TOWN_DATA;
                            }
                        } else {
                            ret = mCD_RESULT_SD_SLOT;
                            fileInfo->_04 = mCD_TRANS_ERR_CORRUPT;
                        }
                    } else {
                        ret = mCD_RESULT_SD_SLOT;
                        fileInfo->_04 = mCD_TRANS_ERR_CORRUPT;
                    }
                } else {
                    ret = mCD_RESULT_SD_SLOT;
                    fileInfo->_04 = 41;
                }
            } else {
                ret = mCD_RESULT_SD_SLOT;
                fileInfo->_04 = 41;
            }
        } else {
            ret = mCD_RESULT_SD_SLOT;
            fileInfo->_04 = mCD_TRANS_ERR_NO_TOWN_DATA;
        }
    } else if (mCsd_thread_result_chk() != mCD_RESULT_ERROR) {
        if (mSdcardprobe_fg_chk() == 0) {
            ret = mCD_SD_CheckStation_check_this_land_sd(mgr, fileInfo);
            if (ret == mCD_RESULT_SUCCESS) {
                ret = mCD_SD_SaveStation_NextLand_get_next_land_data_common(mgr, fileInfo);
                fileInfo->proc = 4;
            }
        } else {
            fileInfo->_04 = mSdcardprobe_fg_chk();
            ret = mCD_RESULT_SD_SLOT;
        }
    }

    return ret;
}

#if VERSION == VER_GAEJ01_00
static int mCD_SD_SaveStation_NextLand_load_others(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    s32 chan = mgr->chan;

    mgr->chan = ~chan & 1;
    fileInfo->proc++;
    return mCD_RESULT_SUCCESS;
}
#else
static int mCD_SD_SaveStation_NextLand_load_others(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    s32 chan = mgr->chan;

    if (mCD_movingInfo_get() == 3) {
        mCD_SaveStation_NextLand_load_others(mgr, fileInfo);
    } else {
        mgr->chan = ~chan & 1;
        fileInfo->proc++;
    }
    return mCD_RESULT_SUCCESS;
}
#endif

static void mCDsd_set_SD_playcode(SDSave_t* sd_save, Save_t* save) {
    u16 playcode;
    int i;
    int found = FALSE;

    playcode = (u16)RANDOM_F(0xFFFF);
    if (playcode == sd_save->hdr._E || playcode == 0) {
        playcode++;
    }
    sd_save->hdr._E = playcode;

    for (i = 0; i < 8; i++) {
        if (save->sd_save_info._00003C[i] == sd_save->hdr.field_38) {
            found = TRUE;
            save->sd_save_info._00004C[i] = playcode;
            break;
        }
    }

    if (found == FALSE) {
        for (i = 7; i > 0; i--) {
            save->sd_save_info._00003C[i] = save->sd_save_info._00003C[i - 1];
            save->sd_save_info._00004C[i] = save->sd_save_info._00004C[i - 1];
        }
        save->sd_save_info._00003C[0] = sd_save->hdr.field_38;
        save->sd_save_info._00004C[i] = playcode; // @BUG - copy-paste error? Should be 0, not i
    }

    save->rnd_hash = (u64)RANDOM_F(-1.0f);
    save->save_check.checksum = mFRm_GetFlatCheckSum((u16*)save, mCD_SD_SAVE_DATA_SIZE, save->save_check.checksum);
}

static int mCD_SD_SaveStation_NextLand_write_main(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    SDSave_t* sd_save;
    int ret = mCD_RESULT_BUSY;
    u8* buf;
    u8* encode_buf;
    u32 encoded_size;
    u16 checksum;

    if (mCD_movingInfo_get() == 2) {
        ret = mCD_SaveStation_NextLand_write_main(mgr, fileInfo);
        if (ret == mCD_RESULT_SUCCESS) {
            fileInfo->proc = 11;
        }
    } else {
        if (mgr->_0014 != NULL) {
            sd_save = (SDSave_t*)mgr->_0014;
            if (mFRm_ReturnCheckSum((u16*)sd_save, mCD_SD_LAND_SAVE_SIZE) == 0) {
                buf = (u8*)mgr->workArea;
                mCDsd_set_SD_playcode(sd_save, &l_keepSave.save);
                encode_buf = (u8*)mCD_malloc_32(mCD_SD_ENCODE_BUF_SIZE);
                encoded_size = encode_asr(encode_buf, buf, mCD_SD_SAVE_DATA_SIZE);
                if (encoded_size <= mCD_SD_SAVE_DATA_SIZE) {
                    sd_save->hdr.save_compressed = 1;
                    memcpy(sd_save->save_data, encode_buf, mCD_SD_SAVE_DATA_SIZE);
                } else {
                    sd_save->hdr.save_compressed = 0;
                    memcpy(sd_save->save_data, buf, mCD_SD_SAVE_DATA_SIZE);
                }
                zelda_free(encode_buf);

                checksum = mFRm_GetFlatCheckSum((u16*)sd_save, mCD_SD_LAND_SAVE_SIZE, sd_save->hdr.checksum);
                sd_save->hdr.checksum = checksum;
                memcpy(mgr->workArea, sd_save, mCD_SD_LAND_SAVE_SIZE);
                ret = mCD_RESULT_SUCCESS;
            } else {
                ret = mCD_RESULT_SD_SLOT;
                fileInfo->_04 = mCD_TRANS_ERR_CORRUPT;
            }
        } else {
            ret = mCD_RESULT_SD_SLOT;
            fileInfo->_04 = 41;
        }

        if (ret == mCD_RESULT_SUCCESS) {
            mCsd_set_mura_filename_tmp_set();
            mgr->save_home_info._20 = 1;
            mCsd_mura_write_start();
            fileInfo->proc++;
        }
    }

    return ret;
}

static int mCD_SD_SaveStation_NextLand_write_wait(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int ret = mCD_RESULT_BUSY;

    if (mCsd_thread_result_chk() != mCD_RESULT_ERROR) {
        if (mSdcardprobe_fg_chk() == 0) {
            if (mgr->_0014 != NULL) {
                memcpy(mgr->_0014, mgr->workArea, mCD_SD_LAND_SAVE_SIZE);
            }
            fileInfo->proc++;
            ret = mCD_RESULT_SUCCESS;
            bcopy(&l_keepSave, mgr->workArea, mCD_SD_SAVE_DATA_SIZE);
            mgr->loaded_file_type = mCD_FILE_SAVE_MAIN;
            mgr->workArea_size = mCD_get_size(mgr->loaded_file_type);
            mgr->chan = ~mgr->chan & 1;
        } else if (mSdcardprobe_fg_chk() == 0x24) {
            mCsd_set_mura_filename_dbm_set();
            mCsd_mura_write_start();
        } else if (mSdcardprobe_fg_chk() == 0x2E) {
            mCsd_mura_write_start();
        } else {
            mCsd_set_mura_filename_dbm_set();
            fileInfo->_04 = mSdcardprobe_fg_chk();
            ret = mCD_RESULT_SD_SLOT;
        }
    }

    return ret;
}

static int mCD_SD_SaveStation_NextLand_sd_write_end(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    fileInfo->proc = 14;
    return mCD_RESULT_SUCCESS;
}

extern int mCD_SD_SaveStation_NextLand_bg(mCD_sd_card_info_c* sd_info) {
    // clang-format off
    static mCD_SAVEHOME_PROC save_proc[] = {
        mCD_SD_SaveStation_NextLand_get_area,
        mCD_SD_SaveStation_NextLand_check_repair_land,
        mCD_SaveStatoin_NextLand_repair_land,
        mCD_SD_SaveStation_NextLand_get_next_land_data,
        mCD_SD_SaveStation_NextLand_load_others,
        mCD_SaveStation_NextLand_set_data,
        mCD_SD_SaveStation_NextLand_write_main,
        mCD_SD_SaveStation_NextLand_write_wait,
        mCD_SaveStation_NextLand_write_main,
        mCD_SaveStation_NextLand_write_bk,
        mCD_SD_SaveStation_NextLand_sd_write_end,
        mCD_SaveStation_NextLand_write_bk,
        mCD_SaveHome_bg_set_others,
        mCD_SaveStation_NextLand_write_others,
    };
    // clang-format on

    mCD_memMgr_c* mgr = &l_memMgr;
    mCD_memMgr_fileInfo_c* fileInfo = &mgr->save_home_info;
    u8 proc;
    int ret = mCD_SD_BG_BUSY;
    int res;

    proc = (u8)fileInfo->proc;
    sd_info->exist = FALSE;
    mgr->_0188++;
    if (mgr->_018C == 0) {
        if (proc < 14) {
            res = (*save_proc[proc])(mgr, fileInfo);
            if (res == mCD_RESULT_SUCCESS) {
                if (fileInfo->proc == 14) {
                    sd_info->chan = mgr->chan;
                    ret = mCD_TRANS_ERR_NONE;
                }
            } else if (res != mCD_RESULT_BUSY) {
                ret = fileInfo->_04;
                sd_info->chan = mgr->chan;
                if (res == mCD_RESULT_SD_SLOT) {
                    sd_info->chan = mCsd_nowdrive_get();
                    sd_info->exist = TRUE;
                }

                if (ret == mCD_TRANS_ERR_NONE) {
                    ret = mCD_TRANS_ERR_IOERROR;
                }

                if (mgr->_0198 == 1 && Now_Private != NULL) {
                    Now_Private->exists = TRUE;
                    mCD_ReplaceKeep(Now_Private, &mgr->private_item);
                }

                if (mgr->copy_protect != -1 && fileInfo->proc <= 7) {
                    Common_Set(copy_protect, (u16)mgr->copy_protect);
                }

                mCD_ClearKeepLand();
            }

            if (res <= -1 || (res == mCD_RESULT_SUCCESS && fileInfo->proc == 14)) {
                if (mgr->_0188 >= 112) {
                    sAdo_SysLevStop(NA_SE_47);
                    mCD_ClearMemMgr_com2(mgr);
                    if (res == mCD_RESULT_SUCCESS && mLd_PlayerManKindCheck() == FALSE) {
                        mCD_create_famicom_file(mgr->chan);
                    }
                } else {
                    mgr->_018C = 1;
                    mgr->_01D4 = sd_info->exist;
                    mgr->_0190 = ret;
                    mgr->_0194 = sd_info->chan;
                    ret = mCD_SD_BG_BUSY;
                    if (mgr->_0190 == mCD_SD_BG_BUSY) {
                        mgr->_0190 = mCD_TRANS_ERR_NOCARD;
                    }
                }
            }
        } else {
            ret = mCD_TRANS_ERR_NONE;
            mCD_ClearMemMgr_com2(mgr);
        }
    } else if (mgr->_0188 >= 112) {
        sd_info->exist = mgr->_01D4;
        ret = mgr->_0190;
        sd_info->chan = mgr->_0194;
        mCD_ClearMemMgr_com2(mgr);
        if (ret == mCD_TRANS_ERR_NONE && mLd_PlayerManKindCheck() == FALSE) {
            mCD_create_famicom_file(sd_info->chan);
        }
        sAdo_SysLevStop(NA_SE_47);
    }

    if (ret != mCD_SD_BG_BUSY) {
        SoftResetEnable = TRUE;
    }

    if (ret != mCD_SD_BG_BUSY && ret != mCD_TRANS_ERR_NONE && proc >= 5) {
        mNpc_ClearJustRemoveAnimal();
    }

    return ret;
}

static int mCD_SD_InitGameStart_bg_get_area(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    static int sound_mode[] = { 2, 0, 0, 0, 0, 0 };

    int soundm = 2;
    int ret;

    if (fileInfo->chan >= 0 && fileInfo->chan < 6) {
        soundm = sound_mode[fileInfo->chan];
    }

    fileInfo->_10 = soundm;
    SoftResetEnable = FALSE;
    ret = mCD_bg_get_area_common(mgr, fileInfo, mCD_FILE_SD_LAND, soundm);
    if (ret == mCD_RESULT_SUCCESS) {
        mgr->_0014 = mCD_malloc_32(mCD_SD_LAND_SAVE_SIZE);
        bzero(mgr->_0014, mCD_SD_LAND_SAVE_SIZE);
        if (mCD_movingInfo_get() == 2) {
            int chan = mCsd_sdcard_slot_chk();
            if (chan >= 0) {
                mCsd_nowdrive_set(chan);
                mgr->_0004 = chan;
                mCsd_mura_read_start();
            } else {
                mgr->chan = mCsd_nowdrive_get();
                ret = mCD_RESULT_SD_SLOT;
                mgr->cards[mgr->chan].game_result = mCD_TRANS_ERR_NOCARD;
            }
        }
    }

    return ret;
}

static int mCD_SD_InitGameStart_bg_get_slot(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int ret = mCD_RESULT_BUSY;

    if (mCD_movingInfo_get() == 2) {
        if (mCsd_thread_result_chk() != mCD_RESULT_ERROR) {
            if (mSdcardprobe_fg_chk() == 0) {
                if (mgr->cards[0].workArea != NULL && mgr->cards[1].workArea != NULL && mgr->workArea != NULL) {
                    int slot = mCD_SD_get_this_land_slot_no_game_start(mgr);
                    if (slot == mCD_RESULT_SUCCESS) {
                        Save_t* save = (Save_t*)mgr->workArea;

                        if (save->copy_protect == Common_Get(copy_protect)) {
                            ret = mCD_RESULT_SUCCESS;
                            fileInfo->proc = 4;
                        } else {
                            ret = mCD_RESULT_SD_SLOT;
                            mgr->cards[mgr->chan].game_result = mCD_TRANS_ERR_WRONG_LAND;
                        }
                    } else {
                        ret = mCD_RESULT_SD_SLOT;
                    }
                } else {
                    ret = mCD_RESULT_SD_SLOT;
                }
            } else {
                mgr->chan = mgr->_0004;
                mgr->cards[mgr->_0004].game_result = mSdcardprobe_fg_chk();
                ret = mCD_RESULT_SD_SLOT;
            }
        }
    } else {
        ret = mCD_InitGameStart_bg_get_slot(mgr, fileInfo);
        if (mgr->cards[mgr->chan].game_result == 41) {
            mgr->cards[mgr->chan].game_result = mCD_TRANS_ERR_NOCARD;
        }
    }

    return ret;
}

static int mCD_SD_InitGameStart_bg_check_repair_land(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    mCD_InitGameStart_bg_check_repair_land(mgr, fileInfo);
    if (fileInfo->proc == 4) {
        fileInfo->proc = 4;
    }

    return mCD_RESULT_SUCCESS;
}

static int mCD_SD_InitGameStart_bg_make_data(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    GAME* game = gamePT;
    int player_no = fileInfo->_04;
    int start_cond = fileInfo->chan;
    Private_c* priv;
    InAnimal_c* in_animal = mNpc_GetInAnimalP();
    u16 copy_protect;

    if (start_cond >= 6) {
        start_cond = 0;
        fileInfo->chan = 0;
    }

    priv = mPr_GetForeignerP();
    mPr_CopyPrivateInfo(priv, &l_mcd_foreigner_file.file.priv);
    if (in_animal != NULL) {
        bcopy(&l_mcd_foreigner_file.file.remove_animal, &in_animal->animal, sizeof(Animal_c));
        bcopy(l_mcd_foreigner_file.file.compress_data, in_animal->compress_data,
              sizeof(l_mcd_foreigner_file.file.compress_data));
    }
    mPr_LoadPak_and_SetPrivateInfo2(priv, player_no);

    {
        static int init_mode_table[] = { 0, 2, 1, 3, 3, 3 };

        mSDI_StartDataInit(game, player_no, init_mode_table[start_cond]);
    }

    l_mcd_keep_startCond = start_cond;
    mgr->copy_protect = Common_Get(copy_protect);
    priv = Now_Private;
    if (mLd_PlayerManKindCheckNo((u8)player_no) == NATIVE) {
        priv = Now_Private;
        if (priv != NULL) {
            mCD_SetResetInfo(priv);
            mCD_SetResetCode(priv);
            mRmTp_SetDefaultLightSwitchData(3);
        }

        if (start_cond == 3) {
            fileInfo->_14 = 1;
        } else {
            fileInfo->_14 = 0;
        }
    } else {
        priv = mCD_GetSaveFilePrivateP();
        if (priv != NULL) {
            mCD_SetResetInfo(priv);
            mCD_SetResetCode(priv);
        }

        priv = Now_Private;
        if (priv != NULL) {
            mCD_SetResetInfo(priv);
            mCD_SetResetCode(priv);
        }

        mCD_SetCopyProtect(&l_mcd_foreigner_file.file);
        if (start_cond == 3) {
            fileInfo->_14 = 2;
        } else {
            fileInfo->_14 = 0;
        }
    }

    Save_Set(travel_hard_time, lbRTC_HardTime());
    if (mCD_castingoff_mura_chk() != TRUE) {
        Save_Set(nukegara_time, lbRTC_HardTime());
    }

    copy_protect = mCD_get_land_copyProtect();
    Save_Set(copy_protect, copy_protect);
    Common_Set(copy_protect, copy_protect);
    fileInfo->proc++;
    return mCD_RESULT_SUCCESS;
}

static int mCD_SD_InitGameStart_bg_set_data(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    Save_t* save = (Save_t*)mgr->workArea;

    if (save != NULL) {
        mgr->loaded_file_type = mCD_FILE_SAVE_MAIN;
        mgr->workArea_size = mCD_get_size(mgr->loaded_file_type);
        bzero(save, mgr->workArea_size);
        bcopy(Common_GetPointer(save), save, sizeof(Save_t));
        save->save_check.version = mFRm_VERSION;
        mFRm_SetSaveCheckData(&save->save_check);
        save->rnd_hash = (u64)RANDOM_F(-1.0f);
        save->save_check.checksum = mFRm_GetFlatCheckSum((u16*)save, mCD_SD_SAVE_DATA_SIZE, save->save_check.checksum);
        bcopy(save, &l_keepSave, mCD_SD_SAVE_DATA_SIZE);
        fileInfo->proc++;
        return mCD_RESULT_SUCCESS;
    }

    return mCD_RESULT_ERROR;
}

static int mCD_SD_InitGameStart_bg_write_main(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int ret;
    SDSave_t* sd_save;
    u8* encode_buf;
    u32 encoded_size;
    u16 checksum;
    mCD_memMgr_card_info_c* card;
    u8* buf;

    if (mCD_movingInfo_get() == 3) {
        ret = mCD_InitGameStart_bg_write_main(mgr, fileInfo);
        if (ret == mCD_RESULT_SUCCESS) {
            mgr->loaded_file_type = mCD_FILE_SAVE_MAIN_BAK;
            mgr->workArea_size = mCD_get_size(mgr->loaded_file_type);
            fileInfo->proc = 8;
        }
    } else if (mgr->_0014 != NULL) {
        memcpy(mgr->workArea, mgr->_0014, mCD_SD_LAND_SAVE_SIZE);
        sd_save = (SDSave_t*)mgr->workArea;
        checksum = mFRm_ReturnCheckSum((u16*)sd_save, mCD_SD_LAND_SAVE_SIZE);
        if (checksum == 0) {
            buf = (u8*)&l_keepSave;
            encode_buf = (u8*)mCD_malloc_32(mCD_SD_ENCODE_BUF_SIZE);
            encoded_size = encode_asr(encode_buf, buf, mCD_SD_SAVE_DATA_SIZE);
            if (encoded_size <= mCD_SD_SAVE_DATA_SIZE) {
                sd_save->hdr.save_compressed = 1;
                memcpy(sd_save->save_data, encode_buf, mCD_SD_SAVE_DATA_SIZE);
            } else {
                sd_save->hdr.save_compressed = 0;
                memcpy(sd_save->save_data, buf, mCD_SD_SAVE_DATA_SIZE);
            }

            checksum = mFRm_GetFlatCheckSum((u16*)sd_save, mCD_SD_LAND_SAVE_SIZE, sd_save->hdr.checksum);
            sd_save->hdr.checksum = checksum;
            ret = mCD_RESULT_SUCCESS;
            zelda_free(encode_buf);
            mCsd_set_mura_filename_tmp_set();
            mgr->save_home_info._20 = 1;
            mCsd_mura_write_start();
            fileInfo->proc++;
        } else {
            mgr->chan = mCsd_nowdrive_get();
            ret = mCD_RESULT_SD_SLOT;
            card = &mgr->cards[mgr->chan];
            card->game_result = 41;
        }
    } else {
        mgr->chan = mCsd_nowdrive_get();
        ret = mCD_RESULT_SD_SLOT;
        card = &mgr->cards[mgr->chan];
        card->game_result = 41;
    }

    return ret;
}

static int mCD_SD_InitGameStart_sd_write_wait(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    Private_c* priv = Now_Private;
    mCD_memMgr_card_info_c* card;
    int ret = mCD_RESULT_BUSY;

    if (mCsd_thread_result_chk() != mCD_RESULT_ERROR) {
        if (mSdcardprobe_fg_chk() == 0) {
            if (mgr->_0014 != NULL) {
                memcpy(mgr->_0014, mgr->workArea, mCD_SD_LAND_SAVE_SIZE);
            }

            if (Common_Get(player_decoy_flag) == TRUE && priv != NULL && !mPr_NullCheckPersonalID(&priv->player_ID)) {
                priv->exists = TRUE;
                priv->equipment = EMPTY_NO;
            }

            ret = mCD_RESULT_SUCCESS;
            fileInfo->proc = 9;
        } else {
            int probe_result = mSdcardprobe_fg_chk();

            if (probe_result == 0x24) {
                mCsd_set_mura_filename_dbm_set();
                mCsd_mura_write_start();
            } else if (probe_result == 0x2E) {
                mCsd_mura_write_start();
            } else {
                mCsd_set_mura_filename_dbm_set();
                mgr->chan = mCsd_nowdrive_get();
                ret = mCD_RESULT_SD_SLOT;
                card = &mgr->cards[mgr->chan];
                card->game_result = probe_result;
            }
        }
    }

    return ret;
}

extern int mCD_SD_InitGameStart_bg(int player_no, s32 card_private_idx, s32 start_cond, s32* mounted_chan,
                                   int* sd_exists) {
    // clang-format off
    static mCD_SAVEHOME_PROC start_proc[] = {
        mCD_SD_InitGameStart_bg_get_area,
        mCD_SD_InitGameStart_bg_get_slot,
        mCD_SD_InitGameStart_bg_check_repair_land,
        mCD_SaveHome_bg_repair_land,
        mCD_SD_InitGameStart_bg_make_data,
        mCD_SD_InitGameStart_bg_set_data,
        mCD_SD_InitGameStart_bg_write_main,
        mCD_SD_InitGameStart_sd_write_wait,
        mCD_InitGameStart_bg_write_bk,
    };
    // clang-format on

    mCD_memMgr_c* mgr = &l_memMgr;
    mCD_memMgr_fileInfo_c* fileInfo = &mgr->init_game_start_info;
    mCD_memMgr_card_info_c* card;
    u8 proc = (u8)fileInfo->proc;
    int res;
    int ret = mCD_SD_BG_BUSY;
    Private_c* priv = Now_Private;

    mgr->_0188++;
    if (mgr->_018C == 0) {
        if (proc < 9) {
            fileInfo->_04 = player_no;
            fileInfo->fileNo = card_private_idx;
            fileInfo->chan = start_cond;
            res = (*start_proc[proc])(mgr, fileInfo);
            if (res == mCD_RESULT_SUCCESS) {
                if (fileInfo->proc == 9) {
                    ret = mCD_TRANS_ERR_NONE;
                    *mounted_chan = mgr->chan;
                }
            } else if (res != mCD_RESULT_BUSY) {
                if (priv != NULL) {
                    priv->reset_code = 0;
                }

                priv = mCD_GetSaveFilePrivateP();
                if (priv != NULL) {
                    priv->reset_code = 0;
                }

                if (res == mCD_RESULT_SD_SLOT) {
                    *sd_exists = TRUE;
                } else {
                    *sd_exists = FALSE;
                }

                mgr->_01D4 = *sd_exists;
                if (mgr->_01A0 == 1) {
                    ret = mCD_TRANS_ERR_NONE;
                    *mounted_chan = mgr->chan;
                    mgr->copy_protect = -1;
                } else if (mgr->chan == mCD_SLOT_A || mgr->chan == mCD_SLOT_B) {
                    *mounted_chan = mgr->chan;
                    card = &mgr->cards[mgr->chan];
                    ret = card->game_result;
                    if (ret == mCD_TRANS_ERR_NONE) {
                        ret = mCD_TRANS_ERR_IOERROR;
                    }

                    bzero(Common_Get(npclist), sizeof(Common_Get(npclist)));
                    bzero(Common_Get(island_npclist), sizeof(Common_Get(island_npclist)));
                    bzero(Common_Get(npc_schedule), sizeof(Common_Get(npc_schedule)));
                } else {
                    mgr->chan = mCD_SLOT_A;
                    ret = mCD_TRANS_ERR_IOERROR;
                    bzero(Common_Get(npclist), sizeof(Common_Get(npclist)));
                    bzero(Common_Get(island_npclist), sizeof(Common_Get(island_npclist)));
                    bzero(Common_Get(npc_schedule), sizeof(Common_Get(npc_schedule)));
                }

                if (mgr->copy_protect != -1 && fileInfo->proc <= 7) {
                    Common_Set(copy_protect, mgr->copy_protect);
                }
            }

            if (res <= -1 || (res == mCD_RESULT_SUCCESS && fileInfo->proc == 9)) {
                if (fileInfo->_10 == 2) {
                    mCD_ClearMemMgr_com2(mgr);
                    mCD_load_famicom_file();
                } else if (mgr->_0188 >= 112) {
                    sAdo_SysLevStop(NA_SE_47);
                    mCD_ClearMemMgr_com2(mgr);
                    if (res == mCD_RESULT_SUCCESS) {
                        mCD_load_famicom_file();
                    }
                } else {
                    if (ret == 41) {
                        ret = mCD_TRANS_ERR_IOERROR;
                    }

                    mgr->_0190 = ret;
                    ret = mCD_SD_BG_BUSY;
                    mgr->_018C = 1;
                    mgr->_0194 = *mounted_chan;
                    if (mgr->_0190 == mCD_SD_BG_BUSY) {
                        mgr->_0190 = mCD_TRANS_ERR_NOCARD;
                    }
                }
            }
        } else {
            ret = mCD_TRANS_ERR_NONE;
            mCD_ClearMemMgr_com2(mgr);
        }
    } else if (mgr->_0188 >= 112) {
        *sd_exists = mgr->_01D4;
        ret = mgr->_0190;
        *mounted_chan = mgr->_0194;
        sAdo_SysLevStop(NA_SE_47);
        mCD_ClearMemMgr_com2(mgr);
        if (ret == mCD_TRANS_ERR_NONE) {
            mCD_load_famicom_file();
        }
    }

    ret = mCD_GameStart_ChangeErrCode(ret);
    if (ret != mCD_SD_BG_BUSY) {
        SoftResetEnable = TRUE;
    }

    return ret;
}

extern void mCD_movingInfo_set(void) {
    int movingInfo;

    if (Common_Get(player_no) == mPr_FOREIGNER) {
        if (S_movingInfo <= 1) {
            S_movingInfo = 1;
        } else {
            S_movingInfo = 3;
        }
    } else {
        if (mCsd_sdcard_slot_chk() < 0) {
            if (Common_Get(player_no) != mPr_FOREIGNER) {
                movingInfo = 0;
            } else {
                movingInfo = 1;
            }
        } else {
            if (Common_Get(player_no) != mPr_FOREIGNER) {
                movingInfo = 2;
            } else {
                movingInfo = 3;
            }
        }

        S_movingInfo = movingInfo;
    }
}

extern int mCD_movingInfo_get(void) {
    return S_movingInfo;
}

static int mCD_SD_CheckReten_Load_Nukegara_check(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    mCD_memMgr_card_info_c* card = mgr->cards;
    Save_t* save = (Save_t*)mgr->workArea;
    int found = FALSE;
    int ret = mCD_RESULT_ERROR;
    int chan;

    for (chan = 0; chan < CARD_NUM_CHANS; chan++) {
        mgr->cards[chan].result = CARD_RESULT_NOCARD;
        mgr->cards[mCD_SLOT_B].game_result = mCD_TRANS_ERR_NOCARD;
    }

    for (chan = 0; chan < CARD_NUM_CHANS; chan++, card++) {
        int type;

        mgr->chan = chan;
        for (type = 0; type < 2; type++) {
            mgr->loaded_file_type = mCD_FILE_SAVE_MAIN + type;
            mgr->workArea_size = mCD_get_size(mgr->loaded_file_type);
            bzero(save, mgr->workArea_size);
            if (mCD_load_file(save, mgr->loaded_file_type, chan, &card->result) == mCD_RESULT_SUCCESS) {
                if (mFRm_CheckSaveData_common(&save->save_check, Save_Get(land_info).id)) {
                    if (mFRm_ReturnCheckSum((u16*)save, mgr->workArea_size) == 0 &&
                        (save->save_check.version == mFRm_VERSION || save->save_check.version == 5)) {
                        if (save->_000190[0] == 1) {
                            mgr->chan = chan;
                            memcpy(&l_keepSave, save, mCD_SD_SAVE_DATA_SIZE);
                            S_CheckReten_next_cnt = 0;
                            ret = mCD_RESULT_SUCCESS;
                            found = TRUE;
                            fileInfo->proc++;
                        } else {
                            found = TRUE;
                            mgr->cards[mCD_SLOT_B].game_result = mCD_TRANS_ERR_NOCARD;
                        }
                        break;
                    }
                    card->game_result = mCD_TRANS_ERR_IOERROR;
                }
            } else {
                card->game_result = mCD_TransErrorCode_nes(card->result);
            }
        }

        if (found == TRUE) {
            break;
        }
    }

    if (ret != mCD_RESULT_SUCCESS) {
        if (mgr->cards[mCD_SLOT_A].game_result == mCD_TRANS_ERR_NONE ||
            mgr->cards[mCD_SLOT_B].game_result == mCD_TRANS_ERR_NONE) {
            fileInfo->_04 = mCD_TRANS_ERR_NOCARD;
        } else {
            mCD_GetHighPriority_common(mgr, mgr->cards[mCD_SLOT_A].game_result, mgr->cards[mCD_SLOT_B].game_result);
            fileInfo->_04 = mgr->cards[mgr->chan].game_result;
            if (fileInfo->_04 == 41 || fileInfo->_04 == mCD_TRANS_ERR_WRONGDEVICE) {
                fileInfo->_04 = mCD_TRANS_ERR_NOCARD;
            }
        }
    }

    return ret;
}

static int mCD_SD_CheckReten_sdcard_next_data_setup(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    u8 filename[10];
    int ret = mCD_RESULT_BUSY;
    int res;

    memset(filename, 0, sizeof(filename));
    res = mSD_mura_nextname_get(filename, &S_CheckReten_next_cnt);
    if (res == 0) {
        mCsd_set_mura_filename(filename);
        ret = mCD_RESULT_SUCCESS;
        fileInfo->proc++;
    } else if (res == 0x2C) {
        if (fileInfo->_04 != 0x1B && fileInfo->_04 != 0x2F && fileInfo->_04 != 0x31 && fileInfo->_04 != 0x1C) {
            fileInfo->_04 = 0x1D;
        }
        ret = mCD_RESULT_SD_SLOT;
    } else if (res != mCD_SD_BG_BUSY) {
        if (res == 41) {
            res = mCD_SD_PROBE_NO_SD;
        }
        fileInfo->_04 = res;
        ret = mCD_RESULT_SD_SLOT;
    }

    return ret;
}

static int mCD_SD_CheckReten_sdcard_check(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    SDSave_t* sd_save;
    Save_t* save;
    int ret;

    save = &l_keepSave.save;
    if (mgr->_0014 != NULL) {
        memcpy(mgr->workArea, mgr->_0014, mCD_SD_LAND_SAVE_SIZE);
        sd_save = (SDSave_t*)mgr->workArea;
        if (mFRm_ReturnCheckSum(&sd_save->hdr.checksum, mCD_SD_LAND_SAVE_SIZE) == 0) {
            if (mLd_CheckThisLand(sd_save->hdr.land_info.name, sd_save->hdr.land_info.id) == TRUE) {
                if (sd_save->hdr.field_38 == save->sd_save_info._000038) {
                    if (sd_save->hdr._E != 0) {
                        ret = mCD_RESULT_SUCCESS;
                        fileInfo->_04 = mCD_TRANS_ERR_NONE;
                        fileInfo->proc++;
                    } else {
                        ret = mCD_RESULT_SD_SLOT;
                        fileInfo->_04 = 0x1B;
                    }
                } else {
                    if (fileInfo->_04 != 0x1B) {
                        fileInfo->_04 = 0x2F;
                    }
                    ret = mCD_RESULT_BUSY;
                    fileInfo->proc = 2;
                }
            } else {
                if (fileInfo->_04 != 0x1B && fileInfo->_04 != 0x2F && fileInfo->_04 != 0x31) {
                    fileInfo->_04 = 0x1C;
                }
                ret = mCD_RESULT_BUSY;
                fileInfo->proc = 2;
            }
        } else {
            if (mCsd_mura_filename_equal_cgeck(save->sd_eng_name) == TRUE) {
                if (fileInfo->_04 != 0x1B && fileInfo->_04 != 0x2F) {
                    fileInfo->_04 = 0x31;
                }
            } else if (fileInfo->_04 != 0x1B && fileInfo->_04 != 0x2F && fileInfo->_04 != 0x31 &&
                       fileInfo->_04 != 0x1C) {
                fileInfo->_04 = 41;
            }
            ret = mCD_RESULT_BUSY;
            fileInfo->proc = 2;
        }
    } else {
        if (fileInfo->_04 != 0x1B && fileInfo->_04 != 0x2F && fileInfo->_04 != 0x31 && fileInfo->_04 != 0x1C) {
            fileInfo->_04 = 41;
        }
        ret = mCD_RESULT_BUSY;
        fileInfo->proc = 2;
    }

    return ret;
}

static int mCD_SD_CheckReten_sdcard_check_for_proc(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int ret;

    ret = mCD_SD_CheckReten_sdcard_check(mgr, fileInfo);
    if (ret == mCD_RESULT_SD_SLOT && fileInfo->_04 == 0x1B && fileInfo->_28 == 0) {
        ret = mCD_RESULT_SUCCESS;
        fileInfo->_04 = mCD_TRANS_ERR_NONE;
        fileInfo->proc++;
    }

    if (ret == mCD_RESULT_BUSY && fileInfo->proc == 2) {
        fileInfo->proc = 2;
    }

    return ret;
}

static int mCD_SD_CheckReten_sdcard_mura_read(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int chan;
    int ret;

    chan = mCsd_sdcard_slot_chk();
    if (chan >= 0) {
        mCsd_nowdrive_set(chan);
        mgr->_0004 = chan;
        mCsd_mura_read_start();
        ret = mCD_RESULT_SUCCESS;
        fileInfo->proc++;
    } else {
        ret = mCD_RESULT_SD_SLOT;
        fileInfo->_04 = mCD_TRANS_ERR_NOCARD;
    }

    return ret;
}

static int mCD_SD_CheckReten_sdcard_mura_read_wait(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int ret = mCD_RESULT_BUSY;

    if (mCsd_thread_result_chk() != mCD_RESULT_ERROR) {
        if (mSdcardprobe_fg_chk() == 0) {
            ret = mCD_RESULT_SUCCESS;
            fileInfo->proc++;
        } else {
            if (fileInfo->_04 != 0x1B && fileInfo->_04 != 0x2F && fileInfo->_04 != 0x31 && fileInfo->_04 != 0x1C) {
                fileInfo->_04 = mSdcardprobe_fg_chk();
            }
            ret = mCD_RESULT_BUSY;
            fileInfo->proc = 2;
        }
    }

    return ret;
}

extern int mCD_SD_CheckReten_SDmura(mCD_sd_card_info_c* sd_info) {
    // clang-format off
    static mCD_CHECKSTATION_PROC check_proc[] = {
        mCD_SD_CheckReten_get_area,
        mCD_SD_CheckReten_Load_Nukegara_check,
        mCD_SD_CheckReten_sdcard_next_data_setup,
        mCD_SD_CheckReten_sdcard_mura_read,
        mCD_SD_CheckReten_sdcard_mura_read_wait,
        mCD_SD_CheckReten_sdcard_check,
    };
    // clang-format on

    mCD_memMgr_c* mgr = &l_memMgr;
    mCD_memMgr_fileInfo_c* fileInfo = &mgr->init_game_start_info;
    u8 proc = (u8)fileInfo->proc;
    int res;
    s32 chan;
    int ret = mCD_SD_BG_BUSY;

    sd_info->exist = FALSE;
    if (proc < 6) {
        res = (*check_proc[proc])(mgr, fileInfo);
        if (res == mCD_RESULT_SUCCESS) {
            if (fileInfo->proc == 6) {
                sd_info->chan = mgr->chan;
                ret = fileInfo->_04;
                mCD_ClearMemMgr_com2(mgr);
            }
        } else if (res != mCD_RESULT_BUSY) {
            sd_info->chan = mgr->chan;
            if (res == mCD_RESULT_SD_SLOT) {
                chan = mCsd_nowdrive_get();
                sd_info->chan = chan;
                sd_info->exist = TRUE;
            }
            ret = fileInfo->_04;
            mCD_ClearMemMgr_com2(mgr);
        }
    } else {
        ret = mCD_TRANS_ERR_NOCARD;
        sd_info->chan = mgr->chan;
        mCD_ClearMemMgr_com2(mgr);
    }

    if (ret != mCD_TRANS_ERR_BUSY) {
        SoftResetEnable = TRUE;
    }

    if (ret != mCD_TRANS_ERR_BUSY && ret != mCD_TRANS_ERR_NONE && proc == 1) {
        ret = mCD_TRANS_ERR_NOCARD;
    }

    return ret;
}

static int mCD_SD_repayment_data_set(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    SDSave_t* sd_save = (SDSave_t*)mgr->workArea;
    Save_t* save;
    Save_t* keep_save;
    u8* buf;
    u16 checksum;

    keep_save = &l_keepSave.save;
    buf = (u8*)mCD_malloc_32(mCD_SD_LAND_SAVE_SIZE);
    if (sd_save->hdr.save_compressed == 1) {
        decode_asr(sd_save->save_data, buf);
    } else {
        memcpy(buf, sd_save->save_data, mCD_SD_SAVE_DATA_SIZE);
    }

    bzero(mgr->workArea, mgr->workArea_size);
    save = (Save_t*)mgr->workArea;
    memcpy(save, buf, mgr->workArea_size);
    memcpy(save->private_data, keep_save->private_data, sizeof(save->private_data));
    mFRm_mergeAnimal(save, keep_save, save->sd_anm_ids);
    save->sd_save_info._000038 = 0;
    save->_000190[0] = 0;
    save->rnd_hash = (u64)RANDOM_F(-1.0f);
    checksum = mFRm_GetFlatCheckSum((u16*)save, mCD_SD_SAVE_DATA_SIZE, save->save_check.checksum);
    save->save_check.checksum = checksum;
    mgr->loaded_file_type = mCD_FILE_SAVE_MAIN;
    mgr->workArea_size = mCD_get_size(mgr->loaded_file_type);
    zelda_free(buf);
    fileInfo->proc++;
    return mCD_RESULT_SUCCESS;
}

static int mCD_SD_repayment_data_write(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int ret;
    mCD_memMgr_card_info_c* card;
    int result;

    ret = mCD_write_common(mgr);
    if (ret != mCD_RESULT_BUSY) {
        if (ret == mCD_RESULT_SUCCESS) {
            mgr->loaded_file_type = mCD_FILE_SAVE_MAIN_BAK;
            mgr->workArea_size = mCD_get_size(mgr->loaded_file_type);
            fileInfo->proc++;
        } else if (mgr->chan != -1) {
            card = &mgr->cards[mgr->chan];
            result = card->result;
            switch (result) {
                case CARD_RESULT_BROKEN:
                case CARD_RESULT_ENCODING:
                    fileInfo->_04 = mCD_TRANS_ERR_BROKEN_WRONGENCODING;
                    break;
                case CARD_RESULT_WRONGDEVICE:
                case CARD_RESULT_NOCARD:
                    fileInfo->_04 = mCD_TRANS_ERR_NOCARD;
                    break;
                default:
                    fileInfo->_04 = mCD_TRANS_ERR_IOERROR;
                    break;
            }
        } else {
            fileInfo->_04 = mCD_TRANS_ERR_IOERROR;
        }
    }

    return ret;
}

static int mCD_SD_repayment_data_write_bk(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int ret;

    ret = mCD_write_common(mgr);
    if (ret != mCD_RESULT_BUSY) {
        fileInfo->proc++;
        ret = mCD_RESULT_SUCCESS;
    }

    return ret;
}

static int mCD_SD_repayment_remove_sd(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    if (mSD_mura_repayment_remove() == 0) {
        fileInfo->_04 = mCD_TRANS_ERR_NONE;
        fileInfo->proc++;
        return mCD_RESULT_SUCCESS;
    } else {
        fileInfo->_04 = mCD_TRANS_ERR_NONE;
        fileInfo->proc++;
        return mCD_RESULT_SUCCESS;
    }
}

