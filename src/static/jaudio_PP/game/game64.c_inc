void Sou_SpecialRoutine11() {
    u8 i = 0;
    u8 se_id = 0;

    if (sou_scene_mode == 2 || sou_scene_mode == 14 || sou_scene_mode == 15 || sou_scene_mode == 16) {

        for (i = 0; i < 2; i++) {
