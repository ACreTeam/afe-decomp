static void aNPC2_set_nukegara_time(void) {
    lbRTC_time_c time;
    u8 str[mMsg_FREE_STRING_LEN];
    int len;

    lbRTC_GetNukegaraTime(&time);

    // year
    len = mFont_UnintToString(str, 4, time.year, 4, TRUE, FALSE, FALSE);
    mMsg_SET_FREE_STR(mMsg_FREE_STR5, str, len);

    // month
    len = mFont_UnintToString(str, 2, time.month, 2, TRUE, FALSE, FALSE);
    mMsg_SET_FREE_STR(mMsg_FREE_STR6, str, len);

    // day
    len = mFont_UnintToString(str, 2, time.day, 2, TRUE, FALSE, FALSE);
    mMsg_SET_FREE_STR(mMsg_FREE_STR7, str, len);
}

static void aNPS2_set_free_str(int str_no, int free_str_no) {
    u8 str[mString_DEFAULT_STR_SIZE];
    mString_Load_StringFromRom(str, mString_DEFAULT_STR_SIZE, str_no);
    mMsg_Set_free_str(mMsg_Get_base_window_p(), free_str_no, str, mString_DEFAULT_STR_SIZE);
}

static void aNPS2_set_slot_name(int slot, int str_no) {
    aNPS2_set_free_str(0x6CD + slot, str_no);
}

static int aNPS2_make_msg(NPC_P_SEL2_ACTOR* p_sel2, int idx) {
    int msg_no;

    if (idx < aNPS2_MSG_GRP1) {
        msg_no = p_sel2->base_message + idx;
        msg_no -= aNPS2_MSG_GRP0;
    } else if (idx < aNPS2_MSG_GRP2) {
        msg_no = p_sel2->base_message2 + idx;
        msg_no -= aNPS2_MSG_GRP1;
    } else if (idx < aNPS2_MSG_GRP3) {
        msg_no = p_sel2->base_message3 + idx;
        msg_no -= aNPS2_MSG_GRP2;
    } else if (idx < aNPS2_MSG_GRP4) {
        msg_no = p_sel2->base_message4 + idx;
        msg_no -= aNPS2_MSG_GRP3;
    } else if (idx < aNPS2_MSG_GRP5) {
        msg_no = p_sel2->base_message5 + idx;
        msg_no -= aNPS2_MSG_GRP4;
    } else {
        msg_no = p_sel2->base_message6 + idx;
        msg_no -= aNPS2_MSG_GRP5;
    }

    return msg_no;
}

static int aNPS2_now_sd_drive(void) {
    int drive;
    
    drive = mCsd_nowdrive_get();
    if (drive == mCD_SLOT_A) {
        aNPS2_set_slot_name(mCD_SLOT_A, mMsg_FREE_STR3);
    } else {
        aNPS2_set_slot_name(mCD_SLOT_B, mMsg_FREE_STR3);
    }
    return drive;
}

static int aNPS2_search_sd_drive(void) {
    int drive;

    drive = mCsd_sdcard_slot_chk();
    if (drive >= 0) {
        mCsd_nowdrive_set(drive);
    } else {
        drive = mCsd_nowdrive_get();
    }

    if (drive == mCD_SLOT_A) {
        aNPS2_set_slot_name(mCD_SLOT_A, mMsg_FREE_STR3);
    } else {
        aNPS2_set_slot_name(mCD_SLOT_B, mMsg_FREE_STR3);
    }

    return drive;
}

static int aNPS2_chk_off_skin(void) {
    return mCD_castingoff_mura_chk();
}

static int aNPS2_make_sdcard_local(NPC_P_SEL2_ACTOR* p_sel2) {
    mCD_sd_card_info_c sd_info;
    int ret;

    if (p_sel2->sd_action_timer != 0) {
        p_sel2->sd_action_timer--;
    }

    if (p_sel2->sd_result == 0xFF) {
        if (p_sel2->flags & 2) {
            ret = mCD_SaveLand_sdcard_bg(&sd_info);
        } else {
            ret = mCD_SaveLand_sdcard_pileup_bg(&sd_info);
        }

        switch (ret) {
            case mCD_TRANS_ERR_NONE:
                p_sel2->sd_result = 1;
                break;
            case 8:
            case 14:
            case 21:
            case 22:
                p_sel2->sd_result = 3;
                break;
            case 7:
                p_sel2->sd_result = 4;
                break;
            case 2:
            case 4:
            case 5:
            case 6:
            case 11:
            case 24:
                p_sel2->sd_result = 2;
                break;
            case 25:
                break;
            case 41:
            case 42:
            case 46:
            case 50:
                p_sel2->sd_result = 5;
                break;
            case 34:
                p_sel2->sd_result = 6;
                break;
            case 12:
            case 36:
                p_sel2->sd_result = 7;
                break;
            case 37:
                p_sel2->sd_result = 8;
                break;
            case 35:
                p_sel2->sd_result = 9;
                break;
            case 45:
                p_sel2->flags &= ~2;
                p_sel2->sd_result = 10;
                break;
            case 13:
                p_sel2->sd_result = 5;
                break;
            case 51:
                p_sel2->sd_result = 11;
                break;
            default:
                p_sel2->sd_result = 2;
                break;
        }

        if (p_sel2->sd_result >= 2) {
            if (sd_info.exist) {
                aNPS2_set_slot_name(sd_info.chan, mMsg_FREE_STR3);
                aNPS2_set_slot_name(sd_info.chan == mCD_SLOT_A ? mCD_SLOT_B : mCD_SLOT_A, mMsg_FREE_STR4);
            } else {
                aNPS2_set_slot_name(sd_info.chan == mCD_SLOT_A ? mCD_SLOT_B : mCD_SLOT_A, mMsg_FREE_STR3);
                aNPS2_set_slot_name(sd_info.chan, mMsg_FREE_STR4);
            }
        }
    }

    if (p_sel2->sd_action_timer == 0 && p_sel2->sd_result != 0xFF) {
        ret = p_sel2->sd_result;
    } else {
        ret = 0;
    }

    return ret;
}

