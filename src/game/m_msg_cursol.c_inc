static int mMsgTag_dummy_proc(mMsg_Window_c* msg_p, int* idx_p) {
    (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
    msg_p->end_text_cursor_idx = *idx_p;
    return mMsg_RESULT_VOID;
}

