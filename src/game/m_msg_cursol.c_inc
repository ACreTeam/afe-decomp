static int mMsgTag_set_NextRand(mMsg_Window_c* msg_p, int* idx_p, int count) {
    u8* data = msg_p->msg_data->text_buf.data + *idx_p;
    u16 msg_tbl[4];
    int i;
    int rand_idx = get_random_timer(0, count);

    for (i = 0; i < count; i++) {
        msg_tbl[i] = (data[5 + i * 2] << 8) | data[5 + i * 2 + 1];
    }

    mMsg_Set_continue_msg_num(msg_p, msg_tbl[rand_idx]);
    (*idx_p) += mMsg_Set_SizeCode(msg_p, *idx_p);
    return mMsg_RESULT_VOID;
}

static int get_ins_collect_num(void) {
    int i;
    int count = 0;

    for (i = 0; i < aINS_INSECT_TYPE_NUM; i++) {
        int ftr_idx = mNT_ftr_item_no_to_ftr_idx(FTR_START(FTR_SUM_MONSHIRO) + i * 4);
        int idx = ftr_idx >> 5;
        int bit = ftr_idx & 0x1F;

        if ((Now_Private->furniture_collected_bitfield[idx] & (1 << bit)) != 0) {
            count++;
        }
    }

    return count;
}

static int get_fish_collect_num(void) {
    int i;
    int count = 0;

    for (i = 0; i < aGYO_TYPE_NUM; i++) {
        int ftr_idx = mNT_ftr_item_no_to_ftr_idx(FTR_START(FTR_SUM_FUNA) + (mActor_name_t)(i * 4));
        int idx = ftr_idx >> 5;
        int bit = ftr_idx & 0x1F;

        if ((Now_Private->furniture_collected_bitfield[idx] & (1 << bit)) != 0) {
            count++;
        }
    }

    return count;
}

static int get_compatriot_num(void) {
    int i;
    int count = 0;

    for (i = 0; i < 4; i++) {
        if (mPr_NullCheckPersonalID(&Save_Get(homes[i].ownerID)) == FALSE) {
            count++;
        }
    }

    return count;
}

static int mMsgTag_Jump_NextForce(mMsg_Window_c* msg_p, int* idx_p) {
