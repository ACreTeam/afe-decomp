static int aNPS2_chk_sdcard_village(NPC_P_SEL2_ACTOR* p_sel2) {
    mMsg_Window_c* msg_p;
    int slot_no;
    int ret;

    slot_no = p_sel2->sd_slot_no;
    ret = mSD_mura_nextname_get(aNPS2_eng_name, &p_sel2->sd_slot_no);

    switch (ret) {
        case mCD_TRANS_ERR_NONE:
            if (p_sel2->sd_slot_no == -1) {
                if (slot_no == mCD_SLOT_A) {
                    return 2;
                }
                return 3;
            } else {
                msg_p = mMsg_Get_base_window_p();
                mMsg_Set_item_str(msg_p, mMsg_ITEM_STR0, aNPS2_eng_name, mCD_SD_FILE_NAME_SAVE_SIZE);
                return 1;
            }
        case 36:
        case 41:
        case 46:
        case 50:
            return 4;
        case 34:
            return 5;
        case 35:
            return 7;
        case 37:
            return 6;
        case 44:
            if (slot_no == mCD_SLOT_A) {
                return 2;
            }
            return 3;
        case 25:
            return 0;
        default:
            return 5;
    }
}

static int aNPS2_chk_sdcard_photograph(NPC_P_SEL2_ACTOR* p_sel2) {
    int ret;

    ret = mSD_tiff_nextnumber_get(&p_sel2->sd_tiff_number, &p_sel2->sd_file_count);
    switch (ret) {
        case mCD_TRANS_ERR_NONE:
            if (p_sel2->sd_tiff_number == -1) {
                aNPS2_set_slot_name(mCsd_nowdrive_get(), mMsg_FREE_STR3);
                ret = 2;
            } else {
                ret = 1;
            }
            break;
        case 36:
        case 41:
        case 46:
        case 50:
            ret = 3;
            break;
        case 34:
            ret = 4;
            break;
        case 35:
            ret = 5;
            break;
        case 37:
            ret = 6;
            break;
        default:
            ret = 2;
            break;
    }

    return ret;
}

static int aNPS2_chk_repayment_bg_local(int* chan) {
    mCD_sd_card_info_c sd_info;
    int ret;

    ret = mCD_SD_CheckReten_SDmura(&sd_info);
    switch (ret) {
        case mCD_TRANS_ERR_NONE:
            ret = 2;
            break;
        case 25:
            return 0;
        case 47:
            ret = 3;
            break;
        case 27:
            ret = 4;
            aNPS2_set_slot_name(sd_info.chan, mMsg_FREE_STR3);
            aNPS2_set_slot_name(sd_info.chan == mCD_SLOT_A, mMsg_FREE_STR4);
            break;
        case 49:
            ret = 6;
            aNPS2_set_slot_name(sd_info.chan, mMsg_FREE_STR3);
            aNPS2_set_slot_name(sd_info.chan == mCD_SLOT_A, mMsg_FREE_STR4);
            break;
        case 21:
        case 34:
            ret = 5;
            break;
        case 28:
        case 29:
            ret = 1;
            break;
        case 50:
        default:
            ret = 7;
            break;
    }

    *chan = sd_info.chan;
    return ret;
}

