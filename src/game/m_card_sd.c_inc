static int mCD_SD_CheckThisLandSlot(s32* result, s32* game_result, s32 chan, Save_t* data) {
    mCD_memMgr_c* mgr = &l_memMgr;
    SDSave_t* sd_save;
    int ret = mCD_RESULT_BUSY;

    if (data != NULL) {
        *result = CARD_RESULT_NOCARD;
        *game_result = mCD_TRANS_ERR_NOCARD;

        if (chan == -1) {
            return mCD_RESULT_ERROR;
        }

        mCsd_nowdrive_set(chan);
        sd_save = (SDSave_t*)mgr->_0014;
        if (sd_save != NULL) {
            if (mFRm_ReturnCheckSum((u16*)sd_save, mCD_SD_LAND_SAVE_SIZE) == 0) {
                if (sd_save->hdr.save_compressed == 1) {
                    decode_asr(sd_save->save_data, (u8*)data);
                } else {
                    memcpy(data, sd_save->save_data, mCD_SD_SAVE_DATA_SIZE);
                }

                if (mFRm_CheckSaveData_common(&data->save_check, data->land_info.id) == TRUE) {
                    if (mLd_CheckThisLand(data->land_info.name, data->land_info.id) == TRUE) {
                        *game_result = mCD_TRANS_ERR_NONE;
                        ret = mCD_RESULT_SUCCESS;
                    } else if (mLd_CheckId(data->land_info.id) == TRUE) {
                        *game_result = mCD_TRANS_ERR_OTHER_TOWN;
                        ret = mCD_RESULT_ERROR;
                    } else {
                        *game_result = mCD_TRANS_ERR_TOWN_INVALID;
                        ret = mCD_RESULT_ERROR;
                    }
                } else {
                    *game_result = mCD_TRANS_ERR_TOWN_INVALID;
                    ret = mCD_RESULT_ERROR;
                }
            } else {
                *game_result = 41;
                ret = mCD_RESULT_ERROR;
            }
        } else {
            *game_result = 41;
            ret = mCD_RESULT_ERROR;
        }
    }

    return ret;
}

static int mCD_SD_get_this_land_slot_no_game_start(mCD_memMgr_c* mgr) {
    mCD_memMgr_card_info_c* card = mgr->cards;
    Save_t* data = (Save_t*)mgr->workArea;
    int ret = mCD_RESULT_ERROR;
    s32 chan;
    int i;

    for (i = 0; i < CARD_NUM_CHANS; i++) {
        card[i].result = CARD_RESULT_NOCARD;
        card[i].game_result = mCD_TRANS_ERR_NOCARD;
    }

    if (data != NULL) {
        chan = mCsd_sdcard_slot_chk();
        if (chan >= 0) {
            if (mCD_SD_CheckThisLandSlot(&card[chan].result, &card[chan].game_result, chan, data) ==
                mCD_RESULT_SUCCESS) {
                mgr->chan = chan;
                ret = mCD_RESULT_SUCCESS;
            } else {
                mgr->chan = chan;
            }
        } else {
            mgr->chan = mCsd_nowdrive_get();
        }
    }

    return ret;
}

