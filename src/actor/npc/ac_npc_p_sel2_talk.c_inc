        &aNPS2_chk_breaking_2, // aNPS2_TALK_CHK_BREAKING_2
        &aNPS2_common_message_wait, // aNPS2_TALK_MSG_WAIT_BREAKING_2
        &aNPS2_breaking_2, // aNPS2_TALK_BREAKING_2
        &aNPS2_chk_kanji, // aNPS2_TALK_CHK_KANJI
        &aNPS2_chk_option_sdcard, // aNPS2_TALK_CHK_OPTION_SDCARD
        &aNPS2_chk_sdcard_delete, // aNPS2_TALK_CHK_SDCARD_DELETE
        &aNPS2_chk_sdcard_format, // aNPS2_TALK_CHK_SDCARD_FORMAT
        &aNPS2_common_message_wait, // aNPS2_TALK_MSG_WAIT_SDCARD_FORMAT
        &aNPS2_sdcard_format, // aNPS2_TALK_SDCARD_FORMAT
