extern int mCD_abandonment_SDmura(mCD_sd_card_info_c* sd_info) {
    // clang-format off
    static mCD_CHECKSTATION_PROC check_proc[] = {
        mCD_abandonment_SDmura_get_area,
        mCD_SD_CheckReten_Load_Nukegara_check,
        mCD_abandonment_SDmura_abandonment_data_set,
        mCD_SD_repayment_data_write,
        mCD_SD_repayment_data_write_bk,
    };
    // clang-format on

    mCD_memMgr_c* mgr = &l_memMgr;
    mCD_memMgr_fileInfo_c* fileInfo = &mgr->init_game_start_info;
    u8 proc = (u8)fileInfo->proc;
    int ret = mCD_SD_BG_BUSY;
    int res;
    s32 chan;

    sd_info->exist = FALSE;
    if (proc < 5) {
        res = (*check_proc[proc])(mgr, fileInfo);
        if (res == mCD_RESULT_SUCCESS) {
            if (fileInfo->proc == 5) {
                sd_info->chan = mgr->chan;
                ret = fileInfo->_04;
                sAdo_SysLevStop(NA_SE_47);
                mCD_ClearMemMgr_com2(mgr);
            }
        } else if (res != mCD_RESULT_BUSY) {
            sd_info->chan = mgr->chan;
            if (res == mCD_RESULT_SD_SLOT) {
                chan = mCsd_nowdrive_get();
                sd_info->chan = chan;
                sd_info->exist = TRUE;
            }
            ret = fileInfo->_04;
            sAdo_SysLevStop(NA_SE_47);
            mCD_ClearMemMgr_com2(mgr);
        }
    } else {
        ret = mCD_TRANS_ERR_NOCARD;
        sd_info->chan = mgr->chan;
        mCD_ClearMemMgr_com2(mgr);
        sAdo_SysLevStop(NA_SE_47);
    }

    if (ret != mCD_SD_BG_BUSY) {
        SoftResetEnable = TRUE;
    }

    return ret;
}

extern int mSD_sdcard_tiff_read(void* buf, size_t size, s32 chan) {
    mCD_memMgr_c* mgr = &l_memMgr;
    mCD_memMgr_fileInfo_c* fileInfo = &mgr->init_game_start_info;
    u8 proc = (u8)fileInfo->proc;
    int ret = 0x26;

    switch (proc) {
        case 0:
            SoftResetEnable = FALSE;
            fileInfo->fileNo = size;
            fileInfo->chan = chan;
            if (mgr->workArea == NULL) {
                mgr->workArea_size = size;
                mgr->workArea = mCD_malloc_32(size);
            }

            if (mgr->workArea != NULL) {
                mCsd_sd_tiff_read_start();
                fileInfo->proc++;
            }
            break;

        case 1:
            if (mCsd_thread_result_chk() != mCD_RESULT_ERROR) {
                memcpy(buf, mgr->workArea, size);
                ret = mSdcardprobe_fg_chk();
                mCD_ClearMemMgr_com2(mgr);
                SoftResetEnable = TRUE;
            }
            break;
    }

    return ret;
}

extern int mSD_mura_allcount_get(s32* count) {
    mCD_memMgr_c* mgr = &l_memMgr;
    mCD_memMgr_fileInfo_c* fileInfo = &mgr->init_game_start_info;
    u8 proc = (u8)fileInfo->proc;
    int ret = mCD_SD_BG_BUSY;

    switch (proc) {
        case 0:
            SoftResetEnable = FALSE;
            fileInfo->fileNo = *count;
            mCsd_sd_mura_allcount_get_start();
            fileInfo->proc++;
            break;

        case 1:
            if (mCsd_thread_result_chk() != mCD_RESULT_ERROR) {
                *count = fileInfo->fileNo;
                ret = mSdcardprobe_fg_chk();
                mCD_ClearMemMgr_com2(mgr);
                SoftResetEnable = TRUE;
            }
            break;
    }

    return ret;
}

extern int mSD_mura_nextname_get(u8* name, int* count) {
    mCD_memMgr_c* mgr = &l_memMgr;
    mCD_memMgr_fileInfo_c* fileInfo = &mgr->init_game_start_info;
    int ret = mCD_SD_BG_BUSY;

    switch (mgr->_01DC) {
        case 0:
            SoftResetEnable = FALSE;
            fileInfo->_24 = *count;
            mCsd_sd_mura_nextname_get_start();
            mgr->_01DC++;
            break;

        case 1:
            if (mCsd_thread_result_chk() != mCD_RESULT_ERROR) {
                memcpy(name, mgr->sd_eng_name, mCD_SD_FILE_NAME_SAVE_SIZE);
                *count = fileInfo->_24;
                ret = mSdcardprobe_fg_chk();
                mgr->_01DC = 0;
                SoftResetEnable = TRUE;
            }
            break;
    }

    return ret;
}

extern void mCD_SD_static_clear(void) {
    S_SDprobe_fg = 0;
    S_SDthread_use_fg = 0;
    S_movingInfo = 0;
}
