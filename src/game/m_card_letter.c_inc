static int mCD_CheckPPLetterFilename(const char* filename, int idx) {
    char name[32];

    bcopy(l_mCD_letter0_file_name, name, sizeof(l_mCD_letter0_file_name));
    name[17] = '0' | (idx & 0xF);
    name[18] = '\0';
    return mCD_CheckFilename(filename, name, 18);
}

static int mCD_CheckPPLetterFileStatus(CARDStat* stat, int idx) {
    int ret = FALSE;

    if (stat->company[0] == '0' && stat->company[1] == '1') {
        ret = mCD_CheckPPLetterFilename(stat->fileName, idx);
    }

    return ret;
}

static int mCD_SavePostOffice_bg_get_area(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    SoftResetEnable = FALSE;
    return mCD_bg_get_area_common(mgr, fileInfo, mCD_FILE_SAVE_MAIN, 0);
}

static int mCD_SavePostOffice_mura_check_slot(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int res = mCD_RESULT_BUSY;

    if (mgr->cards[0].workArea != NULL && mgr->cards[1].workArea != NULL && mgr->workArea != NULL) {
        int slot = mCD_get_this_land_slot_no_nes(mgr);

        if (slot == mCD_RESULT_SUCCESS) {
            s32 chan = mgr->chan;

            S_mura_slot_no = chan;
            if (chan != -1) {
                if (mCD_check_copyProtect(mgr->workArea, chan) == TRUE) {
                    res = mCD_RESULT_SUCCESS;
                    fileInfo->proc++;
                    mgr->land_saved = Save_Get(save_exist);
                    mgr->copy_protect = Common_Get(copy_protect);
                } else {
                    res = mCD_RESULT_ERROR;
                    mgr->cards[chan].game_result = mCD_TRANS_ERR_WRONG_LAND;
                    mgr->land_saved = Save_Get(save_exist);
                    mgr->copy_protect = Common_Get(copy_protect);
                    fileInfo->_04 = mCD_TRANS_ERR_WRONG_LAND;
                }
            } else {
                fileInfo->_04 = mCD_TRANS_ERR_NOCARD;
                res = mCD_RESULT_ERROR;
            }
        } else if (slot != mCD_RESULT_BUSY) {
            fileInfo->_04 = mCD_TRANS_ERR_NOCARD;
            res = mCD_RESULT_ERROR;
        }
    } else {
        fileInfo->_04 = mCD_TRANS_ERR_NOCARD;
        res = mCD_RESULT_ERROR;
    }

    return res;
}

static int mCD_SavePostOffice_check_repair_land(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int success = FALSE;
    int ret = mCD_RESULT_SUCCESS;

    if (mCD_check_broken_land(mgr) == TRUE) {
        if (mCD_repair_load_land(mgr) == TRUE) {
            fileInfo->proc++;
        } else {
            success = TRUE;
        }
    } else {
        success = TRUE;
    }

    if (success) {
        fileInfo->proc++;
        fileInfo->proc++;
        mgr->loaded_file_type = mCD_FILE_SAVE_MAIN;
        mgr->workArea_size = mCD_get_size(mgr->loaded_file_type);
    }

    return ret;
}

static int mCD_SavePostOffice_repair_land(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int ret = mCD_RESULT_BUSY;

    if (mCD_repair_land(mgr)) {
        mgr->loaded_file_type = mCD_FILE_SAVE_MAIN;
        mgr->workArea_size = mCD_get_size(mgr->loaded_file_type);
        fileInfo->proc++;
        ret = mCD_RESULT_SUCCESS;
    }

    return ret;
}

static int mCD_SavePostOffice_file(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int saved_chan = mgr->chan;
    int chan;
    mCD_memMgr_card_info_c* card;
    int ret = mCD_RESULT_BUSY;
    int i;

    mgr->chan = fileInfo->fileNo;
    chan = mgr->chan;
    if (mgr->workArea != NULL && chan != -1) {
        card = &mgr->cards[mgr->chan];
        if (card->workArea != NULL && mCD_check_card(&card->result, mCD_MEMCARD_SECTORSIZE, chan) == mCD_RESULT_SUCCESS) {
            card->result = CARDMount((s32)chan, card->workArea, NULL);
            if (card->result == CARD_RESULT_READY || card->result == CARD_RESULT_BROKEN) {
                card->result = CARDCheck((s32)chan);
                if (card->result == CARD_RESULT_READY) {
                    for (i = 0; i < CARD_MAX_FILE; i++) {
                        bzero(mgr->workArea, mCD_MAIL_SAVE_SIZE);
                        card->result = CARDGetStatus((s32)chan, i, &card->stat);
                        if (card->result == CARD_RESULT_READY &&
                            mCD_CheckPPMydesignFileStatus(&card->stat, fileInfo->chan) == TRUE) {
                            bcopy(card->stat.fileName, mgr->filename, sizeof(mgr->filename));
                            fileInfo->_04 = mCD_TRANS_ERR_TRAVEL_DATA_EXISTS;
                            ret = mCD_RESULT_SUCCESS;
                            break;
                        }
                    }

                    if (ret == mCD_RESULT_BUSY) {
                        fileInfo->_04 = 32; // TODO: need a error for this
                        ret = mCD_RESULT_ERROR;
                    }
                } else {
                    fileInfo->_04 = mCD_TRANS_ERR_DAMAGED;
                    ret = mCD_RESULT_ERROR;
                }

                CARDUnmount((s32)chan);
            } else {
                if (card->result == CARD_RESULT_ENCODING) {
                    fileInfo->_04 = mCD_TRANS_ERR_BROKEN_WRONGENCODING;
                    CARDUnmount((s32)chan);
                } else {
                    fileInfo->_04 = mCD_TransErrorCode_nes(card->result);
                }

                ret = mCD_RESULT_ERROR;
            }
        } else {
            if (card->result == CARD_RESULT_WRONGDEVICE) {
                fileInfo->_04 = mCD_TRANS_ERR_WRONGDEVICE;
            } else {
                fileInfo->_04 = mCD_TransErrorCode_nes(card->result);
            }
            ret = mCD_RESULT_ERROR;
        }
    } else {
        fileInfo->_04 = mCD_TRANS_ERR_NOCARD;
        ret = mCD_RESULT_ERROR;
    }

    mgr->chan = saved_chan;
    return ret;
}

static int mCD_SavePostOffice_check_slot(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int ret;

    if (fileInfo->chan < 5) {
        ret = mCD_SavePostOffice_file(mgr, fileInfo);
    } else {
        ret = mCD_RESULT_SUCCESS;
        fileInfo->_04 = mCD_TRANS_ERR_NONE;
    }

    if (ret == mCD_RESULT_SUCCESS) {
        if (fileInfo->_04 == mCD_TRANS_ERR_TRAVEL_DATA_EXISTS) {
            fileInfo->_10 = 1;
        } else {
            fileInfo->_10 = 0;
        }

        fileInfo->proc++;
        ret = mCD_RESULT_SUCCESS;
    } else {
        ret = mCD_RESULT_ERROR;
    }

    return ret;
}

static int mCD_SavePostOffice_set_data(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    Save_t* save = (Save_t*)mgr->workArea;
    InAnimal_c* in_animal = mNpc_GetInAnimalP(); // @unused
    u16 copy_protect;
    int chan = mgr->chan;
    int ret = mCD_RESULT_BUSY;
    
    if (save != NULL && chan != -1) {
        Private_c* priv = Now_Private;
        mCkRh_SavePlayTime(Common_Get(player_no));
        if (mCD_CheckResetCode(priv) == TRUE) {
            mCD_SetResetCode(priv);
        }

        Save_Set(save_exist, TRUE);
        copy_protect = mCD_get_land_copyProtect();
        Save_Set(copy_protect, copy_protect);
        Common_Set(copy_protect, copy_protect);
        Save_Set(travel_hard_time, lbRTC_HardTime());
        if (mCD_castingoff_mura_chk() != TRUE) {
            Save_Set(nukegara_time, lbRTC_HardTime());
        }

        // @BUG - this is duplicated code
        if (mCD_castingoff_mura_chk() != TRUE) {
            Save_Set(nukegara_time, lbRTC_HardTime());
        }

        bcopy(Common_GetPointer(save.save), save, sizeof(Save_t));
        if (Common_Get(player_decoy_flag) == TRUE) {
            save->private_data[Common_Get(player_no)].exists = FALSE;
        }

        save->save_check.version = mFRm_VERSION;
        mFRm_SetSaveCheckData(&save->save_check);
        save->save_check.checksum = mFRm_GetFlatCheckSum((u16*)save, sizeof(Save), save->save_check.checksum);
        mgr->loaded_file_type = mCD_FILE_SAVE_MAIN;
        mgr->workArea_size = mCD_get_size(mgr->loaded_file_type);
        fileInfo->proc++;
        ret = mCD_RESULT_SUCCESS;
    } else {
        fileInfo->_04 = mCD_TRANS_ERR_NOCARD;
        ret = mCD_RESULT_ERROR;
    }

    return ret;
}

static int mCD_SavePostOffice_write_main(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int ret = mCD_SaveMydesign_write_main(mgr, fileInfo);
    // TODO: enums
    if (fileInfo->proc == 9) {
        fileInfo->proc = 9;
    } else if (fileInfo->proc == 13) {
        fileInfo->proc = 13;
    }

    return ret;
}

static int mCD_SavePostOffice_make_file_name(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int chan = mgr->chan;
    u8 idx;
    int i;

    if (chan == -1) {
        chan = 0;
    }

    mem_clear((u8*)mgr->filename, sizeof(mgr->filename), 0);
    bcopy(l_mCD_mydesign0_file_name, mgr->filename, 0x12);

    if (fileInfo->chan >= 5) {
        idx = 0;
        for (i = 0; i < 5; i++) {
            if (chan == mCD_SLOT_A) {
                if (S_slot_a_file_extence[i] == '\0') {
                    break;
                }
            } else {
                if (S_slot_b_file_extence[i] == '\0') {
                    break;
                }
            }
            idx++;
        }

        if (idx >= 5) {
            idx = 4;
        }
        fileInfo->chan = idx;
    } else {
        idx = (u8)fileInfo->chan;
    }

    mgr->filename[0x11] = '0' | (idx & 0xF);
    mgr->filename[0x12] = '\0';
    fileInfo->proc++;

    return mCD_RESULT_SUCCESS;
}

static int mCD_SavePostOffice_set_rewrite_main(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    int ret = mCD_SaveMydesign_set_rewrite_main(mgr, fileInfo);

    // TODO: enums
    if (fileInfo->proc == 13) {
        fileInfo->proc = 13;
    }

    return ret;
}

static int mCD_SavePostOffice_create_file(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    mCD_file_entry_c* entry = &l_mcd_file_table[mCD_FILE_MAIL];
    mCD_memMgr_card_info_c* card;
    int ret;
    s32 chan;

    chan = mgr->chan;
    if (chan != -1) {
        card = &mgr->cards[chan];
        ret = mCD_create_file_bg(mgr->filename, CARD_ATTR_NO_COPY, entry->filesize, chan, &card->result, &card->fileNo);
        card->game_result = mCD_TransErrorCode_nes(card->result);
        if (ret == mCD_RESULT_SUCCESS) {
            fileInfo->proc++;
        } else if (ret != mCD_RESULT_BUSY) {
            fileInfo->_04 = card->game_result;
            ret = mCD_SavePostOffice_set_rewrite_main(mgr, fileInfo);
        }
    } else {
        fileInfo->_04 = mCD_TRANS_ERR_NOCARD;
        ret = mCD_SavePostOffice_set_rewrite_main(mgr, fileInfo);
    }

    return ret;
}

static int mCD_SaveLetter_set(mCD_memMgr_c* mgr, mCD_memMgr_fileInfo_c* fileInfo) {
    static int icon_fileNo[] = { RESOURCE_LETTER1, RESOURCE_LETTER2, RESOURCE_LETTER3, RESOURCE_LETTER4, RESOURCE_LETTER5 };
    LetterSave_c* save;
    u8* data_p;
    mCD_keep_mail_c* mail;
    s32 result;
    u8 chan_idx;

    save = (LetterSave_c*)mgr->workArea;
    if (save != NULL) {
        mgr->loaded_file_type = mCD_FILE_MAIL;
        mgr->workArea_size = mCD_get_size(mgr->loaded_file_type);

        if (fileInfo->_10 != 0) {
            bzero(save, mgr->workArea_size);
            if (mCD_read_fg(save, mgr->filename, mCD_MAIL_SAVE_SIZE, 0, fileInfo->fileNo, &result) == mCD_RESULT_SUCCESS) {
                mail = &save->mail;
                if (mFRm_ReturnCheckSum((u16*)&mail->checksum, l_aram_real_size_32_table[mCD_ARAM_DATA_MAIL]) == 0 &&
                    S_comp_code != mail->landid) {
                    fileInfo->_04 = 0x20; /* TODO: add mCD_TRANS_ERR_* enum */
                    return mCD_RESULT_ERROR;
                }
            } else {
                fileInfo->_04 = mCD_TransErrorCode_nes(result);
                return mCD_RESULT_ERROR;
            }
        }

        save = (LetterSave_c*)mgr->workArea;
        bzero(save, mgr->workArea_size);
        chan_idx = (u8)fileInfo->chan;
        bcopy(l_comment_lt_0_str0, save->header.comment, sizeof(l_comment_lt_0_str0));

        switch (chan_idx) {
            case 0:
                bcopy(l_comment_lt_0_str1, save->header.comment + sizeof(l_comment_lt_0_str0), sizeof(l_comment_lt_0_str1));
                break;
            case 1:
                bcopy(l_comment_lt_0_str2, save->header.comment + sizeof(l_comment_lt_0_str0), sizeof(l_comment_lt_0_str2));
                break;
            case 2:
                bcopy(l_comment_lt_0_str3, save->header.comment + sizeof(l_comment_lt_0_str0), sizeof(l_comment_lt_0_str3));
                break;
            case 3:
                bcopy(l_comment_lt_0_str4, save->header.comment + sizeof(l_comment_lt_0_str0), sizeof(l_comment_lt_0_str4));
                break;
            case 4:
                bcopy(l_comment_lt_0_str5, save->header.comment + sizeof(l_comment_lt_0_str0), sizeof(l_comment_lt_0_str5));
                break;
        }

        data_p = save->header.banner;
        data_p = mCD_set_bti_data(data_p, RESOURCE_B_LETTER, 0xC00, 1, 0x200, FALSE);
        data_p = mCD_set_bti_data(data_p, icon_fileNo[chan_idx], 0x400, 1, 0x200, FALSE);
        data_p += 32;
        bcopy(mgr->_115C, data_p, l_aram_real_size_32_table[mCD_ARAM_DATA_MAIL]);
        mail = (mCD_keep_mail_c*)data_p;
        mail->landid = (u16)RANDOM(0xFFFF);
        mail->checksum = mFRm_GetFlatCheckSum((u16*)mail, l_aram_real_size_32_table[mCD_ARAM_DATA_MAIL], mail->checksum);
        mgr->workArea_size = ALIGN_NEXT(l_aram_real_size_32_table[mCD_ARAM_DATA_MAIL] + sizeof(MemcardHeader_c) + 0x20, mCD_MEMCARD_SECTORSIZE);
        fileInfo->proc++;
        return mCD_RESULT_SUCCESS;
    }
    
    return mCD_RESULT_ERROR;
}

