    }

    if (p_sel2->sd_action_timer == 0 && p_sel2->sd_result != 0xFF) {
        ret = p_sel2->sd_result;
    } else {
        ret = 0;
    }

    return ret;
}

static int aNPS2_sdcard_format_local(NPC_P_SEL2_ACTOR* p_sel2) {
    int ret;

    if (p_sel2->sd_action_timer == 112) {
        mCsd_sd_format_start();
    }

    if (p_sel2->sd_action_timer != 0) {
        p_sel2->sd_action_timer--;
    }

    if (p_sel2->sd_result == 0xFF) {
        ret = mCsd_sd_format_wait();

        switch (ret) {
            case 38:
                return 0;
            case 37:
                p_sel2->sd_result = 3;
                break;
            case 34:
                p_sel2->sd_result = 4;
                break;
            case 41:
            case 46:
                p_sel2->sd_result = 2;
                break;
            case 33:
                p_sel2->sd_result = 1;
                break;
            case 50:
                p_sel2->sd_result = 5;
                break;
            default:
                p_sel2->sd_result = 2;
                break;
        }
    }

    if (p_sel2->sd_action_timer == 0 && p_sel2->sd_result != 0xFF) {
        ret = p_sel2->sd_result;
    } else {
        ret = 0;
    }

    return ret;
}

