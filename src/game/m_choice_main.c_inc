static int mChoice_TagPut_String(u8* data, int* idx, int max_size, ACTOR* actor) {
    static const mChoice_PUT_STRING_PROC proc[mFont_TAG_STR_NUM] = {
        &mChoice_Str_PlayerName,
        &mChoice_Str_NpcName,
        &mChoice_Str_Tail,
        &mChoice_Str_Determination,
        NULL,
        &mChoice_Str_CountryName,
        &mChoice_Str_IslandName,
        &mChoice_Str_Year,
        &mChoice_Str_Mounth,
        &mChoice_Str_Week,
        &mChoice_Str_Day,
        &mChoice_Str_Hour,
        &mChoice_Str_Min,
        &mChoice_Str_Sec,
        &mChoice_Str_RandomNum,
        &mChoice_Str_AmPm,
        NULL,
        NULL,
        &mChoice_Str_Free0,
        &mChoice_Str_Free1,
        &mChoice_Str_Free2,
        &mChoice_Str_Free3,
        &mChoice_Str_Free4,
        &mChoice_Str_Free5,
        &mChoice_Str_Free6,
        &mChoice_Str_Free7,
        &mChoice_Str_Free8,
        &mChoice_Str_Free9,
        &mChoice_Str_Free10,
        &mChoice_Str_Free11,
        &mChoice_Str_Free12,
        &mChoice_Str_Free13,
        &mChoice_Str_Free14,
        &mChoice_Str_Free15,
        &mChoice_Str_Free16,
        &mChoice_Str_Free17,
        &mChoice_Str_Free18,
        &mChoice_Str_Free19,
        &mChoice_Str_Item0,
        &mChoice_Str_Item1,
        &mChoice_Str_Item2,
        &mChoice_Str_Item3,
        &mChoice_Str_Item4,
        NULL,
        NULL,
        NULL,
        &mChoice_Str_OwnIslandName,
        &mChoice_Str_PlClothType,
        NULL,
        NULL,
        &mChoice_Str_TruthTail,
        &mChoice_Str_CountryNameKana,
    };

    u8* str = data + *idx;
    int group;
    int id;
    mChoice_PUT_STRING_PROC put_proc;

    group = mFont_Get_TagGroup(str);
    id = mFont_Get_TagId(str);
    mFont_Get_TagSize(str); // @unused
    put_proc = NULL;

    if (group == mFont_TAG_GROUP_STR) {
        put_proc = proc[id];
    }

    if (put_proc != NULL) {
        return (*put_proc)(data, *idx, max_size, actor);
    } else {
        *idx += mFont_Get_TagSize(str);
    }

    return max_size;
}

static void mChoice_Change_ControlCode(u8* data, int max_size, ACTOR* actor) {
    int new_max_idx = max_size;
    int idx = 0;

    while (idx < new_max_idx) {
        if (data[idx] == CHAR_CONTROL_CODE) {
            new_max_idx = mChoice_ContPut_String(data, idx, new_max_idx, actor);
        } else if (data[idx] == CHAR_MESSAGE_TAG) {
            new_max_idx = mChoice_TagPut_String(data, &idx, new_max_idx, actor);
        } else {
            idx++;
        }
    }
}

extern void mChoice_Load_ChoseStringFromRom(mChoice_c* choice, u8* str, int str_no, ACTOR* actor) {
    mMsg_bmg_info_c bmg_info;

    mMsgLoad_bmg_init(&bmg_info, Choice_rom_start, str_no, str, 72);
    if (mMsgLoad_bmg_load(&bmg_info)) {
        mem_clear(str + bmg_info.load_size, 72 - bmg_info.load_size, CHAR_SPACE);
    }

    mChoice_Change_ControlCode(str, mChoice_CHOICE_STRING_LEN, actor);
}

extern void mChoice_no_b_set(mChoice_c* choice) {
    choice->no_b_flag = TRUE;
}

extern void mChoice_no_b_close_set(mChoice_c* choice) {
    choice->no_b_flag = TRUE;
    choice->no_close_flag = TRUE;
}
