#define KITEKI_BASE_VOLUME 1.15f
#define KITEKI_MIN_DISTANCE 320.0f
#define KITEKI_MAX_DISTANCE 6400.0f
#define KITEKI_VOLUME_SCALE (KITEKI_BASE_VOLUME / (KITEKI_MAX_DISTANCE - KITEKI_MIN_DISTANCE))

#define MD_BASE_VOLUME 1.15f
#define MD_MIN_DISTANCE 0.0f
#define MD_MAX_DISTANCE SOU_ONGEN_AREA2
#define MD_VOLUME_SCALE (MD_BASE_VOLUME / SQ(MD_MAX_DISTANCE - MD_MIN_DISTANCE))
#define MD_MIN_VOLUME 0.2f
#define MD_MAX_VOLUME 0.8f

void Sou_lev_ongen_data_struct_clear() {
    u8 i = 0;
    for (i = 0; i < ARRAY_COUNT(sou_lev_ongen_data); i++) {
        sou_lev_ongen_data[i].update_count = 0;
        sou_lev_ongen_data[i].prev_update_count = 0;
        sou_lev_ongen_data[i].state = 0;
        sou_lev_ongen_data[i].crossed_area_flag = 0;
        sou_lev_ongen_data[i].entry_id = 0;
        sou_lev_ongen_data[i].se_id = 0;
        sou_lev_ongen_data[i].priority = 0;
        sou_lev_ongen_data[i].distance = 9999.f;
        sou_lev_ongen_data[i].prev_distance = 9999.f;
    }
    for (i = 0; i < ARRAY_COUNT(sou_ls_stack); i++) {
        sou_ls_stack[i]._0 = 0;
        sou_ls_stack[i]._1 = 0;
        sou_ls_stack[i]._2 = 0;
        sou_ls_stack[i]._3 = 0;
        sou_ls_stack[i]._4 = 0;
        sou_ls_stack[i]._5 = 0;
        sou_ls_stack[i]._6 = 0;
        sou_ls_stack[i]._7 = 0;
    }
    for (i = 0; i < ARRAY_COUNT(sou_lev_se); i++) {
        sou_lev_se[i].queue0 = 0;
        sou_lev_se[i].queue1 = 0;
        sou_lev_se[i].queue2 = 0;
        sou_lev_se[i].queue3 = 0;
        sou_lev_se[i].queue4 = 0;
        sou_lev_se[i].queue5 = 0;
        sou_lev_se[i].queue6 = 0;
        sou_lev_se[i].queue7 = 0;
        sou_lev_se[i].volumeScale = 0.f;
        sou_lev_se[i].baseVolumeScale = 1.f;
        sou_lev_se[i].pan = 0x3f;
        sou_lev_se[i].reverbVolume = 0;
        sou_lev_se[i].echoEnableFlag = 0;
        sou_lev_se[i].echo = 0;
    }
    for (i = 0; i < ARRAY_COUNT(sou_ongen_entry); i++) {
        sou_ongen_entry[i]._00 = 0;
        sou_ongen_entry[i]._04 = 0;
        sou_ongen_entry[i]._06 = 0;
