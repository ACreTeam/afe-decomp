static void mi_kani_setupAction(MUSEUM_INSECT_PRIVATE_DATA* priv, int act, GAME* game) {
    // @ 805d7134
    static PRIV_INSECT_PROCESS init_proc[7] = {
        &mi_kani_wait_init,
        &mi_kani_move_init,
        &mi_kani_dug_init,
        &mi_kani_appear_init,
        &mi_kani_appear_from_shell_init,
        &mi_kani_into_shell_init,
        &mi_kani_camouflage_init,
    };

    // @ 805d7150
    static PRIV_INSECT_PROCESS move_proc[7] = {
        &mi_kani_wait,
        &mi_kani_move,
        &mi_kani_dug,
        &mi_kani_appear,
        &mi_kani_appear_from_shell,
        &mi_kani_into_shell,
        &mi_kani_camouflage,
    };
    
    priv->_04 = move_proc[act];
    (*init_proc[act])(priv, game);
}

static void minsect_kani_ct(MUSEUM_INSECT_PRIVATE_DATA* priv, GAME* game) {
    switch (priv->insect_type) {
        case aINS_INSECT_TYPE_CRAB:
            priv->_7A = 0;
            break;
        case aINS_INSECT_TYPE_HERMIT_CRAB:
            priv->_7A = 1;
            break;
        case aINS_INSECT_TYPE_COCONUT_CRAB:
            priv->_7A = 2;
            break;
    }

    priv->_1C = mi_kani_init_pos[priv->_7A];

    if (priv->insect_type != aINS_INSECT_TYPE_COCONUT_CRAB) {
        priv->_1C.y = mi_kani_get_pos_y(&priv->_1C);
    }

    priv->_74 = 0;
    mi_kani_setupAction(priv, MI_KANI_ACT_WAIT, game);
    priv->_68.y = DEG2SHORT_ANGLE2(Rnd_EX_fx(90.0f));
    priv->_72 = priv->_68.y;
    priv->_78 = 1;
    priv->_5C = 1.0f;
}

static void minsect_kani_mv(MUSEUM_INSECT_PRIVATE_DATA* priv, GAME* game) {
    if (GETREG(NMREG, 18)) {
        priv->_1C.x = 97.0f + GETREG(NMREG, 16);
        priv->_1C.z = 387.0f + GETREG(NMREG, 17);
    }

    if (priv->insect_type != aINS_INSECT_TYPE_COCONUT_CRAB) {
        priv->_1C.y = mi_kani_get_pos_y(&priv->_1C);
    }

    (*priv->_04)(priv, game);
    minsect_kani_ObjCheck(priv);
    minsect_tree_ObjCheck(priv);
}

extern Gfx ef_shadow_insect_modelT[];
static void minsect_kani_dw(MUSEUM_INSECT_PRIVATE_DATA* priv, GAME* game) {
    GAME_PLAY* play = (GAME_PLAY*)game;
    s16 anglY = priv->_68.y;
    float scale;

    if (priv->insect_type == aINS_INSECT_TYPE_CRAB) {
        anglY += DEG2SHORT_ANGLE2(90.0f);
    }

    _texture_z_light_fog_prim(game->graph);
    Matrix_translate(priv->_1C.x, priv->_1C.y + priv->_58, priv->_1C.z, MTX_LOAD);
    scale = priv->_14 * priv->_5C;
    Matrix_scale(scale, scale, scale, MTX_MULT);
    Matrix_rotateXYZ(priv->_68.x, anglY, priv->_68.z, MTX_MULT);

    if (priv->_58 > -13.0f) {
        OPEN_DISP(game->graph);

        gSPMatrix(NEXT_POLY_OPA_DISP, _Matrix_to_Mtx_new(game->graph), G_MTX_NOPUSH | G_MTX_LOAD | G_MTX_MODELVIEW);
        gDPSetEnvColor(NEXT_POLY_OPA_DISP, 0, 255, 155, 255);
        gSPDisplayList(NEXT_POLY_OPA_DISP, minsect_mdl[priv->insect_type][priv->_74]);

        CLOSE_DISP(game->graph);
    }

    if (priv->insect_type == aINS_INSECT_TYPE_HERMIT_CRAB) {
        Matrix_translate(priv->_1C.x, priv->_1C.y, priv->_1C.z, MTX_LOAD);
        scale = priv->_14;
        Matrix_scale(scale, scale, scale, MTX_MULT);
        Matrix_rotateXYZ(priv->_68.x, anglY, priv->_68.z, MTX_MULT);

        OPEN_DISP(game->graph);

        gSPMatrix(NEXT_POLY_OPA_DISP, _Matrix_to_Mtx_new(game->graph), G_MTX_NOPUSH | G_MTX_LOAD | G_MTX_MODELVIEW);
        gSPDisplayList(NEXT_POLY_OPA_DISP, minsect_mdl[priv->insect_type][2]);

        CLOSE_DISP(game->graph);
    }

    if (priv->insect_type != aINS_INSECT_TYPE_CRAB || !(priv->_58 < -2.0f)) {
        f32 scale;
        u8 alpha;
        f32 v1;
        u8 shadow = play->kankyo.shadow_alpha;


        v1 = 1.f + (GETREG(TAKREG, 43) * 0.1f);
        alpha = (int)(100.f * v1 + 40.0f + GETREG(TAKREG, 44));
        alpha = (alpha * shadow) >> 8;

        scale = (GETREG(TAKREG, 0x28) * 0.001f + 0.005f);
        scale *= minsect_shadow_scale_tbl[priv->insect_type];

        Matrix_translate(priv->_1C.x, priv->_1C.y, priv->_1C.z, MTX_LOAD);
        Matrix_scale(scale, scale, scale, MTX_MULT);
        _texture_z_light_fog_prim_shadow(game->graph);

        OPEN_SHADOW_DISP(game->graph);
        gDPSetPrimColor(SHADOW_DISP++, 0, 255, 0, 0, 0, alpha);
        gSPMatrix(SHADOW_DISP++, _Matrix_to_Mtx_new(game->graph), G_MTX_NOPUSH | G_MTX_LOAD | G_MTX_MODELVIEW);
        gSPDisplayList(SHADOW_DISP++, ef_shadow_insect_modelT);
        CLOSE_SHADOW_DISP(game->graph);
    }
}
