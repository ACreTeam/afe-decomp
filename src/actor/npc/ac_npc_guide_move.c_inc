}

static void aNGD_move_ready_init(NPC_GUIDE_ACTOR* guide, GAME_PLAY* play) {
    guide->npc_class.draw.main_animation.keyframe.morph_counter = 0.0f;
}

static void aNGD_move_to_aisle_init(NPC_GUIDE_ACTOR* guide, GAME_PLAY* play) {
    aNGD_set_walk_spd2(guide, play);
}

static void aNGD_move_to_deck_init(NPC_GUIDE_ACTOR* guide, GAME_PLAY* play) {
    aNGD_set_stop_spd(guide, play);
    guide->npc_class.actor_class.world.position.x = 140.0f;
    guide->npc_class.actor_class.world.position.z = 130.0f;
    guide->next_action = aNGD_ACTION_KEITAI_ON;
}

static void aNGD_keitai_off_init(NPC_GUIDE_ACTOR* guide, GAME_PLAY* play) {
    aNGD_chg_cond_keitai(guide, aTOL_ACTION_PUTAWAY);
    guide->next_action = aNGD_ACTION_OPEN_DOOR;
}

static void aNGD_open_door_init(NPC_GUIDE_ACTOR* guide, GAME_PLAY* play) {
    guide->next_action = aNGD_ACTION_RETURN_APPROACH;
}

static void aNGD_return_approach_init(NPC_GUIDE_ACTOR* guide, GAME_PLAY* play) {
    guide->camera_eyes_flag = TRUE;
    aNGD_set_walk_spd2(guide, play);
    guide->npc_class.draw.main_animation.keyframe.morph_counter = 0.0f;
}

static void aNGD_sitdown2_start_wait_init(NPC_GUIDE_ACTOR* guide, GAME_PLAY* play) {
    mDemo_Set_OrderValue(mDemo_ORDER_NPC0, 9, 0);
}

static void aNGD_sitdown2_init(NPC_GUIDE_ACTOR* guide, GAME_PLAY* play) {
    guide->npc_class.draw.main_animation.keyframe.morph_counter = 0.0f;
    guide->next_action = aNGD_ACTION_LAST_TALK_END_WAIT;
}

static void aNGD_last_talk_end_wait_init(NPC_GUIDE_ACTOR* guide, GAME_PLAY* play) {
    if (guide->old_data_loaded == FALSE) {
        aNGD_chg_cond_keitai(guide, aTOL_ACTION_DESTRUCT);
        guide->npc_class.right_hand.item_actor_p = NULL;
    }
}

static void aNGD_scene_change_wait_init(NPC_GUIDE_ACTOR* guide, GAME_PLAY* play) {
    u8 term;
    int town_day;
    int i;

    /* Init next scene transition */
    goto_next_scene(play, 0, 1);
    play->fb_wipe_type = WIPE_TYPE_FADE_BLACK;
    Common_Get(transition).wipe_type = WIPE_TYPE_CIRCLE_LEFT;

    /* Clear plant growth renew time */
    Save_Set(all_grow_renew_time, mTM_rtcTime_clear_code);

    /* Update player ID town info */
    if (Now_Private != NULL) {
        mLd_CopyLandName(Now_Private->player_ID.land_name, Save_Get(land_info).name);
    }

    /* Init island */
    for (i = 0; i < mHS_HOUSE_NUM; i++) {
        bcopy(Save_GetPointer(land_info), &Save_Get(homes[i]).island.landinfo, sizeof(mLd_land_info_c));
    }

    /* Update some renew time values to current rtc time */
    lbRTC_TimeCopy(Save_GetPointer(last_grow_time), Common_GetPointer(time.rtc_time));
    mTM_set_renew_time(Save_GetPointer(renew_time), Common_GetPointer(time.rtc_time));
    mTM_set_season(); // initialize the season

    /* Initialize first Stalk Market info */
    Kabu_decide_price_schedule();

    /* Init Post Office */
    mPO_post_office_init();

    /* Set insect term info */
    Save_Set(insect_term, Common_Get(time.rtc_time.month));
    Save_Set(insect_term_transition_offset, RANDOM(6));

    /* Set fish term info */
    term = Common_Get(time.rtc_time.month) * 2;
    if (Common_Get(time.rtc_time.day) > 15) {
        term++;
    }
    Save_Set(gyoei_term, term);
    Save_Set(gyoei_term_transition_offset, RANDOM(6));

    /* Decide Town Day date */
    town_day = 1 + RANDOM(30);
    if (town_day >= 4) {
        town_day++; // add one to prevent conflict with Fireworks Festival (4th of July)
    }
    Save_Set(town_day, town_day);

    mSP_ShopGameStartCt(NULL);
    mNtc_SetInitData();

    if (guide->old_data_loaded == FALSE) {
        mPr_SetNowPrivateCloth();
        aNGD_set_pl_face_type(guide);
    } else if (Common_Get(player_no) < mPr_FOREIGNER) {
        mEv_EventON(mEv_SAVED_FJOPENQUEST_PLR0 + Common_Get(player_no));
    }
        
    mEv_SetFirstJob();
    mEv_SetFirstIntro();
    mEnv_DecideWeather_FirstGameStart();
    mCD_calendar_clear(-1);
    mCD_calendar_wellcome_on();
    mNpc_SetParentNameAllAnimal();
    Common_Set(submenu_disabled, TRUE);
    mRmTp_SetDefaultLightSwitchData(1);
    mAP_decide_today_agb_game();
    mBGMPsComp_make_ps_wipe(0x41C2);
    mBGMPsComp_scene_mode(18);
}

typedef struct player_plus_name_s {
    u8 name[mMsg_FREE_STRING_LEN];
    int len;
} aNGD_player_plus_name_c;

static void aNGD_select_player_plus_init(NPC_GUIDE_ACTOR* guide, GAME_PLAY* play) {
    aNGD_player_plus_name_c names[PLAYER_NUM + 1];
    PlusConvData_c* plus_data = &guide->plus_data;
    int len;
    int idx;
    int i;

    for (i = 0; i < PLAYER_NUM; i++) {
        mem_clear(names[i].name, sizeof(names[i].name), CHAR_SPACE);
        names[i].len = 0;
    }

    idx = 0;
    for (i = 0; i < PLAYER_NUM; i++) {
        if (mPr_CheckPrivate((Private_c*)&plus_data->private_plus[i]) == TRUE) {
            memcpy(names[idx].name, plus_data->private_plus[i].player_ID.player_name, PLAYER_NAME_LEN);
            len = mMl_strlen(names[idx].name, sizeof(names[idx].name), CHAR_SPACE);
            mString_Load_StringFromRom(names[idx].name + len, sizeof(names[i].name), 0x780 + idx);
            names[idx].len = mMl_strlen(names[idx].name, sizeof(names[idx].name), CHAR_SPACE);
            idx++;
        }
    }

    guide->num_plus_players = idx;
    mString_Load_StringFromRom(names[idx].name, sizeof(names[idx].name), 0x784);
    names[idx].len = mMl_strlen(names[idx].name, sizeof(names[idx].name), CHAR_SPACE);

    mChoice_Set_choice_data(mChoice_Get_base_window_p(), names[0].name, names[0].len, names[1].name, names[1].len, names[2].name, names[2].len, names[3].name, names[3].len, names[4].name, names[4].len, NULL, 0);
}

typedef void (*aNGD_INIT_PROC)(NPC_GUIDE_ACTOR*, GAME_PLAY*);

static void aNGD_init_proc(NPC_GUIDE_ACTOR* guide, GAME_PLAY* play, int action) {
    static aNGD_INIT_PROC init_proc[] = {
        (aNGD_INIT_PROC)&none_proc1, // aNGD_ACTION_ENTER
        &aNGD_set_walk_spd, // aNGD_ACTION_APPROACH
        &aNGD_set_stop_spd, // aNGD_ACTION_TALK_START_WAIT
        (aNGD_INIT_PROC)&none_proc1, // aNGD_ACTION_TIME_CHECK
        &aNGD_sdon_and_pb_wait_init, // aNGD_ACTION_SDON_AND_PB_WAIT
        &aNGD_time_menu_open_wait_init, // aNGD_ACTION_TIME_MENU_OPEN_WAIT
        &aNGD_time_menu_close_wait_init, // aNGD_ACTION_TIME_MENU_CLOSE_WAIT
        &aNGD_msg_win_open_wait_init, // aNGD_ACTION_MSG_WIN_OPEN_WAIT
        (aNGD_INIT_PROC)&none_proc1, // aNGD_ACTION_CONFIRM_INPUT_DATA
        (aNGD_INIT_PROC)&none_proc1, // aNGD_ACTION_WAIT_PERMISSION
        &aNGD_sitdown_init, // aNGD_ACTION_SITDOWN
        &aNGD_pname_menu_open_wait_init, // aNGD_ACTION_PNAME_MENU_OPEN_WAIT
        &aNGD_time_menu_close_wait_init, // aNGD_ACTION_PNAME_MENU_CLOSE_WAIT
        (aNGD_INIT_PROC)&none_proc1, // aNGD_ACTION_SEX_SELECT_WAIT
        (aNGD_INIT_PROC)&none_proc1, // aNGD_ACTION_SEX_SELECT_WAIT2
        &aNGD_sdon_and_pb_wait_init, // aNGD_ACTION_SEX_SELECT_AFTER
        &aNGD_cname_menu_open_wait_init, // aNGD_ACTION_CNAME_MENU_OPEN_WAIT
        &aNGD_time_menu_close_wait_init, // aNGD_ACTION_CNAME_MENU_CLOSE_WAIT
        &aNGD_cename_menu_open_wait_init, // aNGD_ACTION_CENAME_MENU_OPEN_WAIT
        &aNGD_time_menu_close_wait_init, // aNGD_ACTION_CENAME_MENU_CLOSE_WAIT
        (aNGD_INIT_PROC)&none_proc1, // aNGD_ACTION_STANDUP_START_WAIT
        &aNGD_standup_init, // aNGD_ACTION_STANDUP
        &aNGD_move_ready_init, // aNGD_ACTION_MOVE_READY
        &aNGD_move_to_aisle_init, // aNGD_ACTION_MOVE_TO_AISLE
        (aNGD_INIT_PROC)&none_proc1, // aNGD_ACTION_MOVE_TO_DOOR
        &aNGD_move_to_deck_init, // aNGD_ACTION_MOVE_TO_DECK
        (aNGD_INIT_PROC)&none_proc1, // aNGD_ACTION_KEITAI_ON
        (aNGD_INIT_PROC)&none_proc1, // aNGD_ACTION_KEITAI_TALK
        &aNGD_keitai_off_init, // aNGD_ACTION_KEITAI_OFF
        &aNGD_open_door_init, // aNGD_ACTION_OPEN_DOOR
        &aNGD_return_approach_init, // aNGD_ACTION_RETURN_APPROACH
        &aNGD_set_stop_spd, // aNGD_ACTION_LAST_TALK_START_WAIT
        &aNGD_sitdown2_start_wait_init, // aNGD_ACTION_SITDOWN2_START_WAIT
        &aNGD_sitdown2_init, // aNGD_ACTION_SITDOWN2
        &aNGD_last_talk_end_wait_init, // aNGD_ACTION_LAST_TALK_END_WAIT
        &aNGD_scene_change_wait_init, // aNGD_ACTION_SCENE_CHANGE_WAIT
        (aNGD_INIT_PROC)&none_proc1, // aNGD_ACTION_WAIT_PERMISSION_PLUS
        &aNGD_sitdown_init, // aNGD_ACTION_37
        &aNGD_sitdown_init, // aNGD_ACTION_38
        &aNGD_select_player_plus_init, // aNGD_ACTION_SELECT_PLAYER_PLUS
        (aNGD_INIT_PROC)&none_proc1, // aNGD_ACTION_CONFIRM_PLAYER
    };

    (*init_proc[action])(guide, play);
}

static void aNGD_setupAction(NPC_GUIDE_ACTOR* guide, GAME_PLAY* play, int action) {
    static aNGD_PROC process[] = {
        &aNGD_enter, // aNGD_ACTION_ENTER
        &aNGD_approach, // aNGD_ACTION_APPROACH
        &aNGD_talk_start_wait, // aNGD_ACTION_TALK_START_WAIT
        &aNGD_time_check, // aNGD_ACTION_TIME_CHECK
        &aNGD_sdon_and_pb_wait, // aNGD_ACTION_SDON_AND_PB_WAIT
        &aNGD_time_menu_open_wait, // aNGD_ACTION_TIME_MENU_OPEN_WAIT
        &aNGD_time_menu_close_wait, // aNGD_ACTION_TIME_MENU_CLOSE_WAIT
        &aNGD_msg_win_open_wait, // aNGD_ACTION_MSG_WIN_OPEN_WAIT
        &aNGD_confirm_input_data, // aNGD_ACTION_CONFIRM_INPUT_DATA
        &aNGD_wait_permission, // aNGD_ACTION_WAIT_PERMISSION
        &aNGD_sitdown, // aNGD_ACTION_SITDOWN
        &aNGD_time_menu_open_wait, // aNGD_ACTION_PNAME_MENU_OPEN_WAIT
        &aNGD_time_menu_close_wait, // aNGD_ACTION_PNAME_MENU_CLOSE_WAIT
        &aNGD_sex_select_wait, // aNGD_ACTION_SEX_SELECT_WAIT
        &aNGD_sex_select_wait2, // aNGD_ACTION_SEX_SELECT_WAIT2
        &aNGD_sex_select_after, // aNGD_ACTION_SEX_SELECT_AFTER
        &aNGD_time_menu_open_wait, // aNGD_ACTION_CNAME_MENU_OPEN_WAIT
        &aNGD_time_menu_close_wait, // aNGD_ACTION_CNAME_MENU_CLOSE_WAIT
        &aNGD_time_menu_open_wait, // aNGD_ACTION_CENAME_MENU_OPEN_WAIT
        &aNGD_time_menu_close_wait, // aNGD_ACTION_CENAME_MENU_CLOSE_WAIT
        &aNGD_standup_start_wait, // aNGD_ACTION_STANDUP_START_WAIT
        &aNGD_standup, // aNGD_ACTION_STANDUP
        &aNGD_move_ready, // aNGD_ACTION_MOVE_READY
        &aNGD_move_to_aisle, // aNGD_ACTION_MOVE_TO_AISLE
        &aNGD_move_to_door, // aNGD_ACTION_MOVE_TO_DOOR
        &aNGD_move_to_deck, // aNGD_ACTION_MOVE_TO_DECK
        &aNGD_keitai_on, // aNGD_ACTION_KEITAI_ON
        &aNGD_keitai_talk, // aNGD_ACTION_KEITAI_TALK
        &aNGD_standup, // aNGD_ACTION_KEITAI_OFF
        &aNGD_open_door, // aNGD_ACTION_OPEN_DOOR
        &aNGD_return_approach, // aNGD_ACTION_RETURN_APPROACH
        &aNGD_last_talk_start_wait, // aNGD_ACTION_LAST_TALK_START_WAIT
        &aNGD_sitdown2_start_wait, // aNGD_ACTION_SITDOWN2_START_WAIT
        &aNGD_sitdown2, // aNGD_ACTION_SITDOWN2
        &aNGD_last_talk_end_wait, // aNGD_ACTION_LAST_TALK_END_WAIT
        (aNGD_PROC)&none_proc1, // aNGD_ACTION_SCENE_CHANGE_WAIT
        &aNGD_wait_permission_plus, // aNGD_ACTION_WAIT_PERMISSION_PLUS
        &aNGD_sitdown, // aNGD_ACTION_37
        &aNGD_sitdown, // aNGD_ACTION_38
        &aNGD_select_player_plus, // aNGD_ACTION_SELECT_PLAYER_PLUS
        &aNGD_confirm_player, // aNGD_ACTION_CONFIRM_PLAYER
    };

    guide->action = action;
    guide->proc = process[action];
    aNGD_set_animation(guide, action);
    aNGD_init_proc(guide, play, action);
}

static void aNGD_actor_move(ACTOR* actorx, GAME* game) {
    NPC_GUIDE_ACTOR* guide = (NPC_GUIDE_ACTOR*)actorx;
    GAME_PLAY* play = (GAME_PLAY*)game;

    Common_Get(clip).npc_clip->move_before_proc(actorx, game);
    aNGD_talk_demo_proc(actorx, game);
    aNGD_check_talk_msg_no(guide);
    (*guide->proc)(guide, play);
    Common_Get(clip).npc_clip->move_after_proc(actorx, game);
    aNGD_set_camera(guide, play);
    aNGD_set_camera_eyes(guide);
    mSC_change_player_freeze(play);
}
